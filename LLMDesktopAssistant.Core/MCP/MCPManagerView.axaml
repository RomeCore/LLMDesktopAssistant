<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.MCP"
			 xmlns:set="using:LLMDesktopAssistant.Settings"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:flui="using:FluentAvalonia.UI"
			 x:Class="LLMDesktopAssistant.MCP.MCPManagerView"
			 x:DataType="local:MCPManagerViewModel">

	<StackPanel Orientation="Vertical">
		
		<TextBlock Grid.Column="0"
				   Margin="10"
				   Text="{loc:Loc mcp_manager_header}"
				   FontSize="{DynamicResource FontSizeL}"
				   FontWeight="Bold"
				   VerticalAlignment="Center"/>

		<Grid Margin="10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="250"/>
				<ColumnDefinition Width="10"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<StackPanel Grid.Column="0">

				<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
				
					<Button Command="{Binding AddCommand}"
							Classes="IconButton"
							ToolTip.Tip="{loc:Loc add}">
				
						<ico:MaterialIcon Kind="Plus"/>
					</Button>

					<Button Command="{Binding RemoveCommand}"
							Classes="IconButton"
							Margin="5,0,0,0"
							ToolTip.Tip="{loc:Loc remove}">
				
						<ico:MaterialIcon Kind="Delete"/>
					</Button>
				
				</StackPanel>

				<ListBox ItemsSource="{Binding Servers}"
						 SelectedItem="{Binding SelectedServer}">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<StackPanel Orientation="Horizontal">
								<ico:MaterialIcon Kind="LanConnect"
												  Width="16"
												  Margin="0,0,5,0"/>

								<TextBlock Text="{Binding Info.Name}"/>

								<Ellipse Width="8" Height="8"
										 Margin="5,0,0,0"
										 IsVisible="{Binding IsConnected}"
										 Fill="LightGreen"/>
							</StackPanel>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

			</StackPanel>

			<StackPanel Grid.Column="2"
						DataContext="{Binding SelectedServer}"
						IsVisible="{Binding Converter={StaticResource NotnullToBooleanConverter}}">

				<TextBox Text="{Binding Info.Name, Mode=TwoWay}"
						 PlaceholderText="{loc:Loc name}"
						 Margin="0,0,0,15"/>

				<ComboBox SelectedItem="{Binding Info.ConnectionType, Mode=TwoWay}"
						  ItemsSource="{Binding ConnectionTypes}"
						  PlaceholderText="{loc:Loc mcp-connection_type}"
						  Margin="0,0,0,15"/>

				<TextBox Text="{Binding Info.Endpoint, Mode=TwoWay}"
						 PlaceholderText="{loc:Loc mcp-endpoint}"
						 UseFloatingPlaceholder="True"
						 Margin="0,0,0,15"/>

				<Grid HorizontalAlignment="Left">

					<Button Content="{loc:Loc connect}"
							Command="{Binding ConnectCommand}"
							IsVisible="{Binding IsConnected, Converter={StaticResource InverseBooleanConverter}}"/>

					<Button Content="{loc:Loc disconnect}"
							Command="{Binding DisconnectCommand}"
							IsVisible="{Binding IsConnected}"/>

				</Grid>

			</StackPanel>
		</Grid>

	</StackPanel>

</UserControl>
