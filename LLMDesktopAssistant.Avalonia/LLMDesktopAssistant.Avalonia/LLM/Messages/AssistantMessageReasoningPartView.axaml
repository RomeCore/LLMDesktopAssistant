<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Avalonia.LLM.Messages"
			 xmlns:ctrl="using:LLMDesktopAssistant.Avalonia.Controls"
			 xmlns:loc="using:LLMDesktopAssistant.Avalonia.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.Avalonia.LLM.Messages.AssistantMessageReasoningPartView"
			 x:DataType="local:AssistantMessageReasoningPartViewModel">
	
	<Expander Padding="0"
			  BorderThickness="0"
			  Background="Transparent"
			  IsExpanded="{Binding NotCompleted, Mode=OneWay}"
			  ExpandDirection="Right">

		<Expander.Header>
			<TextBlock Text="{loc:Loc reasoning}"
					   VerticalAlignment="Top"
					   FontSize="16"
					   Margin="5"/>
		</Expander.Header>

		<ctrl:MarkdownControl MarkdownText="{Binding ReasoningText}"
							  VerticalAlignment="Center"
							  Opacity="0.7"
							  Margin="0,5"/>

	</Expander>

</UserControl>
