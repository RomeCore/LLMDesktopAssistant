<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.Avalonia.LLM.Messages"
			 xmlns:ctrl="using:LLMDesktopAssistant.Avalonia.Controls"
			 xmlns:loc="using:LLMDesktopAssistant.Avalonia.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.Avalonia.LLM.Messages.AssistantMessageView"
			 x:DataType="local:AssistantMessageViewModel">
	
	<StackPanel Orientation="Vertical"
			VerticalAlignment="Top"
			Margin="40,8">

		<ContentControl Content="{Binding ReasoningPart}"/>
		<ContentControl Content="{Binding TextPart}"/>
		<ContentControl Content="{Binding ToolPart}" Foreground="{DynamicResource MaterialDesignBody}"/>
		<Label Content="{Binding Error}"
			   Foreground="Red"
			   IsVisible="{Binding Error, Converter={StaticResource StringNonEmptyToBooleanConverter}}"/>

		<StackPanel Orientation="Horizontal"
					HorizontalAlignment="Left"
					IsVisible="{Binding IsCompleted}"
					Spacing="4">

			<Button Command="{Binding RegenerateCommand}"
					Classes="IconButton"
					ToolTip.Tip="{loc:Loc regenerate}">
				<ico:MaterialIcon Kind="Refresh"/>
			</Button>

			<Button Command="{Binding ResendCommand}"
					Classes="IconButton"
					IsVisible="{Binding ContainsToolCalls}"
					ToolTip.Tip="{loc:Loc resend}">
				<ico:MaterialIcon Kind="ArrowUDownLeft"/>
			</Button>

			<Button Command="{Binding ResendCommand}"
					Classes="IconButton"
					IsVisible="{Binding ContainsToolCalls, Converter={StaticResource InverseBooleanConverter}}"
					ToolTip.Tip="{loc:Loc resend}">
				<ico:MaterialIcon Kind="ChevronDoubleDown"/>
			</Button>

			<StackPanel Orientation="Horizontal"
						IsVisible="{Binding BranchSelectionAvailable}"
						Spacing="4">

				<Button Command="{Binding SwitchBranchCommand}"
						Classes="IconButton"
						CommandParameter="{Binding PreviousBranchIndex}">
					<ico:MaterialIcon Kind="ChevronLeft"/>
				</Button>

				<ComboBox ItemsSource="{Binding BranchIndices}"
						  SelectedItem="{Binding SelectedBranchIndex}"
						  Foreground="{DynamicResource MaterialDesignBody}"/>

				<Button Command="{Binding SwitchBranchCommand}"
						Classes="IconButton"
						CommandParameter="{Binding NextBranchIndex}">
					<ico:MaterialIcon Kind="ChevronRight"/>
				</Button>

			</StackPanel>

		</StackPanel>

		<Grid IsVisible="{Binding IsCompleted, Converter={StaticResource InverseBooleanConverter}}">

			<ProgressBar IsIndeterminate="True" Height="5" Margin="0,5"/>

		</Grid>

	</StackPanel>

</UserControl>
