<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Avalonia.LLM"
			 xmlns:beh="clr-namespace:LLMDesktopAssistant.Avalonia.Behaviours"
			 x:Class="LLMDesktopAssistant.Avalonia.LLM.ChatView"
			 x:DataType="local:ChatViewModel">
	
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Messages Area -->
		<ScrollViewer Grid.Row="0"
					  VerticalScrollBarVisibility="Auto"
					  beh:ScrollViewerBehavior.AutoScrollEnabled="True">

			<ContentControl Content="{Binding MessageSequence}"/>
		</ScrollViewer>

		<!-- Input Area -->
		<Border Grid.Row="1"
				Padding="16,8"
				Background="{DynamicResource MaterialDesignPaper}"
				BorderBrush="{DynamicResource MaterialDesignDivider}"
				BorderThickness="0,1,0,0">

			<ContentControl Content="{Binding UserInput}"/>
		</Border>
	</Grid>
	
</UserControl>
