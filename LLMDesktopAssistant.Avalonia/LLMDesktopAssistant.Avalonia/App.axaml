<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="LLMDesktopAssistant.Avalonia.App"
			 xmlns:mvvm="using:LLMDesktopAssistant.Avalonia.MVVM"
			 RequestedThemeVariant="Dark">
  
	<Application.Styles>
		<FluentTheme />
	</Application.Styles>

	<Application.DataTemplates>
		<mvvm:ViewLocator />
	</Application.DataTemplates>

	<Application.Resources>
		<ResourceDictionary>
			
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://LLMDesktopAssistant.Avalonia/Styles/General.axaml"/>
			</ResourceDictionary.MergedDictionaries>

		</ResourceDictionary>
	</Application.Resources>

</Application>