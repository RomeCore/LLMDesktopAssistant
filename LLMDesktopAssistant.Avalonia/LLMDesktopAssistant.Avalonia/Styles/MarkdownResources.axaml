<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<x:Double x:Key="FontSizeS">14</x:Double>
	<x:Double x:Key="FontSizeM">17</x:Double>
	<x:Double x:Key="FontSizeL">20</x:Double>
	<x:Double x:Key="FontSizeXl">22</x:Double>
	<x:Double x:Key="FontSize2Xl">26</x:Double>
	<x:Double x:Key="FontSize3Xl">30</x:Double>

</ResourceDictionary>