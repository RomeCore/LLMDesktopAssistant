@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page @(_isChatPage ? "chat-page" : "")">
    @if (!_isChatPage)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="@(_isChatPage ? "chat-main" : "")">
        @if (!_isChatPage)
        {
            <div class="top-row px-4">
                <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            </div>
        }

        <article class="content @(_isChatPage ? "chat-content" : "px-4")">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _isChatPage = false;

    protected override void OnInitialized()
    {
        _isChatPage = Navigation.Uri.EndsWith("/chat") || Navigation.Uri.Contains("/chat");
    }
}
