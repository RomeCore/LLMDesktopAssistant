@page "/register"
@using Material.Icons
@using LLMDesktopAssistant.Blazor.Services
@using LLMDesktopAssistant.WebUI
@inject IUserManagementService UserManager
@inject NavigationManager Navigation
@rendermode InteractiveServer

<div class="auth-page">
	<div class="auth-card">
		<div class="auth-header">
			<div class="auth-icon">
				<MaterialIconComponent Kind="@MaterialIconKind.AccountPlus" Size="48" Color="#0078d4" />
			</div>
			<h1 class="auth-title">Регистрация</h1>
			<p class="auth-subtitle">Создай аккаунт</p>
		</div>

		@if (_errorMessage != null)
		{
			<div class="auth-error">
				<MaterialIconComponent Kind="@MaterialIconKind.AlertCircle" Size="16" Color="#d32f2f" />
				<span>@_errorMessage</span>
			</div>
		}

		@if (_successMessage != null)
		{
			<div class="auth-success">
				<MaterialIconComponent Kind="@MaterialIconKind.CheckCircle" Size="16" Color="#2e7d32" />
				<span>@_successMessage</span>
			</div>
		}

		<div class="auth-form">
			<div class="auth-field">
				<label for="reg-login">Логин</label>
				<input id="reg-login"
					   type="text"
					   @bind="_login"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Придумай логин..."
					   disabled="@_isLoading" />
			</div>

			<div class="auth-field">
				<label for="reg-name">Имя</label>
				<input id="reg-name"
					   type="text"
					   @bind="_name"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Твоё имя"
					   disabled="@_isLoading" />
			</div>

			<div class="auth-field">
				<label for="reg-password">Пароль</label>
				<input id="reg-password"
					   type="password"
					   @bind="_password"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Придумай пароль..."
					   disabled="@_isLoading" />
			</div>

			<div class="auth-field">
				<label for="reg-password-confirm">Подтверди пароль</label>
				<input id="reg-password-confirm"
					   type="password"
					   @bind="_passwordConfirm"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Повтори пароль..."
					   disabled="@_isLoading" />
			</div>

			<button class="auth-btn"
					@onclick="Register">
				@if (_isLoading)
				{
					<span class="auth-spinner"></span>
					<span>Идет регистрация...</span>
				}
				else
				{
					<MaterialIconComponent Kind="@MaterialIconKind.AccountPlus" Size="18" Color="white" />
					<span>Зарегистрироваться</span>
				}
			</button>

			<div class="auth-footer">
				<span>Уже есть аккаунт?</span>
				<a href="/login" class="auth-link">Войти</a>
			</div>
		</div>
	</div>
</div>

@code {
	private string _login = string.Empty;
	private string _name = string.Empty;
	private string _password = string.Empty;
	private string _passwordConfirm = string.Empty;
	private bool _isLoading = false;
	private string? _errorMessage = null;
	private string? _successMessage = null;

	private async Task Register()
	{
		if (_isLoading) return;

		if (_password != _passwordConfirm)
		{
			_errorMessage = "Пароли не совпадают!";
			return;
		}

		if (_password.Length < 4)
		{
			_errorMessage = "Пароль слишком короткий! Минимум 4 символа.";
			return;
		}

		_isLoading = true;
		_errorMessage = null;
		_successMessage = null;
		StateHasChanged();

		try
		{
			var registeredUser = UserManager.RegisterUser(
				_login.Trim(),
				_password,
				string.IsNullOrWhiteSpace(_name) ? _login.Trim() : _name.Trim(),
				null
			);

			if (registeredUser != null)
			{
				_successMessage = "Аккаунт создан! Теперь можно войти";
				_login = string.Empty;
				_password = string.Empty;
				_passwordConfirm = string.Empty;
			}
			else
			{
				_errorMessage = "Пользователь с таким логином уже существует";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = $"Ошибка: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}
}
