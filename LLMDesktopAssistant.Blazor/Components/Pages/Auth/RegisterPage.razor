@page "/register"
@using LLMDesktopAssistant.Blazor.Services
@using LLMDesktopAssistant.Users
@using Material.Icons

@inject IUserManagementService UserManager
@inject NavigationManager Navigation

@rendermode InteractiveServer

<div class="auth-page">
	<div class="auth-card">
		<div class="auth-header">
			<div class="auth-icon">
				<MaterialIconComponent Kind="@MaterialIconKind.AccountPlus" Size="48" Color="#0078d4" />
			</div>
			<h1 class="auth-title">@LocalizationManager.LocalizeStatic("webui_register_title")</h1>
			<p class="auth-subtitle">@LocalizationManager.LocalizeStatic("webui_register_subtitle")</p>
		</div>

		@if (_errorMessage != null)
		{
			<div class="auth-error">
				<MaterialIconComponent Kind="@MaterialIconKind.AlertCircle" Size="16" Color="#d32f2f" />
				<span>@_errorMessage</span>
			</div>
		}

		@if (_successMessage != null)
		{
			<div class="auth-success">
				<MaterialIconComponent Kind="@MaterialIconKind.CheckCircle" Size="16" Color="#2e7d32" />
				<span>@_successMessage</span>
			</div>
		}

		<div class="auth-form">
			<div class="auth-field">
				<label for="reg-login">@LocalizationManager.LocalizeStatic("webui_login_label")</label>
				<input id="reg-login"
					   type="text"
					   @bind="_login"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="@LocalizationManager.LocalizeStatic("webui_register_placeholder_login")"
					   disabled="@_isLoading" />
			</div>

			<div class="auth-field">
				<label for="reg-name">@LocalizationManager.LocalizeStatic("webui_profile_name")</label>
				<input id="reg-name"
					   type="text"
					   @bind="_name"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="@LocalizationManager.LocalizeStatic("webui_register_placeholder_name")"
					   disabled="@_isLoading" />
			</div>

			<div class="auth-field">
				<label for="reg-password">@LocalizationManager.LocalizeStatic("webui_password_label")</label>
				<input id="reg-password"
					   type="password"
					   @bind="_password"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="@LocalizationManager.LocalizeStatic("webui_register_placeholder_password")"
					   disabled="@_isLoading" />
			</div>

			<div class="auth-field">
				<label for="reg-password-confirm">@LocalizationManager.LocalizeStatic("webui_register_placeholder_confirm")</label>
				<input id="reg-password-confirm"
					   type="password"
					   @bind="_passwordConfirm"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="@LocalizationManager.LocalizeStatic("webui_register_placeholder_confirm")"
					   disabled="@_isLoading" />
			</div>

			<button class="auth-btn"
					@onclick="Register">
				@if (_isLoading)
				{
					<span class="auth-spinner"></span>
					<span>@LocalizationManager.LocalizeStatic("webui_register_loading")</span>
				}
				else
				{
					<MaterialIconComponent Kind="@MaterialIconKind.AccountPlus" Size="18" Color="white" />
					<span>@LocalizationManager.LocalizeStatic("webui_register_btn")</span>
				}
			</button>

			<div class="auth-footer">
				<span>@LocalizationManager.LocalizeStatic("webui_register_have_account")</span>
				<a href="/login" class="auth-link">@LocalizationManager.LocalizeStatic("webui_register_login_link")</a>
			</div>
		</div>
	</div>
</div>

@code {
	private string _login = string.Empty;
	private string _name = string.Empty;
	private string _password = string.Empty;
	private string _passwordConfirm = string.Empty;
	private bool _isLoading = false;
	private string? _errorMessage = null;
	private string? _successMessage = null;

	private async Task Register()
	{
		if (_isLoading) return;

		if (_password != _passwordConfirm)
		{
			_errorMessage = LocalizationManager.LocalizeStatic("webui_register_error_password_mismatch");
			return;
		}

		if (_password.Length < 4)
		{
			_errorMessage = LocalizationManager.LocalizeStatic("webui_register_error_password_short");
			return;
		}

		_isLoading = true;
		_errorMessage = null;
		_successMessage = null;
		StateHasChanged();

		try
		{
			var registeredUser = UserManager.RegisterUser(
				_login.Trim(),
				_password,
				string.IsNullOrWhiteSpace(_name) ? _login.Trim() : _name.Trim(),
				null
			);

			if (registeredUser != null)
			{
				_successMessage = LocalizationManager.LocalizeStatic("webui_register_success");
				_login = string.Empty;
				_password = string.Empty;
				_passwordConfirm = string.Empty;
			}
			else
			{
				_errorMessage = LocalizationManager.LocalizeStatic("webui_register_error_exists");
			}
		}
		catch (Exception ex)
		{
			_errorMessage = $"Ошибка: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}
}
