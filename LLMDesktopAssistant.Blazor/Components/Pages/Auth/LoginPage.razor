@page "/login"

@using Microsoft.AspNetCore.Authorization
@using Material.Icons

@inject NavigationManager Navigation
@inject WebUI.WebUIStartupSettings Settings
@inject IJSRuntime JS

@rendermode InteractiveServer

@implements IDisposable

@attribute [AllowAnonymous]

<div class="auth-page">
	<div class="auth-card">
		<div class="auth-header">
			<div class="auth-icon">
				<MaterialIconComponent Kind="@MaterialIconKind.ShieldAccount" Size="48" Color="#0078d4" />
			</div>
			<h1 class="auth-title">dASS WebUI</h1>
			<p class="auth-subtitle">Войдите в аккаунт</p>
		</div>

		@if (_errorMessage != null)
		{
			<div class="auth-error">
				<MaterialIconComponent Kind="@MaterialIconKind.AlertCircle" Size="16" Color="#d32f2f" />
				<span>@_errorMessage</span>
			</div>
		}

		<div class="auth-form">
			<div class="auth-field">
				<label for="login-input">Логин</label>
				<input id="login-input"
					   type="text"
					   @bind="_login"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Введите логин..."
					   disabled="@_isLoading"
					   @onkeydown="HandleKeyDown" />
			</div>

			<div class="auth-field">
				<label for="password-input">Пароль</label>
				<input id="password-input"
					   type="password"
					   @bind="_password"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Введите пароль..."
					   disabled="@_isLoading"
					   @onkeydown="HandleKeyDown" />
			</div>

			@if (Settings.PasswordHash != null)
			{
				<div class="auth-field">
					<label for="master-password-input">Пароль для входа в чат</label>
					<input id="master-password-input"
						   type="password"
						   @bind="_masterPassword"
						   @bind:event="oninput"
						   class="auth-input"
						   placeholder="Введите мастер-пароль..."
						   disabled="@_isLoading"
						   @onkeydown="HandleKeyDown" />
				</div>
			}

			<button class="auth-btn"
					@onclick="Login"
					disabled="@(_isLoading || string.IsNullOrWhiteSpace(_login))">
				@if (_isLoading)
				{
					<span class="auth-spinner"></span>
					<span>Signing in...</span>
				}
				else
				{
					<MaterialIconComponent Kind="@MaterialIconKind.Login" Size="18" Color="white" />
					<span>Войти</span>
				}
			</button>

			<div class="auth-footer">
				<span>Нет аккаунта?</span>
				<a href="/register" class="auth-link">Создать</a>
			</div>
		</div>
	</div>
</div>

@code {
	private string _login = string.Empty;
	private string _password = string.Empty;
	private string _masterPassword = string.Empty;
	private bool _isLoading = false;
	private string? _errorMessage = null;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var isAuthed = await JS.InvokeAsync<bool>("checkAuth");
			if (isAuthed)
			{
				Navigation.NavigateTo("/", forceLoad: true);
			}
		}
		catch
		{
			// Not authenticated, show login form
		}
	}

	private async Task HandleKeyDown(KeyboardEventArgs e)
	{
		if (e.Key == "Enter")
		{
			await Login();
		}
	}

	private async Task Login()
	{
		if (string.IsNullOrWhiteSpace(_login) || _isLoading)
			return;

		_isLoading = true;
		_errorMessage = null;
		StateHasChanged();

		try
		{
			var requireMasterPass = Settings.PasswordHash != null;
			var success = await JS.InvokeAsync<bool>("loginUser", _login.Trim(), _password, requireMasterPass ? _masterPassword : null);

			if (success)
			{
				Navigation.NavigateTo("/");
			}
			else
			{
				_errorMessage = "Некорректный логин или пароль. Попробуйте снова.";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = $"Error: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}

	public void Dispose()
	{
	}
}
