@page "/login"
@using Material.Icons
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

@implements IDisposable

<div class="auth-page">
	<div class="auth-card">
		<div class="auth-header">
			<div class="auth-icon">
				<MaterialIconComponent Kind="@MaterialIconKind.ShieldAccount" Size="48" Color="#0078d4" />
			</div>
			<h1 class="auth-title">dASS WebUI</h1>
			<p class="auth-subtitle">Sign in to your account</p>
		</div>

		@if (_errorMessage != null)
		{
			<div class="auth-error">
				<MaterialIconComponent Kind="@MaterialIconKind.AlertCircle" Size="16" Color="#d32f2f" />
				<span>@_errorMessage</span>
			</div>
		}

		<div class="auth-form">
			<div class="auth-field">
				<label for="login-input">Login</label>
				<input id="login-input"
					   type="text"
					   @bind="_login"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Enter your login..."
					   disabled="@_isLoading"
					   @onkeydown="HandleKeyDown" />
			</div>

			<div class="auth-field">
				<label for="password-input">Password</label>
				<input id="password-input"
					   type="password"
					   @bind="_password"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Enter your password..."
					   disabled="@_isLoading"
					   @onkeydown="HandleKeyDown" />
			</div>

			<button class="auth-btn"
					@onclick="Login"
					disabled="@(_isLoading || string.IsNullOrWhiteSpace(_login))">
				@if (_isLoading)
				{
					<span class="auth-spinner"></span>
					<span>Signing in...</span>
				}
				else
				{
					<MaterialIconComponent Kind="@MaterialIconKind.Login" Size="18" Color="white" />
					<span>Sign In</span>
				}
			</button>

			<div class="auth-footer">
				<span>Don't have an account?</span>
				<a href="/register" class="auth-link">Create one</a>
			</div>
		</div>
	</div>
</div>

@code {
	private string _login = string.Empty;
	private string _password = string.Empty;
	private bool _isLoading = false;
	private string? _errorMessage = null;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var isAuthed = await JS.InvokeAsync<bool>("checkAuth");
			if (isAuthed)
			{
				Navigation.NavigateTo("/chat", forceLoad: true);
			}
		}
		catch
		{
			// Not authenticated, show login form
		}
	}

	private async Task HandleKeyDown(KeyboardEventArgs e)
	{
		if (e.Key == "Enter")
		{
			await Login();
		}
	}

	private async Task Login()
	{
		if (string.IsNullOrWhiteSpace(_login) || _isLoading)
			return;

		_isLoading = true;
		_errorMessage = null;
		StateHasChanged();

		try
		{
			var success = await JS.InvokeAsync<bool>("loginUser", _login.Trim(), _password);

			if (success)
			{
				Navigation.NavigateTo("/chat");
			}
			else
			{
				_errorMessage = "Invalid login or password.";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = $"Error: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}

	public void Dispose()
	{
	}
}
