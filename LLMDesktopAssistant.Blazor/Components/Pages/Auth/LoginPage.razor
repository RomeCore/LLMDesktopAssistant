@page "/login"
@using Material.Icons
@using LLMDesktopAssistant.Blazor.Services
@inject WebUIAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

@implements IDisposable

<div class="auth-page">
	<div class="auth-card">
		<div class="auth-header">
			<div class="auth-icon">
				<MaterialIconComponent Kind="@MaterialIconKind.ShieldAccount" Size="48" Color="#0078d4" />
			</div>
			<h1 class="auth-title">dASS WebUI</h1>
			<p class="auth-subtitle">Авторизация</p>
		</div>

		@if (_errorMessage != null)
		{
			<div class="auth-error">
				<MaterialIconComponent Kind="@MaterialIconKind.AlertCircle" Size="16" Color="#d32f2f" />
				<span>@_errorMessage</span>
			</div>
		}

		<div class="auth-form">
			<div class="auth-field">
				<label for="login-input">Логин</label>
				<input id="login-input"
					   type="text"
					   @bind="_login"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Введи логин..."
					   disabled="@_isLoading"
					   @onkeydown="HandleKeyDown" />
			</div>

			<div class="auth-field">
				<label for="password-input">Пароль</label>
				<input id="password-input"
					   type="password"
					   @bind="_password"
					   @bind:event="oninput"
					   class="auth-input"
					   placeholder="Введи пароль..."
					   disabled="@_isLoading"
					   @onkeydown="HandleKeyDown" />
			</div>

			<button class="auth-btn"
					@onclick="Login"
					disabled="@(_isLoading || string.IsNullOrWhiteSpace(_login))">
				@if (_isLoading)
				{
					<span class="auth-spinner"></span>
					<span>Вхожу...</span>
				}
				else
				{
					<MaterialIconComponent Kind="@MaterialIconKind.Login" Size="18" Color="white" />
					<span>Войти</span>
				}
			</button>

			<div class="auth-footer">
				<span>Нет аккаунта?</span>
				<a href="/register" class="auth-link">Зарегистрироваться</a>
			</div>
		</div>
	</div>
</div>

@code {
	private string _login = string.Empty;
	private string _password = string.Empty;
	private bool _isLoading = false;
	private string? _errorMessage = null;
	private CancellationTokenSource? _redirectCts;

	protected override async Task OnInitializedAsync()
	{
		var state = await AuthProvider.GetAuthenticationStateAsync();
		if (state.User.Identity?.IsAuthenticated == true)
		{
			Navigation.NavigateTo("/chat");
		}
	}

	private async Task HandleKeyDown(KeyboardEventArgs e)
	{
		if (e.Key == "Enter")
		{
			await Login();
		}
	}

	private async Task Login()
	{
		if (string.IsNullOrWhiteSpace(_login) || _isLoading)
			return;

		_isLoading = true;
		_errorMessage = null;
		StateHasChanged();

		try
		{
			var success = await AuthProvider.LoginAsync(_login.Trim(), _password);

			if (success)
			{
				_redirectCts?.Cancel();
				_redirectCts = new CancellationTokenSource();
				
				await Task.Delay(200, _redirectCts.Token);
				
				Navigation.NavigateTo("/chat", forceLoad: false);
			}
			else
			{
				_errorMessage = "Неверный логин или пароль!";
			}
		}
		catch (Exception ex)
		{
			_errorMessage = $"Ошибка: {ex.Message}";
		}
		finally
		{
			_isLoading = false;
			StateHasChanged();
		}
	}

	public void Dispose()
	{
		_redirectCts?.Cancel();
		_redirectCts?.Dispose();
	}
}
