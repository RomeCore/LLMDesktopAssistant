@page "/counter"
@using LLMDesktopAssistant.LLM.Domain
@using Serilog
@inject Chat chat
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

@code {
	private int currentCount = 0;

	public Counter()
	{
		Log.Information("Chat: {Chat}", chat);
		currentCount = chat.Messages.Count;
		chat.Messages.PropertyChanged += (s, e) => currentCount = chat.Messages.Count;
	}
}
