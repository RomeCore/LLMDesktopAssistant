@page "/chat"

@using Microsoft.AspNetCore.Authorization
@using LLMDesktopAssistant.Blazor.Services
@using LLMDesktopAssistant.Blazor.Components.Messages
@using LLMDesktopAssistant.LLM.Domain
@using LLMDesktopAssistant.LLM.Services
@using LLMDesktopAssistant.WebUI
@using Material.Icons

@implements IDisposable

@inject NavigationManager NavigationManager
@inject WebUIAuthenticationStateProvider AuthProvider
@inject Chat chat
@inject IChatOperationService chatOperation
@inject IUserManagementService userManager
@inject IJSRuntime JS

@attribute [Authorize]

@rendermode InteractiveServer

<div class="chat-layout">

	<div class="chat-topbar">
		<div class="chat-topbar-left">
			<MaterialIconComponent Kind="@MaterialIconKind.ShieldAccount" Size="20" Color="#0078d4" />
			<span class="chat-topbar-user">@(AuthProvider.GetCurrentUser()?.Name ?? "Anonymous")</span>
		</div>
		<div class="chat-topbar-right">
			<button class="chat-topbar-profile-btn" @onclick="ToggleProfileOverlay" title="Настройки профиля">
				<MaterialIconComponent Kind="@MaterialIconKind.AccountSettings" Size="18" Color="#666" />
				<span>Профиль</span>
			</button>
		</div>
	</div>
	<div class="chat-messages-container" id="messages-container">
		<MessageSequenceComponent Messages="@chat.Messages" />
		<ChatStatusComponent />
	</div>

	<div class="chat-input-area">
		<div class="chat-input-row">
			<input class="chat-input"
				   @bind="_inputText"
				   @bind:event="oninput"
				   @onkeydown="HandleKeyDown"
				   placeholder="Введите сообщение..."
				   disabled="@_isGenerating" />

			@* Send message without generation *@
			<button class="chat-send-btn"
					@onclick="SendMessageWithoutGeneration"
					disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isGenerating)">
				<MaterialIconComponent Kind="@MaterialIconKind.SendClock" Size="18" Color="white" />
			</button>

			@if (_isGenerating)
			{
				@* Stop / Cancel generation *@
				<button class="chat-stop-btn" title="Stop generation" @onclick="StopGeneration">
					<MaterialIconComponent Kind="@MaterialIconKind.Stop" Size="20" Color="white" />
				</button>
			}
			else
			{
				@* Send message *@
				<button class="chat-send-btn"
						@onclick="SendMessageWithGeneration"
						disabled="@string.IsNullOrWhiteSpace(_inputText)">
					<MaterialIconComponent Kind="@MaterialIconKind.Send" Size="18" Color="white" />
				</button>
			}
		</div>
	</div>
</div>

<UserProfileOverlay IsVisible="_showProfileOverlay"
					User="@(AuthProvider.GetCurrentUser())"
					OnClose="CloseProfileOverlay" />

@code {
	private string _inputText = string.Empty;
	private bool _isGenerating = false;
	private bool _showProfileOverlay = false;
	private PeriodicTimer? _autoScrollTimer;
	private CancellationTokenSource? _autoScrollCts;

	// Chat Status

	protected override async Task OnInitializedAsync()
	{
		await base.OnInitializedAsync();

		chat.Messages.CollectionChanged += MessagesChanged;
		chat.PropertyChanged += ChatPropertyChanged;
		_isGenerating = chat.GenerationCts != null;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		await base.OnAfterRenderAsync(firstRender);

		await ScrollToBottom();
	}

	private async void MessagesChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
	{
		await InvokeAsync(StateHasChanged);
		await ScrollToBottom();
	}

	private void ChatPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
	{
		if (e.PropertyName == nameof(Chat.GenerationCts))
		{
			InvokeAsync(() =>
			{
				_isGenerating = chat.GenerationCts != null;
				StateHasChanged();

				if (_isGenerating)
				{
					StartAutoScroll();
				}
				else
				{
					StopAutoScroll();
				}
			});
		}
	}

	private void StartAutoScroll()
	{
		StopAutoScroll();

		_autoScrollCts = new CancellationTokenSource();
		var token = _autoScrollCts.Token;

		_ = Task.Run(async () =>
		{
			using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(100));
			try
			{
				while (await timer.WaitForNextTickAsync(token))
				{
					await InvokeAsync(async () =>
					{
						await ScrollToBottom();
					});
				}
			}
			catch (OperationCanceledException) { }
		}, token);
	}

	private void StopAutoScroll()
	{
		_autoScrollCts?.Cancel();
		_autoScrollCts?.Dispose();
		_autoScrollCts = null;
	}

	private async Task HandleKeyDown(KeyboardEventArgs e)
	{
		if (e.Key == "Enter" && !e.ShiftKey)
		{
			await SendMessage(generate: true);
		}
	}

	private async Task SendMessage(bool generate)
	{
		if (_isGenerating)
			return;

		var text = _inputText?.Trim();
		if (string.IsNullOrWhiteSpace(text))
			return;

		_inputText = string.Empty;

		try
		{
			var user = AuthProvider.GetCurrentUser();
			var senderLogin = user?.Login ?? "anonymous";

			await chatOperation.SendUserInputAsync(new UserInput
			{
				Content = text,
				SenderLogin = senderLogin,
				Attachments = [],
				Visibility = MessageVisibility.Always,
				VisibleTo = []
			}, generate);
		}
		catch (Exception ex)
		{
			Console.Error.WriteLine($"Failed to send message: {ex.Message}");
		}
	}

	private Task SendMessageWithoutGeneration() => SendMessage(false);
	private Task SendMessageWithGeneration() => SendMessage(true);

	private void StopGeneration()
	{
		try
		{
			chat.GenerationCts?.Cancel();
		}
		catch (Exception ex)
		{
			Console.Error.WriteLine($"Failed to stop generation: {ex.Message}");
		}
	}

	private async Task ScrollToBottom()
	{
		try
		{
			await JS.InvokeVoidAsync("scrollToBottomIfNeeded", "messages-container");
		}
		catch { }
	}

	private void ToggleProfileOverlay() => _showProfileOverlay = !_showProfileOverlay;
	private void CloseProfileOverlay() => _showProfileOverlay = false;

	public void Dispose()
	{
		chat.Messages.CollectionChanged -= MessagesChanged;
		StopAutoScroll();
	}
}
