@page "/"

@using LLMDesktopAssistant.Blazor.Components.Messages
@using LLMDesktopAssistant.Blazor.Services
@using LLMDesktopAssistant.LLM.Domain
@using LLMDesktopAssistant.LLM.Services
@using LLMDesktopAssistant.Users
@using Material.Icons
@using Microsoft.AspNetCore.Authorization

@implements IDisposable

@inject NavigationManager Navigation
@inject IUserStateService UserState
@inject Chat chat
@inject IChatOperationService chatOperation
@inject IUserManagementService userManager
@inject IJSRuntime JS

@rendermode InteractiveServer

@attribute [Authorize]

<div class="chat-layout">

	<div class="chat-topbar">
		<div class="chat-topbar-left">
			<MaterialIconComponent Kind="@MaterialIconKind.ShieldAccount" Size="20" Color="#0078d4" />
			<span class="chat-topbar-user">@(UserState.GetCurrentUser()?.Name ?? LocalizationManager.LocalizeStatic("webui_anonymous"))</span>
		</div>
		<div class="chat-topbar-right">
			<button class="chat-topbar-profile-btn" @onclick="ToggleProfileOverlay" title="@LocalizationManager.LocalizeStatic("webui_profile_title_attr")">
				<MaterialIconComponent Kind="@MaterialIconKind.AccountSettings" Size="18" Color="#666" />
				<span>@LocalizationManager.LocalizeStatic("webui_profile_btn")</span>
			</button>
		</div>
	</div>
	<div class="chat-messages-container" id="messages-container">
		<MessageSequenceComponent Messages="@chat.Messages" />
		<ChatStatusComponent />
	</div>

	<div class="chat-input-area">
		<div class="chat-input-row">
			<input class="chat-input"
				   @bind="_inputText"
				   @bind:event="oninput"
				   @onkeydown="HandleKeyDown"
				   placeholder="@LocalizationManager.LocalizeStatic("webui_chat_input_placeholder")"
				   disabled="@_isGenerating" />

			@* Send message without generation *@
			<button class="chat-send-btn"
					@onclick="SendMessageWithoutGeneration"
					disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isGenerating)">
				<MaterialIconComponent Kind="@MaterialIconKind.SendClock" Size="18" Color="white" />
			</button>

			@if (_isGenerating)
			{
				@* Stop / Cancel generation *@
				<button class="chat-stop-btn" title="@LocalizationManager.LocalizeStatic("webui_stop_generation")" @onclick="StopGeneration">
					<MaterialIconComponent Kind="@MaterialIconKind.Stop" Size="20" Color="white" />
				</button>
			}
			else
			{
				@* Send message *@
				<button class="chat-send-btn"
						@onclick="SendMessageWithGeneration"
						disabled="@string.IsNullOrWhiteSpace(_inputText)">
					<MaterialIconComponent Kind="@MaterialIconKind.Send" Size="18" Color="white" />
				</button>
			}
		</div>

		<div class="chat-input-row chat-input-tools">
			<select class="chat-visibility-select"
					@bind="_selectedVisibility"
					title="@LocalizationManager.LocalizeStatic("user_message_visibility_hint")">
				@foreach (var vis in _visibilityOptions)
				{
					<option value="@vis.Key">@vis.Value</option>
				}
			</select>

			<ReadinessPanel />
		</div>
	</div>
</div>

<UserProfileOverlay IsVisible="_showProfileOverlay"
					User="@(UserState.GetCurrentUser())"
					OnClose="CloseProfileOverlay" />

@code {
	private string _inputText = string.Empty;
	private bool _isGenerating = false;
	private bool _showProfileOverlay = false;

	/// <summary>
	/// When <see langword="true"/>, the MutationObserver on JS side will auto-scroll
	/// as new content arrives.
	/// </summary>
	private bool _autoScrollEnabled = false;

	/// <summary>
	/// When <see langword="true"/>, the next render will scroll to bottom.
	/// Used after sending a message (without generation) to ensure the new message is visible.
	/// </summary>
	private bool _pendingScroll = false;

	private MessageVisibility _selectedVisibility = MessageVisibility.Always;
	private Dictionary<MessageVisibility, string> _visibilityOptions = new()
	{
		{ MessageVisibility.Always, LocalizationManager.LocalizeStatic("message_visibility_always") },
		{ MessageVisibility.RevealAfterSend, LocalizationManager.LocalizeStatic("message_visibility_reveal_after_send") },
		{ MessageVisibility.OnlyUsers, LocalizationManager.LocalizeStatic("message_visibility_only_users") },
		{ MessageVisibility.OnlyAgents, LocalizationManager.LocalizeStatic("message_visibility_only_agents") },
	};

	protected override async Task OnInitializedAsync()
	{
		await base.OnInitializedAsync();

		chat.Messages.CollectionChanged += MessagesChanged;
		chat.PropertyChanged += ChatPropertyChanged;
		_isGenerating = chat.GenerationCts != null;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		await base.OnAfterRenderAsync(firstRender);

		if (firstRender)
		{
			// Set up the observer once on first render — it will watch for DOM changes
			await JS.InvokeVoidAsync("ChatScroll.init", "messages-container");
			await ScrollToBottom(true);
		}
		else if (_pendingScroll)
		{
			_pendingScroll = false;
			await ScrollToBottom(true);
		}
	}

	private async void MessagesChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
	{
		await InvokeAsync(StateHasChanged);

		// JS observer handles auto-scroll when _autoScrollEnabled is active.
		// No need to call JS interop here for every change.
	}

	private void ChatPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
	{
		if (e.PropertyName == nameof(Chat.GenerationCts))
		{
			InvokeAsync(() =>
			{
				_isGenerating = chat.GenerationCts != null;
				StateHasChanged();

				if (_isGenerating)
				{
					StartAutoScroll();
				}
				else
				{
					StopAutoScroll();
				}
			});
		}
	}

	private void StartAutoScroll()
	{
		_autoScrollEnabled = true;

		// Enable the JS observer and scroll to bottom immediately
		_ = JS.InvokeVoidAsync("ChatScroll.enable");
	}

	private void StopAutoScroll()
	{
		_autoScrollEnabled = false;

		// Disable the JS observer and do one final smooth scroll
		_ = JS.InvokeVoidAsync("ChatScroll.disable");
		_ = ScrollToBottom(true);
	}

	private async Task HandleKeyDown(KeyboardEventArgs e)
	{
		if (e.Key == "Enter" && !e.ShiftKey)
		{
			await SendMessage(generate: false);
		}
	}

	private async Task SendMessage(bool generate)
	{
		if (_isGenerating)
			return;

		var text = _inputText?.Trim();
		if (string.IsNullOrWhiteSpace(text))
			return;

		_inputText = string.Empty;

		try
		{
			var user = UserState.GetCurrentUser();
			var senderLogin = user?.Login ?? "anonymous";

			await chatOperation.SendUserInputAsync(new UserInput
			{
				Content = text,
				SenderLogin = senderLogin,
				Attachments = [],
				Visibility = _selectedVisibility,
				VisibleTo = []
			}, generate);

			// Mark for scroll on next render so the sent message is visible
			_pendingScroll = true;
		}
		catch (Exception ex)
		{
			Console.Error.WriteLine($"Failed to send message: {ex.Message}");
		}
	}

	private Task SendMessageWithoutGeneration() => SendMessage(false);
	private Task SendMessageWithGeneration() => SendMessage(true);

	private void StopGeneration()
	{
		try
		{
			chat.GenerationCts?.Cancel();
		}
		catch (Exception ex)
		{
			Console.Error.WriteLine($"Failed to stop generation: {ex.Message}");
		}
	}

	private async Task ScrollToBottom(bool smooth = true)
	{
		try
		{
			await JS.InvokeVoidAsync("ChatScroll.scrollToBottom", smooth);
		}
		catch { }
	}

	private void ToggleProfileOverlay() => _showProfileOverlay = !_showProfileOverlay;
	private void CloseProfileOverlay() => _showProfileOverlay = false;

	public void Dispose()
	{
		chat.Messages.CollectionChanged -= MessagesChanged;
		_ = JS.InvokeVoidAsync("ChatScroll.destroy");
	}
}
