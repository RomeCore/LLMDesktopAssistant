@using System.ComponentModel
@using LLMDesktopAssistant.LLM.Domain
@using LLMDesktopAssistant.LLM.Messages
@using LLMDesktopAssistant.Localization
@implements IDisposable
@rendermode InteractiveServer

<div class="toolcall-item" data-status="@_status">
	<span class="toolcall-icon">@GetToolStatusIcon()</span>
	<span class="toolcall-name">@_title</span>
	@if (!string.IsNullOrWhiteSpace(_statusTitle))
	{
		<span class="toolcall-status"><MarkdownComponent MarkdownText="@_statusTitle" /></span>
	}

	@if (false)
	{
		@if (_showArgs)
		{
			<div class="toolcall-args">
				<MarkdownComponent MarkdownText="@_argsPreview" />
			</div>
		}

		@if (!string.IsNullOrWhiteSpace(_resultContent))
		{
			<details class="toolcall-result-details">
				<summary class="toolcall-result-summary">📋 Result</summary>
				<div class="toolcall-result-content">
					<pre><code>@_resultContent</code></pre>
				</div>
			</details>
		}
	}
</div>

@code {

	[Parameter]
	public required ToolCall ToolCall { get; init; }

	private string _toolName = string.Empty;
	private string? _title;
	private string _status = "Pending";
	private string? _statusTitle;
	private bool _showArgs;
	private string _argsPreview = string.Empty;
	private string? _resultContent;

	protected override void OnInitialized()
	{
		_toolName = ToolCall.ToolName;
		_title = LocalizationManager.LocalizeStatic(ToolCall.Title ?? _toolName);
		_status = ToolCall.Status.ToString();
		_statusTitle = ToolCall.StatusTitle;
		_resultContent = ToolCall.ResultContent;

		if (ToolCall.Arguments is not null)
		{
			var args = ToolCallArgumentFormatter.FormatToMarkdown(ToolCall.Arguments);
			if (!string.IsNullOrWhiteSpace(args))
			{
				_showArgs = true;
				_argsPreview = args.Length > 500 ? args[..500] + "..." : args;
			}
		}

		ToolCall.PropertyChanged += OnToolCallPropertyChanged;
	}

	private void OnToolCallPropertyChanged(object? sender, PropertyChangedEventArgs e)
	{
		InvokeAsync(() =>
		{
			switch (e.PropertyName)
			{
				case nameof(ToolCall.Status):
					_status = ToolCall.Status.ToString();
					break;
				case nameof(ToolCall.StatusTitle):
					_statusTitle = ToolCall.StatusTitle;
					break;
				case nameof(ToolCall.ResultContent):
					_resultContent = ToolCall.ResultContent;
					break;
			}
			StateHasChanged();
		});
	}

	private string GetToolStatusIcon() => _status switch
	{
		"Pending" => "⏳",
		"Running" => "🔄",
		"Completed" => "✅",
		"Failed" => "❌",
		_ => "⚙️"
	};

	public void Dispose()
	{
		ToolCall.PropertyChanged -= OnToolCallPropertyChanged;
	}
}
