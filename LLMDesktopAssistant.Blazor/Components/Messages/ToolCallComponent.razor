@using System.ComponentModel
@using LLMDesktopAssistant.LLM.Domain
@using LLMDesktopAssistant.LLM.Messages
@using LLMDesktopAssistant.Localization
@using Material.Icons
@implements IDisposable
@rendermode InteractiveServer

<div class="toolcall-item" data-status="@ToolCall.Status">
	<span class="toolcall-icon">
		@switch (ToolCall.Status)
		{
			case ToolStatus.Pending:
				<MaterialIconComponent Kind="@MaterialIconKind.Wrench" Size="16" />
				break;
			case ToolStatus.Executing:
				<MaterialIconComponent Kind="@MaterialIconKind.Wrench" Size="16" Color="#0078d4" />
				break;
			case ToolStatus.ExecutionInterrupted:
				<MaterialIconComponent Kind="@MaterialIconKind.Wrench" Size="16" Color="#1976d2" />
				break;
			case ToolStatus.Success:
				<MaterialIconComponent Kind="@MaterialIconKind.CheckCircle" Size="16" Color="#388e3c" />
				break;
			case ToolStatus.Error:
				<MaterialIconComponent Kind="@MaterialIconKind.AlertCircle" Size="16" Color="#d32f2f" />
				break;
			case ToolStatus.Cancelled:
				<MaterialIconComponent Kind="@MaterialIconKind.CancelCircle" Size="16" Color="#d32f2f" />
				break;
			default:
				<MaterialIconComponent Kind="@MaterialIconKind.Wrench" Size="16" />
				break;
		}
	</span>
	<span class="toolcall-name">@_title</span>
	@if (!string.IsNullOrWhiteSpace(ToolCall.StatusTitle))
	{
		@if (ToolCall.StatusIcon.HasValue)
		{
			<MaterialIconComponent Kind="@ToolCall.StatusIcon.Value" />
		}
		<span class="toolcall-status">
			<MarkdownComponent MarkdownText="@ToolCall.StatusTitle" />
		</span>
	}

	@if (_showArgs)
	{
		<div class="toolcall-args">
			<MarkdownComponent MarkdownText="@_argsPreview" />
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(ToolCall.ResultContent))
	{
		<details class="toolcall-result-details">
			<summary class="toolcall-result-summary">
				<MaterialIconComponent Kind="@MaterialIconKind.CodeBraces" Size="14" Color="rgba(0,0,0,0.5)" AdditionalStyle="margin-right: 4px;" />
				Result
			</summary>
			<div class="toolcall-result-content">
				<pre><code>@ToolCall.ResultContent</code></pre>
			</div>
		</details>
	}
</div>

@code {

	[Parameter]
	public required ToolCall ToolCall { get; init; }

	private string? _title;
	private bool _showArgs;
	private string _argsPreview = string.Empty;

	protected override void OnInitialized()
	{
		_title = LocalizationManager.LocalizeStatic(ToolCall.Title ?? ToolCall.ToolName);

		if (ToolCall.Arguments is not null)
		{
			var args = ToolCallArgumentFormatter.FormatToMarkdown(ToolCall.Arguments);
			if (!string.IsNullOrWhiteSpace(args))
			{
				_showArgs = true;
				_argsPreview = args.Length > 500 ? args[..500] + "..." : args;
			}
		}

		ToolCall.PropertyChanged += OnToolCallPropertyChanged;
	}

	private void OnToolCallPropertyChanged(object? sender, PropertyChangedEventArgs e)
	{
		InvokeAsync(() =>
		{
			StateHasChanged();
		});
	}

	public void Dispose()
	{
		ToolCall.PropertyChanged -= OnToolCallPropertyChanged;
	}
}
