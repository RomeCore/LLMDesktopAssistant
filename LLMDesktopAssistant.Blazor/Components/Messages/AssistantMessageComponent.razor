@using System.ComponentModel
@using LLMDesktopAssistant.LLM.Domain
@using LLMDesktopAssistant.LLM.Services.Agents
@implements IDisposable
@rendermode InteractiveServer

@inject Chat Chat
@inject IAgentManagementService AgentManager

<div class="message-row assistant-message-row">
	@if (_showAvatar)
	{
		<div class="message-header">
			<div class="message-avatar">
				@if (!string.IsNullOrWhiteSpace(_avatarBase64))
				{
					<img src="data:image/png;base64,@_avatarBase64" alt="@_senderName" class="avatar-img" />
				}
				else
				{
					<span class="avatar-placeholder">🤖</span>
				}
			</div>
			<span class="sender-name">@_senderName</span>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(_reasoningContent))
	{
		<div class="reasoning-container">
			<details class="reasoning-details" open="@_reasoningExpanded">
				<summary class="reasoning-summary">💭 Reasoning</summary>
				<div class="reasoning-text">
					<MarkdownComponent MarkdownText="@_reasoningContent" />
				</div>
			</details>
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(Message.Content))
	{
		<div class="message-body">
			<MarkdownComponent MarkdownText="@Message.Content" />
		</div>
	}

	@if (_toolCalls.Count > 0)
	{
		<div class="toolcalls-container">
			@foreach (var toolCall in _toolCalls)
			{
				<ToolCallComponent ToolCall="@toolCall" />
			}
		</div>
	}

	@if (!string.IsNullOrWhiteSpace(_error))
	{
		<div class="message-error">❌ @_error</div>
	}
</div>

@code {
	[Parameter]
	public required BranchedMessage BranchedMessage { get; init; }

	[Parameter]
	public required AssistantMessage Message { get; init; }

	private bool _showAvatar = true;
	private string _avatarBase64 = string.Empty;
	private string _senderName = string.Empty;
	private string _reasoningContent = string.Empty;
	private bool _reasoningExpanded = false;
	private List<ToolCall> _toolCalls = [];
	private string _error = string.Empty;

	protected override void OnInitialized()
	{
		base.OnInitialized();

		LoadAvatar();
		LoadParts();
		Message.PropertyChanged += MessagePropertyChanged;
	}

	private void LoadAvatar()
	{
		var prevMessage = BranchedMessage.MessageIndex - 1 >= 0
				? Chat.Messages[BranchedMessage.MessageIndex - 1].Message as AssistantMessage
				: null;

		_showAvatar = prevMessage == null || Message.SenderAgentId != prevMessage.SenderAgentId;
		if (_showAvatar)
		{
			try
			{
				var agent = AgentManager.GetAgentDescriptor(Message.SenderAgentId);
				_senderName = agent.Info.Name;

				if (!string.IsNullOrWhiteSpace(agent.Info.Base64ProfileImage))
				{
					_avatarBase64 = agent.Info.Base64ProfileImage;
				}
			}
			catch
			{
				_senderName = "Assistant";
				_avatarBase64 = string.Empty;
			}
		}
	}

	private void LoadParts()
	{
		_reasoningContent = Message.ReasoningContent ?? string.Empty;
		_reasoningExpanded = !Message.IsCompleted;
		_toolCalls = [.. Message.ToolCalls];
		_error = Message.Error ?? string.Empty;
	}

	private void MessagePropertyChanged(object? sender, PropertyChangedEventArgs e)
	{
		InvokeAsync(() =>
		{
			switch (e.PropertyName)
			{
				case nameof(AssistantMessage.ReasoningContent):
					_reasoningContent = Message.ReasoningContent ?? string.Empty;
					break;
				case nameof(AssistantMessage.Error):
					_error = Message.Error ?? string.Empty;
					break;
			}
			_reasoningExpanded = !Message.IsCompleted;
			_toolCalls = [.. Message.ToolCalls];
			StateHasChanged();
		});
	}

	public void Dispose()
	{
		Message.PropertyChanged -= MessagePropertyChanged;
	}
}
