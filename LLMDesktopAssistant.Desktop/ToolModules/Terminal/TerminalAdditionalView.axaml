<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.microsoft.com/winfx/markup-compatibility/2006"
			 d:DesignWidth="600" d:DesignHeight="300"
			 xmlns:local="using:LLMDesktopAssistant.Desktop.ToolModules.Terminal"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:terminal="using:Iciclecreek.Terminal"
			 x:Class="LLMDesktopAssistant.Desktop.ToolModules.Terminal.TerminalAdditionalView"
			 x:DataType="local:TerminalAdditionalViewModel">

	<Border BorderBrush="{DynamicResource CardBorderBrush}"
			BorderThickness="1"
			CornerRadius="6"
			Margin="4"
			Padding="0"
			HorizontalAlignment="Stretch"
			MaxHeight="450">

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>
			
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0.65*"/>
				<ColumnDefinition Width="0.35*"/>
			</Grid.ColumnDefinitions>

			<!-- Terminal Control -->
			<terminal:TerminalControl x:Name="Terminal"
																Grid.Row="1"
																FontFamily="Cascadia Mono,Consolas,monospace"
																FontSize="12"
																Background="#1E1E1E"
																Foreground="#D4D4D4"
																BufferSize="5000"/>

			<!-- Footer with controls -->
			<Border Grid.Row="2"
							Grid.ColumnSpan="2"
							Background="{DynamicResource CardBackground}"
							Padding="8,4"
							CornerRadius="0,0,6,6">

				<StackPanel Orientation="Horizontal" Spacing="8">

					<Button Content="{loc:Loc cancel}"
									Command="{Binding CancelCommand}"
									IsVisible="{Binding IsRunning}"
									Classes="Secondary"
									FontSize="12"
									Padding="8,2"/>

				</StackPanel>

			</Border>

		</Grid>
	</Border>
</UserControl>
