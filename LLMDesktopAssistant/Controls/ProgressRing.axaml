<ResourceDictionary xmlns="https://github.com/avaloniaui"
										xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
										xmlns:local="using:LLMDesktopAssistant.Controls">

	<x:Double x:Key="ProgressRingThickness">3</x:Double>
	<x:Double x:Key="ProgressRingSize">24</x:Double>

	<!-- Default theme for ProgressRing -->
	<ControlTheme x:Key="{x:Type local:ProgressRing}"
								TargetType="local:ProgressRing">

		<Setter Property="Width" Value="{DynamicResource ProgressRingSize}" />
		<Setter Property="Height" Value="{DynamicResource ProgressRingSize}" />
		<Setter Property="StrokeThickness" Value="{DynamicResource ProgressRingThickness}" />
		<Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}" />
		<Setter Property="Background" Value="Transparent" />

		<Setter Property="Template">
			<ControlTemplate>
				<Grid x:Name="PART_RootGrid"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch">

					<!-- Track ring (background) -->
					<Path x:Name="PART_Track"
								Stroke="{TemplateBinding Foreground}"
								StrokeThickness="{TemplateBinding StrokeThickness}"
								StrokeDashArray=""
								Opacity="0.2"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								IsHitTestVisible="False" />

					<!-- Progress indicator (foreground arc) -->
					<Path x:Name="PART_Indicator"
								Stroke="{TemplateBinding Foreground}"
								StrokeThickness="{TemplateBinding StrokeThickness}"
								StrokeDashArray=""
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								IsHitTestVisible="False" />

				</Grid>
			</ControlTemplate>
		</Setter>

	</ControlTheme>

</ResourceDictionary>
