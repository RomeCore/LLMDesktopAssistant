<UserControl x:Class="LLMDesktopAssistant.Core.Controls.StreamingMarkdownControl"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Core.Controls"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<StackPanel>

		<FlowDocumentScrollViewer Name="CompleteContent"
								  HorizontalScrollBarVisibility="Disabled"
								  VerticalScrollBarVisibility="Disabled"
								  Background="{x:Null}"
								  IsTabStop="False"
								  local:FlowDocumentScrollViewerBehavior.PassThroughMouseWheel="True"
								  Padding="0" Margin="0">

		</FlowDocumentScrollViewer>

		<FlowDocumentScrollViewer Name="IncompleteContent"
								  HorizontalScrollBarVisibility="Disabled"
								  VerticalScrollBarVisibility="Disabled"
								  Background="{x:Null}"
								  IsTabStop="False"
								  local:FlowDocumentScrollViewerBehavior.PassThroughMouseWheel="True"
								  Padding="0" Margin="0">

		</FlowDocumentScrollViewer>

	</StackPanel>
	
</UserControl>
