<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<ResourceDictionary.ThemeDictionaries>
		
		<ResourceDictionary x:Key="Light">
		
			<Brush x:Key="DefaultForeground">Black</Brush>
			<Brush x:Key="TopBarBackground">#FFE5E5E5</Brush>
			<Brush x:Key="MessageBackground">#FFDEDEDE</Brush>

		</ResourceDictionary>
		
		<ResourceDictionary x:Key="Dark">
			
			<Brush x:Key="DefaultForeground">White</Brush>
			<Brush x:Key="TopBarBackground">#FF2F2F30</Brush>
			<Brush x:Key="MessageBackground">#FF414141</Brush>

		</ResourceDictionary>
		
	</ResourceDictionary.ThemeDictionaries>

	<x:Double x:Key="TaskDialogMaxHeight">1080</x:Double>
	<x:Double x:Key="TaskDialogMaxWidth">1920</x:Double>

</ResourceDictionary>