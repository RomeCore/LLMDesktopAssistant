<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:ico="using:Material.Icons.Avalonia">

	<Design.PreviewWith>
		<Border Padding="20">
			<!-- Add Controls for Previewer Here -->
		</Border>
	</Design.PreviewWith>



	<Style Selector="Button.IconButton">
		<Setter Property="Width" Value="32"/>
		<Setter Property="Height" Value="32"/>
	</Style>
	
	<Style Selector="Button.IconButton > ico|MaterialIcon">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
	</Style>
	
	<Style Selector="ToggleButton.IconButton">
		<Setter Property="Width" Value="32"/>
		<Setter Property="Height" Value="32"/>
	</Style>
	
	<Style Selector="ToggleButton.IconButton > ico|MaterialIcon">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
	</Style>


	
	<Style Selector="Button.MidIconButton">
		<Setter Property="Width" Value="28"/>
		<Setter Property="Height" Value="28"/>
	</Style>
	
	<Style Selector="Button.MidIconButton > ico|MaterialIcon">
		<Setter Property="Width" Value="22"/>
		<Setter Property="Height" Value="22"/>
	</Style>
	
	<Style Selector="ToggleButton.MidIconButton">
		<Setter Property="Width" Value="28"/>
		<Setter Property="Height" Value="28"/>
	</Style>
	
	<Style Selector="ToggleButton.MidIconButton > ico|MaterialIcon">
		<Setter Property="Width" Value="22"/>
		<Setter Property="Height" Value="22"/>
	</Style>

	
	
	<Style Selector="Button.SmallIconButton">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
	</Style>
	
	<Style Selector="Button.SmallIconButton > ico|MaterialIcon">
		<Setter Property="Width" Value="16"/>
		<Setter Property="Height" Value="16"/>
	</Style>
	
	<Style Selector="ToggleButton.SmallIconButton">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
	</Style>
	
	<Style Selector="ToggleButton.SmallIconButton > ico|MaterialIcon">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
	</Style>


	
	<Style Selector="ico|MaterialIcon.Icon">
		<Setter Property="Width" Value="32"/>
		<Setter Property="Height" Value="32"/>
	</Style>
	
	<Style Selector="ico|MaterialIcon.MidIcon">
		<Setter Property="Width" Value="28"/>
		<Setter Property="Height" Value="28"/>
	</Style>

	<Style Selector="ico|MaterialIcon.SmallIcon">
		<Setter Property="Width" Value="24"/>
		<Setter Property="Height" Value="24"/>
	</Style>

</Styles>
