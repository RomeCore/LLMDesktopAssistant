<Styles xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Design.PreviewWith>
    <Border Padding="20">
      <StackPanel Spacing="10">
        <MenuItem Header="_Standard" />
        <MenuItem Header="Selected" IsSelected="True" />
        <MenuItem Header="Disabled" IsEnabled="False" />
        <MenuItem Header="Submenu">
          <MenuItem Header="Child 1" />
          <MenuItem Header="Child 2" />
        </MenuItem>
      </StackPanel>
    </Border>
  </Design.PreviewWith>

  <!-- Base MenuItem style (for sub-items) -->
  <Style Selector="MenuItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#EAEAEA" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="12 8" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15" />
        <BrushTransition Property="Foreground" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>

  <!-- Layout root -->
  <Style Selector="MenuItem /template/ Border#PART_LayoutRoot">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>

  <!-- Chevron -->
  <Style Selector="MenuItem /template/ Path#PART_ChevronPath">
    <Setter Property="Fill" Value="#888888" />
  </Style>

  <!-- Input gesture text -->
  <Style Selector="MenuItem /template/ TextBlock#PART_InputGestureText">
    <Setter Property="Foreground" Value="#666666" />
  </Style>

  <!-- Hover -->
  <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#2A2A3E" />
  </Style>

  <Style Selector="MenuItem:pointerover">
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <Style Selector="MenuItem:pointerover /template/ Path#PART_ChevronPath">
    <Setter Property="Fill" Value="#FFFFFF" />
  </Style>

  <!-- Pressed -->
  <Style Selector="MenuItem:pressed /template/ Border#PART_LayoutRoot:pointerover">
    <Setter Property="Background" Value="#3A3A5E" />
  </Style>

  <!-- Selected (highlighted, like hover for top-level) -->
  <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#3A3A7E" />
  </Style>

  <Style Selector="MenuItem:selected">
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <!-- Disabled -->
  <Style Selector="MenuItem:disabled /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="MenuItem:disabled">
    <Setter Property="Foreground" Value="#555555" />
  </Style>

  <Style Selector="MenuItem:disabled /template/ Path#PART_ChevronPath">
    <Setter Property="Fill" Value="#3A3A4E" />
  </Style>

  <!-- Popup (submenu background) -->
  <Style Selector="MenuItem /template/ Popup#PART_Popup /template/ Border">
    <Setter Property="Background" Value="#1A1A2E" />
    <Setter Property="BorderBrush" Value="#2A2A3E" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="BoxShadow" Value="0 4 20 0 #00000066" />
  </Style>

</Styles>
