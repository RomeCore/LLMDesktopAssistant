<Styles xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Design.PreviewWith>
    <Border Padding="0">
      <ListBox>
        <ListBoxItem IsEnabled="False">Disabled</ListBoxItem>
        <ListBoxItem>Normal</ListBoxItem>
        <ListBoxItem>Selected</ListBoxItem>
      </ListBox>
    </Border>
  </Design.PreviewWith>

  <!-- Base ListBoxItem style -->
  <Style Selector="ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#EAEAEA" />
    <Setter Property="Padding" Value="12 9 12 12" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15" />
        <BrushTransition Property="Foreground" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>

  <!-- Hover -->
  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#2A2A3E" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <!-- Pressed -->
  <Style Selector="ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#3A3A5E" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <!-- Selected -->
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#3A3A7E" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <!-- Selected + hover -->
  <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#4A4A8E" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <!-- Selected + pressed -->
  <Style Selector="ListBoxItem:selected:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#5A5A9E" />
    <Setter Property="Foreground" Value="#FFFFFF" />
  </Style>

  <!-- Disabled -->
  <Style Selector="ListBoxItem:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#555555" />
  </Style>

</Styles>
