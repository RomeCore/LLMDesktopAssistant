<ResourceDictionary xmlns="https://github.com/avaloniaui"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
					xmlns:conv="clr-namespace:LLMDesktopAssistant.Converters">
	
	<conv:ToUnsetIfNullConverter x:Key="ToUnsetIfNullConverter"/>
	<conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
	<conv:AssistantMessageStateToBooleanConverter x:Key="AssistantMessageStateToBooleanConverter"/>
	<conv:StringNonEmptyToBooleanConverter x:Key="StringNonEmptyToBooleanConverter"/>
	<conv:StringNonEmptyToBooleanConverter Invert="True" x:Key="StringNonEmptyToBooleanConverterInverted"/>
	<conv:NotnullToBooleanConverter x:Key="NotnullToBooleanConverter"/>
	<conv:NotnullToBooleanConverter Invert="True" x:Key="NotnullToBooleanConverterInverted"/>
	<conv:StringEqualsConverter x:Key="StringEqualsConverter"/>


</ResourceDictionary>