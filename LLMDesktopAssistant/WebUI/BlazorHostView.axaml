<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="520"
			 xmlns:local="using:LLMDesktopAssistant.WebUI"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.WebUI.BlazorHostView"
			 x:DataType="local:BlazorHostViewModel">

	<Grid RowDefinitions="Auto,*,Auto" Margin="16">

		<!-- Header -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">

			<ico:MaterialIcon Kind="Web" FontSize="28"/>

			<TextBlock Text="{loc:Loc blazor_host_title}"
					   FontWeight="Bold"
					   FontSize="20"
					   VerticalAlignment="Center"/>

		</StackPanel>

		<!-- Content -->
		<StackPanel Grid.Row="1" Orientation="Vertical" Spacing="12" Margin="0,16,0,0">

			<!-- Status indicator -->
			<Border Background="Green"
					CornerRadius="8" Padding="12">

				<StackPanel Orientation="Horizontal" Spacing="8">

					<Ellipse Width="12" Height="12"
							 Fill="Green"/>

					<TextBlock VerticalAlignment="Center">
						<Run Text="{loc:Loc blazor_host_status}"/>
						<Run Text=": "/>
						<Run Text="{Binding IsRunning}"/>
					</TextBlock>

				</StackPanel>

			</Border>

			<!-- Separator -->
			<Rectangle Height="1" Fill="{DynamicResource DefaultForeground}" Opacity="0.2"/>

			<!-- Settings -->
			<TextBlock Text="{loc:Loc blazor_host_settings}"
					   FontWeight="Bold"
					   FontSize="16"/>

			<Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">

				<TextBlock Grid.Row="0" Grid.Column="0"
						   Text="{loc:Loc blazor_host_port}"
						   VerticalAlignment="Center"
						   Margin="0,0,8,0"/>

				<DockPanel Grid.Row="0" Grid.Column="1"
									 LastChildFill="True">

					<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">

						<Button Classes="IconButton"
								Command="{Binding CopyUrlCommand}"
								ToolTip.Tip="{loc:Loc blazor_host_copy_url}">
							<ico:MaterialIcon Kind="ContentCopy"/>
						</Button>

						<Button Classes="IconButton"
								Command="{Binding OpenInBrowserCommand}"
								ToolTip.Tip="{loc:Loc blazor_host_open_browser}">
							<ico:MaterialIcon Kind="OpenInNew"/>
						</Button>

					</StackPanel>

					<TextBox Text="{Binding EndpointUrl}"
									 FontFamily="Consolas"
									 FontSize="14"
									 Margin="0,0,4,0"
									 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
									 VerticalAlignment="Center"/>

				</DockPanel>

				<TextBlock Grid.Row="1" Grid.Column="0"
						   Text="{loc:Loc blazor_host_password}"
						   VerticalAlignment="Center"
						   Margin="0,8,8,0"/>
				
				<TextBox Grid.Row="1" Grid.Column="1"
						 Text="{Binding Password, Mode=TwoWay}"
						 PlaceholderText="{loc:Loc blazor_host_password_placeholder}"
						 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
						 PasswordChar="•"
						 Margin="0,8,0,0"/>

			</Grid>

		</StackPanel>

		<!-- Buttons -->
		<Panel Grid.Row="2" Margin="0,16,0,0">

			<Button Content="{loc:Loc blazor_host_start}"
					Command="{Binding StartCommand}"
					IsVisible="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
					Classes="Primary"/>

			<Button Content="{loc:Loc blazor_host_stop}"
					Command="{Binding StopCommand}"
					IsVisible="{Binding IsRunning}"
					Classes="Danger"/>

		</Panel>

	</Grid>

</UserControl>
