{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "LLT (Large Language Template)",
	"scopeName": "source.llt",
	"fileTypes": ["llt"],
	"patterns": [
		{ "include": "#main" }
	],
	"repository": {
		"main": {
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#escape-sequences" },
				{ "include": "#template-headers" },
				{ "include": "#metadata-block" },
				{ "include": "#message-blocks" },
				{ "include": "#control-keywords" },
				{ "include": "#expression-output" },
				{ "include": "#variable-assign" },
				{ "include": "#multiline-raw" },
				{ "include": "#curly-braces" },
				{ "include": "#square-brackets" },
				{ "include": "#round-parens" },
				{ "include": "#plain-text" }
			]
		},

		"comments": {
			"patterns": [
				{
					"name": "comment.line.llt",
					"match": "@\\/.*$"
				},
				{
					"name": "comment.block.llt",
					"begin": "@\\*",
					"end": "\\*@",
					"beginCaptures": {
						"0": { "name": "punctuation.definition.comment.begin.llt" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.definition.comment.end.llt" }
					}
				}
			]
		},

		"escape-sequences": {
			"patterns": [
				{
					"name": "constant.character.escape.llt",
					"match": "@@|\\{\\{|\\}\\}"
				}
			]
		},

		"template-headers": {
			"patterns": [
				{
					"name": "meta.template.messages.llt",
					"match": "(@)\\s*(messages)\\s+(template)\\s*([a-zA-Z_][a-zA-Z0-9_]*)?",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.messages.llt" },
						"3": { "name": "keyword.control.template.llt" },
						"4": { "name": "entity.name.function.template.llt" }
					}
				},
				{
					"name": "meta.template.llt",
					"match": "(@)\\s*(template)\\s*([a-zA-Z_][a-zA-Z0-9_]*)?",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.template.llt" },
						"3": { "name": "entity.name.function.template.llt" }
					}
				}
			]
		},

		"metadata-block": {
			"name": "meta.metadata.llt",
			"begin": "(@)\\s*(metadata)\\s*\\{",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.directive.llt" },
				"2": { "name": "keyword.control.metadata.llt" }
			},
			"end": "\\}",
			"endCaptures": {
				"0": { "name": "punctuation.definition.block.end.llt" }
			},
			"patterns": [
				{ "include": "#metadata-inner" }
			]
		},

		"metadata-inner": {
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#strings" },
				{ "include": "#numbers" },
				{ "include": "#language-constants" },
				{
					"name": "meta.metadata.key.llt",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*:)"
				},
				{
					"name": "punctuation.separator.key-value.llt",
					"match": ":"
				},
				{
					"name": "punctuation.separator.comma.llt",
					"match": ","
				},
				{ "include": "#metadata-braces" },
				{ "include": "#metadata-brackets" }
			]
		},

		"metadata-braces": {
			"name": "meta.object.llt",
			"begin": "\\{",
			"end": "\\}",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.block.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.block.end.llt" }
			},
			"patterns": [
				{ "include": "#metadata-inner" }
			]
		},

		"metadata-brackets": {
			"name": "meta.array.llt",
			"begin": "\\[",
			"end": "\\]",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.array.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.array.end.llt" }
			},
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#strings" },
				{ "include": "#numbers" },
				{ "include": "#language-constants" },
				{ "include": "#metadata-braces" },
				{ "include": "#metadata-brackets" },
				{
					"name": "punctuation.separator.comma.llt",
					"match": ","
				}
			]
		},

		"message-blocks": {
			"patterns": [
				{
					"name": "meta.message.explicit-role.llt",
					"match": "(@)\\s*(system|user|assistant|tool)\\s+(message)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.message-role.llt" },
						"3": { "name": "keyword.control.message.llt" }
					}
				},
				{
					"name": "meta.message.variable-role.llt",
					"match": "(@)\\s*(message)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.message.llt" }
					}
				},
				{
					"name": "meta.message.role-decl.llt",
					"match": "(@)\\s*(role)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.role.llt" }
					}
				}
			]
		},

		"control-keywords": {
			"patterns": [
				{
					"name": "meta.control.if.llt",
					"match": "(@)\\s*(if)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.if.llt" }
					}
				},
				{
					"name": "meta.control.else-if.llt",
					"match": "(@)\\s*(else)\\s+(if)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.else.llt" },
						"3": { "name": "keyword.control.if.llt" }
					}
				},
				{
					"name": "meta.control.else.llt",
					"match": "(@)\\s*(else)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.else.llt" }
					}
				},
				{
					"name": "meta.control.foreach.llt",
					"match": "(@)\\s*(foreach)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.foreach.llt" }
					}
				},
				{
					"name": "meta.control.while.llt",
					"match": "(@)\\s*(while)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.while.llt" }
					}
				},
				{
					"name": "meta.control.render.llt",
					"match": "(@)\\s*(render)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.render.llt" }
					}
				},
				{
					"name": "meta.control.let.llt",
					"match": "(@)\\s*(let)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.let.llt" }
					}
				},
				{
					"name": "keyword.control.in.llt",
					"match": "\\b(in)\\b",
					"captures": {
						"1": { "name": "keyword.control.in.llt" }
					}
				},
				{
					"name": "keyword.control.with.llt",
					"match": "\\b(with)\\b",
					"captures": {
						"1": { "name": "keyword.control.with.llt" }
					}
				}
			]
		},

		"expression-output": {
			"patterns": [
				{
					"name": "meta.expression.output.llt",
					"match": "(@)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*(?:\\s*\\([^)]*\\))?(?:\\s*\\[[^\\]]*\\])?)(:\\s*'[^']*')?",
					"captures": {
						"1": { "name": "punctuation.definition.variable.llt" },
						"2": { "name": "variable.other.llt" },
						"3": { "name": "meta.format-string.llt" }
					}
				}
			]
		},

		"variable-assign": {
			"patterns": [
				{
					"name": "meta.variable.assign.reassign.llt",
					"match": "(?<=^|[\\s\\}])([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)\\s*([^@\\n]+)",
					"captures": {
						"1": { "name": "variable.other.assignment.llt" },
						"2": { "name": "keyword.operator.assignment.llt" },
						"3": { "name": "meta.expression.value.llt" }
					}
				}
			]
		},

		"multiline-raw": {
			"name": "string.unquoted.multiline.llt",
			"begin": "`````",
			"end": "`````",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.llt" }
			}
		},

		"curly-braces": {
			"name": "meta.block.llt",
			"begin": "\\{",
			"end": "\\}",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.block.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.block.end.llt" }
			},
			"patterns": [
				{ "include": "#main" }
			]
		},

		"square-brackets": {
			"name": "meta.brackets.llt",
			"begin": "\\[",
			"end": "\\]",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.array.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.array.end.llt" }
			},
			"patterns": [
				{ "include": "#main" }
			]
		},

		"round-parens": {
			"name": "meta.parens.llt",
			"begin": "\\(",
			"end": "\\)",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.parens.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.parens.end.llt" }
			},
			"patterns": [
				{ "include": "#main" }
			]
		},

		"strings": {
			"name": "string.quoted.single.llt",
			"begin": "'",
			"end": "'",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.llt" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.llt",
					"match": "\\\\'|\\\\\\\\"
				}
			]
		},

		"numbers": {
			"name": "constant.numeric.llt",
			"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
		},

		"language-constants": {
			"patterns": [
				{ "name": "constant.language.boolean.true.llt", "match": "\\btrue\\b" },
				{ "name": "constant.language.boolean.false.llt", "match": "\\bfalse\\b" },
				{ "name": "constant.language.null.llt", "match": "\\bnull\\b" },
				{ "name": "support.constant.ctx.llt", "match": "\\bctx\\b" }
			]
		},

		"operators": {
			"patterns": [
				{ "name": "keyword.operator.logical.llt", "match": "&&|\\|\\||!" },
				{ "name": "keyword.operator.comparison.llt", "match": "==|!=|<=|>=|<|>" },
				{ "name": "keyword.operator.arithmetic.llt", "match": "\\+|-|\\*|\\/|%" },
				{ "name": "keyword.operator.ternary.llt", "match": "\\?|:(?!=)" },
				{ "name": "keyword.operator.assignment.llt", "match": "=" },
				{ "name": "keyword.operator.access.llt", "match": "\\." }
			]
		},

		"expression-keywords": {
			"patterns": [
				{ "include": "#strings" },
				{ "include": "#numbers" },
				{ "include": "#language-constants" },
				{ "include": "#operators" }
			]
		},

		"plain-text": {
			"name": "meta.text.content.llt",
			"match": "[^@{}]+"
		}
	}
}
