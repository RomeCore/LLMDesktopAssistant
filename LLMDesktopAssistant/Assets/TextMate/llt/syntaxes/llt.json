{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "LLT",
	"scopeName": "source.llt",
	"fileTypes": ["llt"],
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#template-header" },
		{ "include": "#directives" },
		{ "include": "#expression-output" },
		{ "include": "#text-multiline-content" },
		{ "include": "#braces" },
		{ "include": "#text-content" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.llt",
					"match": "@/.*$"
				},
				{
					"name": "comment.block.llt",
					"begin": "@\\*",
					"end": "\\*@",
					"beginCaptures": {
						"0": { "name": "punctuation.definition.comment.begin.llt" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.definition.comment.end.llt" }
					}
				}
			]
		},

		"strings": {
			"name": "string.quoted.single.llt",
			"begin": "'",
			"end": "'",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.llt" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.llt",
					"match": "\\\\'|\\\\\\\\"
				}
			]
		},

		"escape-sequences": {
			"patterns": [
				{
					"name": "constant.character.escape.llt",
					"match": "@@|\\{\\{|\\}\\}"
				}
			]
		},

		"template-header": {
			"patterns": [
				{
					"name": "meta.template.header.llt",
					"match": "(?<=^|\\s|\\}|\\{)(@)\\b(template)\\b\\s*([a-zA-Z_][a-zA-Z0-9_]*)?",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.template.llt" },
						"3": { "name": "entity.name.function.template.llt" }
					}
				},
				{
					"name": "meta.template.messages.header.llt",
					"match": "(?<=^|\\s|\\}|\\{)(@)\\b(messages)\\b\\s+\\b(template)\\b\\s*([a-zA-Z_][a-zA-Z0-9_]*)?",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.messages.llt" },
						"3": { "name": "keyword.control.template.llt" },
						"4": { "name": "entity.name.function.template.llt" }
					}
				}
			]
		},

		"metadata-block": {
			"name": "meta.metadata.llt",
			"begin": "(?<=^|\\s|\\{|\\})(@)\\b(metadata)\\b\\s*\\{",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.directive.llt" },
				"2": { "name": "keyword.control.metadata.llt" },
				"3": { "name": "punctuation.definition.block.begin.llt" }
			},
			"end": "\\}",
			"endCaptures": {
				"0": { "name": "punctuation.definition.block.end.llt" }
			},
			"patterns": [
				{ "include": "#comments" },
				{
					"name": "meta.metadata-key.llt",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=:)"
				},
				{
					"name": "punctuation.separator.key-value.llt",
					"match": ":"
				},
				{
					"name": "punctuation.separator.comma.llt",
					"match": ","
				},
				{ "include": "#strings" },
				{ "include": "#numbers" },
				{ "include": "#language-constants" }
			]
		},

		"directives": {
			"patterns": [
				{
					"name": "keyword.control.if.llt",
					"begin": "(?<=^|\\s|\\{)(@)\\b(if)\\b",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.if.llt" }
					},
					"end": "(?=\\{)",
					"patterns": [
						{ "include": "#expression" }
					]
				},
				{
					"name": "keyword.control.else.if.llt",
					"match": "(?<=^|\\s|\\})(@)\\b(else\\s+if)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.else.if.llt" }
					}
				},
				{
					"name": "keyword.control.else.llt",
					"match": "(?<=^|\\s|\\})(@)\\b(else)\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.else.llt" }
					}
				},
				{
					"name": "keyword.control.foreach.llt",
					"begin": "(?<=^|\\s|\\{)(@)\\b(foreach)\\b",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.foreach.llt" }
					},
					"end": "(?=\\{)",
					"patterns": [
						{
							"name": "keyword.control.in.llt",
							"match": "\\b(in)\\b"
						},
						{
							"name": "variable.other.foreach.llt",
							"match": "[a-zA-Z_][a-zA-Z0-9_]*"
						},
						{ "include": "#expression" }
					]
				},
				{
					"name": "keyword.control.while.llt",
					"begin": "(?<=^|\\s|\\{)(@)\\b(while)\\b",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.while.llt" }
					},
					"end": "(?=\\{)",
					"patterns": [
						{ "include": "#expression" }
					]
				},
				{
					"name": "keyword.control.render.llt",
					"begin": "(?<=^|\\s|\\{)(@)\\b(render)\\b",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.render.llt" }
					},
					"end": "(?=\\{|$)",
					"patterns": [
						{
							"name": "keyword.control.with.llt",
							"match": "\\b(with)\\b"
						},
						{ "include": "#expression" }
					]
				},
				{
					"name": "keyword.control.let.llt",
					"begin": "(?<=^|\\s|\\{)(@)\\b(let)\\b",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.let.llt" }
					},
					"end": "(?=\\{|$)",
					"patterns": [
						{
							"name": "variable.other.assignment.llt",
							"match": "[a-zA-Z_][a-zA-Z0-9_]*"
						},
						{
							"name": "keyword.operator.assignment.llt",
							"match": "="
						},
						{ "include": "#expression" }
					]
				},
				{
					"name": "keyword.control.message-role.llt",
					"match": "(?<=^|\\s|\\{)(@)\\b(system|user|assistant|tool)\\s+message\\b",
					"captures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.message-role.llt" }
					}
				},
				{
					"name": "keyword.control.message.llt",
					"begin": "(?<=^|\\s|\\{)(@)\\b(message)\\b",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.directive.llt" },
						"2": { "name": "keyword.control.message.llt" }
					},
					"end": "(?=\\{)",
					"patterns": [
						{
							"name": "keyword.control.role.llt",
							"match": "@role"
						},
						{ "include": "#expression" }
					]
				}
			]
		},

		"expression-output": {
			"begin": "(?<=^|\\s|\\{)(@)(?=[a-zA-Z_!?])",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.variable.llt" }
			},
			"end": "(?=\\s|$|\\}|\\{|\\)|\\]|,|@)",
			"patterns": [
				{ "include": "#expression-core" },
				{
					"name": "punctuation.definition.format-separator.llt",
					"match": ":"
				},
				{
					"name": "string.quoted.single.format.llt",
					"begin": "'",
					"end": "'",
					"beginCaptures": {
						"0": { "name": "punctuation.definition.string.begin.llt" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.definition.string.end.llt" }
					}
				}
			]
		},

		"expression": {
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#strings" },
				{ "include": "#numbers" },
				{ "include": "#language-constants" },
				{ "include": "#expression-core" },
				{ "include": "#operators" },
				{ "include": "#braces" },
				{ "include": "#brackets" }
			]
		},

		"expression-core": {
			"patterns": [
				{
					"name": "support.function.any-method.llt",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
				},
				{
					"name": "variable.other.property.llt",
					"match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"name": "variable.other.llt",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*"
				}
			]
		},

		"operators": {
			"patterns": [
				{ "name": "keyword.operator.comparison.llt", "match": "==|!=|<=|>=|<|>" },
				{ "name": "keyword.operator.logical.llt", "match": "&&|\\|\\||!" },
				{ "name": "keyword.operator.arithmetic.llt", "match": "\\+|-|\\*|/|%" },
				{ "name": "keyword.operator.ternary.llt", "match": "\\?|:" },
				{ "name": "keyword.operator.assignment.llt", "match": "=" },
				{ "name": "keyword.operator.access.llt", "match": "\\." }
			]
		},

		"numbers": {
			"name": "constant.numeric.llt",
			"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
		},

		"language-constants": {
			"patterns": [
				{ "name": "constant.language.boolean.true.llt", "match": "\\btrue\\b" },
				{ "name": "constant.language.boolean.false.llt", "match": "\\bfalse\\b" },
				{ "name": "constant.language.null.llt", "match": "\\bnull\\b" }
			]
		},

		"text-multiline-content": {
			"name": "string.unquoted.llt",
			"begin": "`````",
			"end": "`````",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.llt" }
			}
		},

		"text-content": {
			"name": "meta.text.content.llt",
			"match": "[^@{}]+"
		},

		"braces": {
			"name": "meta.block.llt",
			"begin": "\\{",
			"end": "\\}",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.block.begin.llt" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.block.end.llt" }
			},
			"patterns": [
				{ "include": "#comments" },
				{ "include": "#template-header" },
				{ "include": "#metadata-block" },
				{ "include": "#directives" },
				{ "include": "#expression-output" },
				{ "include": "#text-multiline-content" },
				{ "include": "#escape-sequences" },
				{ "include": "#braces" },
				{ "include": "#text-content" }
			]
		},

		"brackets": {
			"patterns": [
				{ "name": "punctuation.definition.array.begin.llt", "match": "\\[" },
				{ "name": "punctuation.definition.array.end.llt", "match": "\\]" }
			]
		}
	}
}
