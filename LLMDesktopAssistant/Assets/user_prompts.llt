@template user_message_prompt
{
	@metadata
	{
		lang: 'en'
	}
	@if time_sent
	{
		Message sent at: @time_sent
	}
	@if attachments
	{
		[Attachments (they also can be accessed via various tools, like python, shell or filesystem)]:
		@foreach attachment in attachments
		{
			File name inside working directory: @attachment.LocalPath
			Size: @attachment.DisplaySize
			@if attachment.PreviewContent
			{
				@attachment.PreviewContent
			}
		}
		Note that attachments also can be accessed via various tools, like python, shell or filesystem.
		Look at the preview content to understand the structure of the attachmetns (if it's available).
		[Attachments section ends here]
	}

	User message:
	@content
}