<UserControl x:Class="LLMDesktopAssistant.LLM.ToolCallView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<Grid Margin="0,2">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<!-- Tool Icon based on status -->
		<materialDesign:PackIcon Grid.Column="0"
						Width="20" Height="20"
						Margin="0,0,4,0">

			<materialDesign:PackIcon.Style>
				<Style TargetType="materialDesign:PackIcon">
					<Setter Property="Kind" Value="Hammer"/>
					<Style.Triggers>
						<DataTrigger Binding="{Binding Status}" Value="InProgress">
							<Setter Property="Kind" Value="Loading"/>
						</DataTrigger>
						<DataTrigger Binding="{Binding Status}" Value="Success">
							<Setter Property="Kind" Value="CheckCircle"/>
						</DataTrigger>
						<DataTrigger Binding="{Binding Status}" Value="Failure">
							<Setter Property="Kind" Value="AlertCircle"/>
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</materialDesign:PackIcon.Style>

		</materialDesign:PackIcon>

		<!-- Tool Name -->
		<TextBlock Grid.Column="1"
				   Text="{loc:Loc {Binding ToolName}}"
				   FontWeight="Medium"
				   VerticalAlignment="Center"/>
	</Grid>

</UserControl>