<UserControl x:Class="LLMDesktopAssistant.LLM.ToolCallView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<UserControl.Resources>
		<Style x:Key="ToolIconStyle" TargetType="materialDesign:PackIcon">
			<Setter Property="Width" Value="20"/>
			<Setter Property="Height" Value="20"/>
			<Setter Property="Kind" Value="Hammer"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding Status}" Value="Success">
					<Setter Property="Kind" Value="CheckCircle"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding Status}" Value="Failure">
					<Setter Property="Kind" Value="AlertCircle"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>

	<Grid Margin="0,2">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<!-- Container for icon/progress -->
		<Grid Grid.Column="0" Width="20" Height="20" Margin="0,0,4,0">
			<!-- Progress bar for InProgress state (visible only when status is InProgress) -->
			<ProgressBar 
				IsIndeterminate="True"
				Value="35">
				<ProgressBar.Style>
					<Style TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignCircularProgressBar}">
						<Setter Property="Visibility" Value="Collapsed"/>
						<Style.Triggers>
							<DataTrigger Binding="{Binding Status}" Value="InProgress">
								<Setter Property="Visibility" Value="Visible"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</ProgressBar.Style>
			</ProgressBar>

			<!-- Static icons for other states (visible when status is not InProgress) -->
			<materialDesign:PackIcon>
				<materialDesign:PackIcon.Style>
					<Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource ToolIconStyle}">
						<Setter Property="Visibility" Value="Visible"/>
						<Style.Triggers>
							<DataTrigger Binding="{Binding Status}" Value="InProgress">
								<Setter Property="Visibility" Value="Collapsed"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</materialDesign:PackIcon.Style>
			</materialDesign:PackIcon>
		</Grid>

		<materialDesign:PopupBox Grid.Column="1">
			
			<materialDesign:PopupBox.ToggleContent>
				<TextBlock Text="{loc:Loc {Binding ToolName}}"
						   FontWeight="Medium"
						   VerticalAlignment="Center"/>
			</materialDesign:PopupBox.ToggleContent>

			<materialDesign:PopupBox.PopupContent>

				<ScrollViewer VerticalScrollBarVisibility="Auto"
							  HorizontalScrollBarVisibility="Auto">

					<StackPanel Orientation="Vertical">

						<StackPanel Orientation="Vertical"
							Visibility="{Binding Arguments, Converter={StaticResource StringNonEmptyToVisiblityConverter}}">

							<Label Content="{loc:Loc tool-arguments}"/>
							<Label Content="{Binding Arguments}" FontFamily="Cascadia Code"/>

						</StackPanel>

						<StackPanel Orientation="Vertical"
							Visibility="{Binding Result, Converter={StaticResource StringNonEmptyToVisiblityConverter}}">

							<Label Content="{loc:Loc tool-result}"/>
							<Label Content="{Binding Result}" FontFamily="Cascadia Code"/>

						</StackPanel>

					</StackPanel>

				</ScrollViewer>
				
			</materialDesign:PopupBox.PopupContent>
			
		</materialDesign:PopupBox>
	</Grid>
</UserControl>