<UserControl x:Class="LLMDesktopAssistant.Core.LLM.MVVM.Attachments.AttachmentsManagerView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Core.LLM.MVVM.Attachments"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Core.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Core.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<Grid Margin="10">

		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid Margin="0,0,0,10">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<TextBox x:Name="UrlInputBox"
					 Grid.Column="0"
					 Text="{Binding InputUrl, UpdateSourceTrigger=PropertyChanged}"
					 Style="{StaticResource MaterialDesignOutlinedTextBox}"
					 materialDesign:HintAssist.Hint="{loc:Loc attachment-url_hint}"
					 VerticalContentAlignment="Center"
					 KeyDown="OnUrlInputKeyDown"/>

			<Button Grid.Column="1"
					Margin="8,0,0,0"
					Width="40"
					Height="40"
					Command="{Binding AddUrlCommand}"
					Style="{StaticResource MaterialDesignIconButton}"
					ToolTip="{loc:Loc attachment-add_url_hint}">
				<materialDesign:PackIcon Kind="Link" />
			</Button>

			<Button Grid.Column="2"
					Margin="8,0,0,0"
					Width="40"
					Height="40"
					Command="{Binding AttachFilesCommand}"
					Style="{StaticResource MaterialDesignIconButton}"
					ToolTip="{loc:Loc attachment-attach_files_hint}">
				<materialDesign:PackIcon Kind="FolderOpen" />
			</Button>
		</Grid>

		<ItemsControl Grid.Row="1" 
					  ItemsSource="{Binding Drafts}">

			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>

			<ItemsControl.ItemTemplate>
				<DataTemplate>

					<materialDesign:Card Margin="5" Padding="10">

						<StackPanel>

							<TextBlock Text="{Binding Title}"
									   FontWeight="Bold"
									   TextTrimming="CharacterEllipsis"/>

							<ComboBox ItemsSource="{Binding AvailableModes}"
									  SelectedItem="{Binding SelectedMode}"
									  materialDesign:HintAssist.Hint="{loc:Loc application-mode_hint}">

								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{loc:Loc {Binding Title}}"
												   Margin="3"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
								
							</ComboBox>

							<StackPanel Orientation="Vertical"
										Visibility="{Binding SelectedMode.HasLineSelections, Converter={StaticResource BooleanToVisibilityConverter}}">
								<TextBox Width="100" HorizontalAlignment="Left" Margin="5"
										 Text="{Binding Parameters.StartLine}"
										 materialDesign:HintAssist.HelperText="{loc:Loc application-start_line}"/>
								<TextBox Width="100" HorizontalAlignment="Left" Margin="5"
										 Text="{Binding Parameters.EndLine}"
										 materialDesign:HintAssist.HelperText="{loc:Loc application-end_line}"/>
							</StackPanel>

							<StackPanel Orientation="Vertical"
										Visibility="{Binding SelectedMode.HasByteSelections, Converter={StaticResource BooleanToVisibilityConverter}}">
								<TextBox Width="100" HorizontalAlignment="Left" Margin="5"
										 Text="{Binding Parameters.StartByte}"
										 materialDesign:HintAssist.HelperText="{loc:Loc application-start_byte}"/>
								<TextBox Width="100" HorizontalAlignment="Left" Margin="5"
										 Text="{Binding Parameters.EndByte}"
										 materialDesign:HintAssist.HelperText="{loc:Loc application-end_byte}"/>
							</StackPanel>

							<Button Content="{loc:Loc application-applicate_hint}"
									Command="{Binding ApplyCommand}"
									HorizontalAlignment="Right"
									Margin="0,10,0,0"/>

						</StackPanel>

					</materialDesign:Card>

				</DataTemplate>
			</ItemsControl.ItemTemplate>

		</ItemsControl>

		<Border x:Name="DropOverlay"
				Grid.RowSpan="2"
				Background="#2000BCD4"
				BorderBrush="#6000BCD4"
				BorderThickness="3"
				CornerRadius="8"
				Visibility="Collapsed"
				IsHitTestVisible="False">
			
			<TextBlock Text="{loc:Loc attachment-drop_files_here}"
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   FontSize="18"
					   Foreground="#FF00BCD4"/>
		</Border>

	</Grid>

</UserControl>