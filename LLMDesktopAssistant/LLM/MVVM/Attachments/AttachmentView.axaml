<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.LLM.Attachments"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:flui="using:FluentAvalonia.UI"
			 x:Class="LLMDesktopAssistant.LLM.Attachments.AttachmentView"
			 x:DataType="local:AttachmentViewModel">

	<Border>

		<DockPanel>

			<Button DockPanel.Dock="Right"
					Classes="SmallIconButton"
					Command="{Binding RemoveAttachmentCommand}"
					Width="24" Height="24">

				<ico:MaterialIcon Kind="Remove"
								  Width="16" Height="16"/>

			</Button>

			<TextBlock Text="{Binding Attachment.Title}" Margin="5"/>

		</DockPanel>
		
	</Border>

</UserControl>
