<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:beh="using:LLMDesktopAssistant.Behaviours"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.ChatManagerView"
			 x:DataType="local:ChatManagerViewModel">

	<Design.DataContext>
		<local:ChatManagerViewModel />
	</Design.DataContext>

	<SplitView x:Name="ChatSplitView"
						 PanePlacement="Right"
						 CompactPaneLength="0"
						 OpenPaneLength="470">
	
		<SplitView.Pane>
			
			<DockPanel>

				<StackPanel Orientation="Horizontal"
										Margin="8"
										DockPanel.Dock="Top">

					<TextBlock Text="{loc:Loc chats}"
										 Foreground="{DynamicResource DefaultForeground}"
										 FontSize="18"
										 VerticalAlignment="Center"
										 Margin="8"/>

				</StackPanel>

				<!-- Sidebar: list of all available chats (no edit controls) -->
				<ListBox ItemsSource="{Binding AvailableChats}"
								 SelectedItem="{Binding SelectedChat.SelectedAvailable}"
								 Margin="8">

					<ListBox.ItemTemplate>
						<DataTemplate>
							
							<DockPanel beh:ListBoxItemBehaviour.IsParentListBoxItemEnabled="{Binding !IsSelected}"
												 beh:ListBoxItemBehaviour.IsParentListBoxItemVisible="{Binding !IsTemporary}">

								<StackPanel VerticalAlignment="Center"
														DockPanel.Dock="Right">
									
									<Label Content="{Binding LastModifiedAt}"
												 Opacity="0.5"
												 FontSize="11"/>

									<StackPanel Orientation="Horizontal"
															HorizontalAlignment="Right"
															Spacing="4">
										
										<Button Command="{Binding OpenInNewTabCommand}"
														IsEnabled="{Binding !IsTemporary}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc open_in_new_tab}">
											<ico:MaterialIcon Kind="TabPlus"/>
										</Button>
										
										<Button Command="{Binding DeleteCommand}"
														IsEnabled="{Binding !IsTemporary}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc delete}">
											<ico:MaterialIcon Kind="Delete"/>
										</Button>
										
									</StackPanel>

								</StackPanel>

								<Border Width="8" Height="8"
												CornerRadius="4"
												Background="{Binding TopicColorHex}"
												VerticalAlignment="Center"
												Margin="0,0,6,0"
												DockPanel.Dock="Left"
												ToolTip.Tip="{Binding Topic}"/>
								
								<StackPanel VerticalAlignment="Center">
									
									<TextBlock Text="{Binding Title}"
														 FontSize="14"
														 TextWrapping="NoWrap"
														 TextTrimming="CharacterEllipsis"/>
									
									<TextBlock Text="{Binding Topic}"
															IsVisible="{Binding Topic, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
															Foreground="{Binding TopicColorHex}"
															FontSize="11"
															Opacity="0.8"
															VerticalAlignment="Center"
															TextWrapping="NoWrap"
															TextTrimming="CharacterEllipsis"/>
								
									<TextBlock Text="{loc:Loc no_topic}"
															IsVisible="{Binding Topic, Converter={StaticResource StringNonEmptyToBooleanConverterInverted}}"
															Foreground="{Binding TopicColorHex}"
															FontSize="11"
															Opacity="0.8"
															VerticalAlignment="Center"
															TextWrapping="NoWrap"
															TextTrimming="CharacterEllipsis"/>
								
								</StackPanel>
								
							</DockPanel>
							
						</DataTemplate>
					</ListBox.ItemTemplate>
					
				</ListBox>
				
			</DockPanel>

		</SplitView.Pane>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>

			<!-- TOP BAR with tabs & buttons -->
			<DockPanel Background="{DynamicResource TopBarBackground}">

				<StackPanel DockPanel.Dock="Right"
										HorizontalAlignment="Right"
										Orientation="Horizontal"
										Margin="10" Spacing="5">
					
					<Button Command="{Binding CreateChatCommand}"
									Classes="IconButton"
									ToolTip.Tip="{loc:Loc new_chat}">
						<ico:MaterialIcon Kind="MessagePlus"/>
					</Button>
					
					<Button Command="{Binding CreateTemporaryChatCommand}"
									Classes="IconButton"
									ToolTip.Tip="{loc:Loc new_temporary_chat}">
						<ico:MaterialIcon Kind="MessageFlash"/>
					</Button>
					
					<ToggleButton IsChecked="{Binding #ChatSplitView.IsPaneOpen}"
											  Classes="IconButton">
						<ico:MaterialIcon Kind="Forum"/>
					</ToggleButton>

				</StackPanel>

				<!-- Opened chats tabs with inline rename & AI rename -->
				<ListBox ItemsSource="{Binding OpenedChats}"
								 SelectedItem="{Binding SelectedChat}"
								 DockPanel.Dock="Left">
					
					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal"/>
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>

					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="local:OpenedChatViewModel">
							
							<Border Margin="2,0">
							
								<StackPanel Orientation="Horizontal"
														VerticalAlignment="Center"
														Spacing="4">
									
									<!-- Display mode -->
									<StackPanel Orientation="Horizontal" Spacing="4"
															IsVisible="{Binding !IsEditing}">
										
										<StackPanel Orientation="Vertical"
																VerticalAlignment="Center">
											
											<TextBlock Text="{Binding SelectedAvailable.Title}"
																 FontSize="14"
																 PointerPressed="TabTitleTextBlock_PointerPressed"
																 IsHitTestVisible="{Binding $parent[ListBoxItem].IsSelected}"
																 Cursor="Hand"/>
											
											<StackPanel Orientation="Horizontal" Spacing="4">
												
												<TextBlock Text="{Binding SelectedAvailable.Topic}"
																	 IsVisible="{Binding SelectedAvailable.Topic, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
																	 Foreground="{Binding SelectedAvailable.TopicColorHex}"
																	 FontSize="11"
																	 PointerPressed="TabTopicTextBlock_PointerPressed"
																	 IsHitTestVisible="{Binding $parent[ListBoxItem].IsSelected}"
																	 Cursor="Hand"/>
											
												<TextBlock Text="{loc:Loc no_topic}"
																	 IsVisible="{Binding SelectedAvailable.Topic, Converter={StaticResource StringNonEmptyToBooleanConverterInverted}}"
																	 Foreground="{Binding SelectedAvailable.TopicColorHex}"
																	 FontSize="11"
																	 PointerPressed="TabTopicTextBlock_PointerPressed"
																	 IsHitTestVisible="{Binding $parent[ListBoxItem].IsSelected}"
																	 Cursor="Hand"/>
											
												<TextBlock Text="{loc:Loc temporary_chat}"
																	 IsVisible="{Binding SelectedAvailable.IsTemporary}"
																	 FontStyle="Italic"
																	 Foreground="#AA888888"
																	 FontSize="11"/>
											
											</StackPanel>

										</StackPanel>

										<Button Command="{Binding RenameWithAICommand}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc rename_with_ai}">
											<ico:MaterialIcon Kind="AutoFix"/>
										</Button>
										
										<Button Command="{Binding CloseChatCommand}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc close}">
											<ico:MaterialIcon Kind="Close"/>
										</Button>

									</StackPanel>
									
									<!-- Title edit mode -->
									<StackPanel Orientation="Horizontal" Spacing="4"
															IsVisible="{Binding IsEditingTitle}">
										
										<TextBox Text="{Binding EditTitleText, Mode=TwoWay}"
														 FontSize="14"
														 MinWidth="80"
														 MaxWidth="200"
														 AcceptsReturn="False"
														 KeyDown="TabTitleTextBox_KeyDown"/>
										
										<Button Command="{Binding CommitEditTitleCommand}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc rename_chat_save}">
											<ico:MaterialIcon Kind="Check"/>
										</Button>
										
										<Button Command="{Binding CancelEditTitleCommand}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc rename_chat_cancel}">
											<ico:MaterialIcon Kind="Close"/>
										</Button>
									</StackPanel>
									
									<!-- Topic editing mode -->
									<StackPanel Orientation="Horizontal" Spacing="4"
															IsVisible="{Binding IsEditingTopic}">
										
										<TextBox Text="{Binding EditTopicText, Mode=TwoWay}"
														 FontSize="14"
														 MinWidth="80"
														 MaxWidth="200"
														 AcceptsReturn="False"
														 KeyDown="TabTopicTextBox_KeyDown"/>
										
										<Button Command="{Binding CommitEditTopicCommand}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc rename_chat_save}">
											<ico:MaterialIcon Kind="Check"/>
										</Button>
										
										<Button Command="{Binding CancelEditTopicCommand}"
														Classes="SmallIconButton"
														ToolTip.Tip="{loc:Loc rename_chat_cancel}">
											<ico:MaterialIcon Kind="Close"/>
										</Button>
									</StackPanel>

								</StackPanel>
								
							</Border>
							
						</DataTemplate>
					</ListBox.ItemTemplate>

				</ListBox>
				
			</DockPanel>

			<!-- CHAT -->
			<ContentControl Grid.Row="1"
											Content="{Binding SelectedChat.CurrentChat}"/>
		</Grid>

	</SplitView>

</UserControl>
