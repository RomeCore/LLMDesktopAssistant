<UserControl x:Class="LLMDesktopAssistant.LLM.MVVM.ChatView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Messages Area -->
		<ScrollViewer Grid.Row="0"
					  VerticalScrollBarVisibility="Auto"
					  PanningMode="VerticalOnly"
					  materialDesign:ScrollViewerAssist.IsAutoHideEnabled="True">

			<ContentControl Content="{Binding MessageSequence}"/>
		</ScrollViewer>

		<!-- Input Area -->
		<Border Grid.Row="1"
				Padding="16,8"
				Background="{DynamicResource MaterialDesignPaper}"
				BorderBrush="{DynamicResource MaterialDesignDivider}"
				BorderThickness="0,1,0,0">

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<materialDesign:Card Grid.Column="0"
									 Padding="8,4"
									 materialDesign:ShadowAssist.Darken="True">

					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<!-- Attach Button -->
						<Button Grid.Column="0"
								Style="{StaticResource MaterialDesignIconButton}"
								ToolTip="{loc:Loc chat-attach_file_hint}">
							<materialDesign:PackIcon Kind="Paperclip"/>
						</Button>

						<!-- Text Input -->
						<TextBox Grid.Column="1"
								 materialDesign:HintAssist.Hint="{loc:Loc chat-input_hint}"
								 materialDesign:TextFieldAssist.HasClearButton="True"
								 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
								 Text="{Binding UserInput, Mode=TwoWay}"
								 Margin="8,0"
								 VerticalAlignment="Center"
								 TextWrapping="Wrap"
								 AcceptsReturn="True"
								 MaxHeight="120"
								 Foreground="{DynamicResource MaterialDesignBody}"
								 FontSize="16"
								 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

						<!-- Send Button -->
						<Button Grid.Column="2"
								Style="{StaticResource MaterialDesignIconButton}"
								Command="{Binding SendMessageCommand}"
								ToolTip="{loc:Loc chat-send_button_hint}">
							<materialDesign:PackIcon Kind="Send"/>
						</Button>
					</Grid>
				</materialDesign:Card>

				<!-- Settings Button -->
				<Button Grid.Column="1"
						Style="{StaticResource MaterialDesignIconButton}"
						Margin="8,0,0,0"
						ToolTip="{loc:Loc chat-settings_hint}">
					<materialDesign:PackIcon Kind="Cog"/>
				</Button>
			</Grid>
		</Border>
	</Grid>
	
</UserControl>