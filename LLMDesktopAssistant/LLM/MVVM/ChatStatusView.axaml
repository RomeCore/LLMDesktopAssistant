<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM"
			 xmlns:ico="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="32"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.ChatStatusView"
			 x:DataType="local:ChatStatusViewModel"
			 Height="32">
	
	<StackPanel Classes="StatusRoot"
							IsVisible="{Binding IsActive}"
							Orientation="Horizontal"
							Margin="40,6">

		<StackPanel.Styles>
			
			<Style Selector="StackPanel.StatusRoot">
				<Style.Animations>
					<Animation Duration="0:0:1"
											IterationCount="INFINITE"
											PlaybackDirection="Alternate"
											Easing="SineEaseInOut">
						<KeyFrame Cue="0%">
							<Setter Property="Opacity" Value="1.0"/>
						</KeyFrame>
						<KeyFrame Cue="100%">
							<Setter Property="Opacity" Value="0.3"/>
						</KeyFrame>
					</Animation>
				</Style.Animations>
			</Style>

		</StackPanel.Styles>

		<ico:MaterialIcon Kind="{Binding IconKind}"
											Width="16" Height="16"
											Margin="2"
											Foreground="White"
											HorizontalAlignment="Center"
											VerticalAlignment="Center" />

		<TextBlock Grid.Column="1"
							 Text="{Binding StatusText}"
							 VerticalAlignment="Center"
							 FontSize="14"
							 Margin="4,0,0,0" />

		<TextBlock Grid.Column="2"
							 Text="{Binding AnimatedDots}"
							 VerticalAlignment="Center"
							 FontSize="14" />

	</StackPanel>

</UserControl>
