<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.LLM.Messages"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.LLM.Messages.AssistantMessageView"
			 x:DataType="local:AssistantMessageViewModel">
	
	<StackPanel Orientation="Vertical"
			VerticalAlignment="Top"
			Margin="40,8">

		<StackPanel Orientation="Horizontal" IsVisible="{Binding ShowAvatar}">
			
			<Panel>
				
				<Border IsVisible="{Binding SenderAvatar, Converter={StaticResource NotnullToBooleanConverter}}"
								Width="32" Height="32" CornerRadius="4" ClipToBounds="True" Margin="4">
					<Image Source="{Binding SenderAvatar}" Width="32" Height="32"/>
				</Border>
				
				
				<ico:MaterialIcon Kind="Robot" Width="32" Height="32" Margin="4"
													IsVisible="{Binding SenderAvatar, Converter={StaticResource NotnullToBooleanConverterInverted}}"/>

			</Panel>

			<TextBlock Text="{Binding SenderName}"
								 FontSize="16"
								 FontWeight="Bold"
								 Margin="4"
								 VerticalAlignment="Center"/>

		</StackPanel>

		<ContentControl Content="{Binding ReasoningPart}"/>
		<ContentControl Content="{Binding TextPart}"/>
		<ContentControl Content="{Binding ToolPart}"/>
		<Label Content="{Binding Error}"
				 Foreground="Red"
				 IsVisible="{Binding Error, Converter={StaticResource StringNonEmptyToBooleanConverter}}"/>

		<ItemsControl ItemsSource="{Binding AssistantMessage.AdditionalViewModels}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Vertical" />
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<ContentControl	Content="{Binding}" IsVisible="{Binding IsVisible}" />
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<StackPanel Orientation="Horizontal"
					HorizontalAlignment="Left"
					IsVisible="{Binding IsCompleted}"
					Spacing="4">

			<Button Command="{Binding RegenerateCommand}"
					Classes="IconButton"
					ToolTip.Tip="{loc:Loc regenerate}">
				<ico:MaterialIcon Kind="Refresh"/>
			</Button>

			<Button Command="{Binding ResendCommand}"
					Classes="IconButton"
					IsVisible="{Binding ContainsToolCalls}"
					ToolTip.Tip="{loc:Loc resend}">
				<ico:MaterialIcon Kind="ArrowUDownLeft"/>
			</Button>

			<Button Command="{Binding ResendCommand}"
					Classes="IconButton"
					IsVisible="{Binding ContainsToolCalls, Converter={StaticResource InverseBooleanConverter}}"
					ToolTip.Tip="{loc:Loc resend}">
				<ico:MaterialIcon Kind="ChevronDoubleDown"/>
			</Button>

			<StackPanel Orientation="Horizontal"
						IsVisible="{Binding BranchSelectionAvailable}"
						Spacing="4">

				<Button Command="{Binding SwitchBranchCommand}"
						Classes="IconButton"
						CommandParameter="{Binding PreviousBranchIndex}">
					<ico:MaterialIcon Kind="ChevronLeft"/>
				</Button>

				<ComboBox ItemsSource="{Binding BranchIndices}"
							SelectedItem="{Binding SelectedBranchIndex}"/>

				<Button Command="{Binding SwitchBranchCommand}"
						Classes="IconButton"
						CommandParameter="{Binding NextBranchIndex}">
					<ico:MaterialIcon Kind="ChevronRight"/>
				</Button>

			</StackPanel>
			
			<ItemsControl ItemsSource="{Binding Extensions}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Horizontal" Spacing="4"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						
						<Button Command="{Binding Command}"
								Classes="IconButton"
								IsVisible="{Binding IsButtonVisible}">
							<ico:MaterialIcon Kind="{Binding Icon}"/>
						</Button>

					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

		</StackPanel>

	</StackPanel>

</UserControl>
