<UserControl x:Class="LLMDesktopAssistant.LLM.MVVM.Messages.AssistantMessageReasoningPartView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM.Messages"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 xmlns:controls="clr-namespace:LLMDesktopAssistant.Controls"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<Expander Padding="0"
			  BorderThickness="0"
			  Background="Transparent"
			  IsExpanded="{Binding NotCompleted, Mode=OneWay}"
			  materialDesign:ExpanderAssist.HorizontalHeaderPadding="0"
			  materialDesign:ExpanderAssist.ExpanderButtonPosition="Start">

		<Expander.Style>
			<Style TargetType="Expander"
				   BasedOn="{StaticResource MaterialDesignExpander}">
				<Setter Property="materialDesign:ExpanderAssist.ExpanderButtonContent"
						Value="{materialDesign:PackIcon Kind=Brain, Size=24}" />
				<Style.Triggers>
					<Trigger Property="IsExpanded"
							 Value="True">
						<Setter Property="materialDesign:ExpanderAssist.ExpanderButtonContent"
								Value="{materialDesign:PackIcon Kind=Minus, Size=24}" />
					</Trigger>
				</Style.Triggers>
			</Style>
		</Expander.Style>

		<Expander.Header>
			<TextBlock Text="{loc:Loc reasoning}"
					   FontSize="16"
					   Margin="5,0,0,0"/>
		</Expander.Header>

		<controls:StreamingMarkdownControl MarkdownText="{Binding ReasoningText}"
										   Completed="{Binding Completed}"
										   Opacity="0.7"
										   Margin="0,5"/>

	</Expander>
	
</UserControl>
