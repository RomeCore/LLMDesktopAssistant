<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.LLM.Messages"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:flui="using:FluentAvalonia.UI.Controls"
			 xmlns:beh="clr-namespace:LLMDesktopAssistant.Behaviours"
			 x:Class="LLMDesktopAssistant.LLM.Messages.ToolCallView"
			 x:DataType="local:ToolCallViewModel">
	
	<UserControl.Styles>
		<Style Selector="FlyoutPresenter">
			<Setter Property="Padding" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="MaxWidth" Value="755"/>
			<Setter Property="MaxHeight" Value="655"/>
			<Setter Property="MinWidth" Value="505"/>
			<Setter Property="MinHeight" Value="305"/>
		</Style>
	</UserControl.Styles>

	<!-- Main tool call button -->
	<Button Padding="2"
					Margin="0,0,0,4">

		<Button.Flyout>
			
			<Flyout Placement="BottomEdgeAlignedLeft"
							ShowMode="Standard">

				<Border Background="{DynamicResource CardBackground}"
								BorderBrush="{DynamicResource CardBorderBrush}"
								BorderThickness="1"
								MinWidth="500"
								MaxWidth="750"
								MinHeight="300"
								MaxHeight="650"
								CornerRadius="8"
								Padding="8">

					<Grid RowDefinitions="Auto,*,Auto">

						<Border Grid.Row="0"
										Background="{DynamicResource WindowBackground}"
										CornerRadius="8,8,0,0"
										Padding="16,12,8,12">

							<Grid ColumnDefinitions="*,*,Auto,Auto">

								<!-- Tool Name: localized + raw -->
								<StackPanel Orientation="Vertical" Grid.Column="0" Spacing="1" VerticalAlignment="Center">

									<TextBlock Text="{loc:Loc {Binding ToolTitle}}"
															FontSize="16"
															FontWeight="Bold"
															HorizontalAlignment="Left"/>

									<TextBlock Text="{Binding ToolName}"
															FontSize="13"
															Opacity="0.45"
															HorizontalAlignment="Left"/>

								</StackPanel>

								<!-- Tool Call ID -->
								<TextBlock Grid.Column="1"
														Text="{Binding ToolCallId}"
														FontSize="11"
														Opacity="0.35"
														VerticalAlignment="Center"
														HorizontalAlignment="Right"
														Margin="0,0,8,0"/>

								<!-- Copy Arguments button -->
								<Button Grid.Column="2"
												Classes="IconButton"
												Command="{Binding CopyArgumentsCommand}"
												IsVisible="{Binding Arguments, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
												ToolTip.Tip="{loc:Loc copy-arguments}"
												Margin="3,0,0,0">

									<ico:MaterialIcon Kind="CodeBraces"/>

								</Button>

								<!-- Copy Result button -->
								<Button Grid.Column="3"
												Classes="IconButton"
												Command="{Binding CopyResultCommand}"
												IsVisible="{Binding Result, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
												ToolTip.Tip="{loc:Loc copy-result}"
												Margin="3,0,0,0">

									<ico:MaterialIcon Kind="ContentCopy"/>

								</Button>

							</Grid>

						</Border>

						<!-- Separator -->
						<Rectangle Grid.Row="1" Grid.RowSpan="2"
												Fill="{DynamicResource PrimaryAccentBrush}"
												Height="1"
												VerticalAlignment="Top"/>

						<ScrollViewer Grid.Row="1"
													VerticalScrollBarVisibility="Auto"
													HorizontalScrollBarVisibility="Auto"
													beh:ScrollViewerBehavior.AutoScrollEnabled="True">

							<StackPanel Orientation="Vertical"
													Spacing="20"
													Margin="16,16,32,32"
													MaxWidth="650">

								<!-- Arguments Section -->
								<StackPanel Orientation="Vertical"
														Spacing="8"
														IsVisible="{Binding Arguments, Converter={StaticResource StringNonEmptyToBooleanConverter}}">
										
									<Border DockPanel.Dock="Top"
													BorderBrush="{DynamicResource DefaultForeground}"
													BorderThickness="0,0,0,1"
													Padding="8,6">
										<TextBlock Text="{loc:Loc tool-arguments}"
																FontSize="18"
																FontWeight="Bold"/>
									</Border>
										
									<ctrl:MarkdownControl MarkdownText="{Binding Arguments}"
																				Background="Transparent"/>

								</StackPanel>

								<!-- Result Section -->
								<StackPanel Orientation="Vertical"
														Spacing="8"
														IsVisible="{Binding Result, Converter={StaticResource StringNonEmptyToBooleanConverter}}">
										
									<Border DockPanel.Dock="Top"
													BorderBrush="{DynamicResource DefaultForeground}"
													BorderThickness="0,0,0,1"
													Padding="8,6">
										<TextBlock Text="{loc:Loc tool-result}"
																FontSize="18"
																FontWeight="Bold"/>
									</Border>
										
									<ctrl:MarkdownControl MarkdownText="{Binding Result}"
																				UsePlaintext="{Binding !UseMarkdown}"
																				Background="Transparent"/>

								</StackPanel>

							</StackPanel>

						</ScrollViewer>

					</Grid>

				</Border>

			</Flyout>
		</Button.Flyout>

		<WrapPanel Orientation="Horizontal"
							 ItemSpacing="4">
				
			<Panel Width="28" Height="28">
					
				<Panel IsVisible="{Binding StatusIcon, Converter={StaticResource NotnullToBooleanConverter}}">
					
					<ico:MaterialIcon Kind="{Binding StatusIcon}"
														Classes="MidIcon"
														HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

					<Border Width="16" Height="16" CornerRadius="6"
									HorizontalAlignment="Right"
									VerticalAlignment="Bottom"
									IsVisible="{Binding DisplayMiniIcon}"
									Background="#ac000000"
									BoxShadow="0 0 3 0 #ac000000">
							
						<Panel>
							
							<Panel IsVisible="{Binding ToolIconVisible}">
						
								<ico:MaterialIcon Kind="{Binding ToolIcon}"
																	Foreground="{Binding ToolIconBrush}"
																	Width="16" Height="16"
																	IsVisible="{Binding IsBlinking}">
				
									<ico:MaterialIcon.Styles>
										<Style Selector="ico|MaterialIcon">
											<Style.Animations>
												<Animation Duration="0:0:1"
																		IterationCount="INFINITE"
																		PlaybackDirection="Alternate"
																		Easing="SineEaseInOut">
													<KeyFrame Cue="0%">
														<Setter Property="Opacity" Value="1.0"/>
													</KeyFrame>
													<KeyFrame Cue="100%">
														<Setter Property="Opacity" Value="0.3"/>
													</KeyFrame>
												</Animation>
											</Style.Animations>
										</Style>
									</ico:MaterialIcon.Styles>
				
								</ico:MaterialIcon>
					
								<ico:MaterialIcon Kind="{Binding ToolIcon}"
																	Foreground="{Binding ToolIconBrush}"
																	Width="16" Height="16"
																	IsVisible="{Binding !IsBlinking}"/>

							</Panel>

							<ctrl:ProgressRing IsVisible="{Binding InProgress}"
																 Foreground="{Binding ToolIconBrush}"
																 Width="16" Height="16"
																 StrokeThickness="4"
																 Minimum="{Binding MinProgress}" Maximum="{Binding MaxProgress}"
																 Value="{Binding Progress}"
																 IsIndeterminate="{Binding Progress, Converter={StaticResource NotnullToBooleanConverterInverted}}"/>
								
						</Panel>

					</Border>

				</Panel>
					
				<Panel IsVisible="{Binding StatusIcon, Converter={StaticResource NotnullToBooleanConverterInverted}}">
					
					<Panel IsVisible="{Binding ToolIconVisible}">
						
						<ico:MaterialIcon Kind="{Binding ToolIcon}"
															Foreground="{Binding ToolIconBrush}"
															Width="28" Height="28"
															IsVisible="{Binding IsBlinking}">
				
							<ico:MaterialIcon.Styles>
								<Style Selector="ico|MaterialIcon">
									<Style.Animations>
										<Animation Duration="0:0:1"
																IterationCount="INFINITE"
																PlaybackDirection="Alternate"
																Easing="SineEaseInOut">
											<KeyFrame Cue="0%">
												<Setter Property="Opacity" Value="1.0"/>
											</KeyFrame>
											<KeyFrame Cue="100%">
												<Setter Property="Opacity" Value="0.3"/>
											</KeyFrame>
										</Animation>
									</Style.Animations>
								</Style>
							</ico:MaterialIcon.Styles>
				
						</ico:MaterialIcon>
					
						<ico:MaterialIcon Kind="{Binding ToolIcon}"
															Foreground="{Binding ToolIconBrush}"
															Width="28" Height="28"
															IsVisible="{Binding !IsBlinking}"/>

					</Panel>

					<ctrl:ProgressRing IsVisible="{Binding InProgress}"
														 Foreground="{Binding ToolIconBrush}"
														 Width="28" Height="28"
														 Minimum="{Binding MinProgress}" Maximum="{Binding MaxProgress}"
														 Value="{Binding Progress}"
														 IsIndeterminate="{Binding Progress, Converter={StaticResource NotnullToBooleanConverterInverted}}"/>

				</Panel>
				
			</Panel>

			<TextBlock Text="{loc:Loc {Binding ToolTitle}}"
									FontSize="{DynamicResource FontSizeM}"
									FontWeight="Medium"
									VerticalAlignment="Bottom"
									Margin="0,2"/>
				
			<StackPanel IsVisible="{Binding StatusTitle, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
									Orientation="Horizontal"
									Spacing="4">

				<GridSplitter Width="2" MinWidth="2" ResizeDirection="Columns" IsEnabled="False"/>
				
				<ctrl:MarkdownControl MarkdownText="{Binding StatusTitle}"
															Margin="2,3"
															VerticalAlignment="Bottom"/>

			</StackPanel>

			<StackPanel IsVisible="{Binding UserAsked}"
									Orientation="Horizontal"
									Spacing="4">
							
				<GridSplitter Width="2" MinWidth="2" ResizeDirection="Columns" IsEnabled="False"/>
				
				<Button Classes="MidIconButton"
								Command="{Binding ApproveCommand}">
					<ico:MaterialIcon Kind="Check"/>
				</Button>

				<Button Classes="MidIconButton"
								Command="{Binding CancelCommand}">
					<ico:MaterialIcon Kind="Close"/>
				</Button>

				<Button Classes="MidIconButton"
								Command="{Binding CancelWithReasonBeginCommand}">
					<ico:MaterialIcon Kind="TextBoxRemoveOutline"/>
				</Button>

			</StackPanel>
				
			<StackPanel IsVisible="{Binding WritingReason}"
									Orientation="Horizontal"
									Spacing="4">
							
				<GridSplitter Width="2" MinWidth="2" ResizeDirection="Columns" IsEnabled="False"/>
				
				<TextBox x:Name="ReasonTextBox2"
									KeyDown="ReasonTextBox_KeyDown"/>

				<Button Classes="MidIconButton"
								Command="{Binding CancelWithReasonEndCommand}"
								CommandParameter="{Binding #ReasonTextBox2.Text}">
					<ico:MaterialIcon Kind="Check"/>
				</Button>

				<Button Classes="MidIconButton"
								Command="{Binding CancelWithReasonBackCommand}">
					<ico:MaterialIcon Kind="Close"/>
				</Button>

			</StackPanel>
				
		</WrapPanel>

	</Button>

</UserControl>
