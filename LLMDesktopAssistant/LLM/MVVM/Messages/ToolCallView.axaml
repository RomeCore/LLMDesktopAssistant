<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.LLM.Messages"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:flui="using:FluentAvalonia.UI.Controls"
			 x:Class="LLMDesktopAssistant.LLM.Messages.ToolCallView"
			 x:DataType="local:ToolCallViewModel">
	
	<UserControl.Styles>
		<Style Selector="FlyoutPresenter">
			<Setter Property="Padding" Value="0"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="MaxWidth" Value="755"/>
			<Setter Property="MaxHeight" Value="655"/>
			<Setter Property="MinWidth" Value="505"/>
			<Setter Property="MinHeight" Value="305"/>
		</Style>
	</UserControl.Styles>

	<Panel>
		
		<!-- Main tool call button -->
		<Button Padding="2">

			<Button.Flyout>
			
				<Flyout Placement="BottomEdgeAlignedLeft"
						ShowMode="Standard">

					<Border Background="{DynamicResource CardBackground}"
							BorderBrush="{DynamicResource CardBorderBrush}"
							BorderThickness="1"
							MinWidth="500"
							MaxWidth="750"
							MinHeight="300"
							MaxHeight="650"
							CornerRadius="8"
							Padding="0">

						<Grid RowDefinitions="Auto,*,Auto" Margin="0">

							<Border Grid.Row="0"
									Background="{DynamicResource WindowBackground}"
									CornerRadius="8,8,0,0"
									Padding="16,12,8,12">

								<Grid ColumnDefinitions="Auto,*,Auto,*,Auto,Auto">

									<!-- Status Icon -->
									<Grid Grid.Column="0" Width="28" Height="28" Margin="0,0,10,0">
										<ico:MaterialIcon Kind="Edit"
																			IsVisible="{Binding IsPending}"
																			Classes="MidIcon">
											<ico:MaterialIcon.Styles>
												<Style Selector="ico|MaterialIcon">
													<Style.Animations>
														<Animation Duration="0:0:1"
																			 IterationCount="INFINITE"
																			 PlaybackDirection="Alternate"
																			 Easing="SineEaseInOut">
															<KeyFrame Cue="0%">
																<Setter Property="Opacity" Value="1.0"/>
															</KeyFrame>
															<KeyFrame Cue="100%">
																<Setter Property="Opacity" Value="0.3"/>
															</KeyFrame>
														</Animation>
													</Style.Animations>
												</Style>
											</ico:MaterialIcon.Styles>
										</ico:MaterialIcon>

										<ctrl:ProgressRing IsVisible="{Binding InProgress}"
																				 Minimum="{Binding MinProgress}"
																				 Maximum="{Binding MaxProgress}"
																				 Value="{Binding Progress}"
																				 IsIndeterminate="{Binding Progress, Converter={StaticResource NotnullToBooleanConverterInverted}}"/>
										
										<ico:MaterialIcon Kind="{Binding ToolIcon}"
																			Classes="MidIcon"
																			IsVisible="{Binding ToolIconVisible}"/>

									</Grid>

									<!-- Tool Name: localized + raw -->
									<StackPanel Grid.Column="1" Orientation="Vertical" Spacing="1" VerticalAlignment="Center">

										<TextBlock Text="{loc:Loc {Binding ToolTitle}}"
															 FontSize="16"
															 FontWeight="Bold"
															 HorizontalAlignment="Left"/>

										<TextBlock Text="{Binding ToolName}"
															 FontSize="13"
															 Opacity="0.45"
															 HorizontalAlignment="Left"/>

									</StackPanel>

									<!-- Approval buttons in header -->
									<StackPanel Orientation="Horizontal"
															Grid.Column="2" 
															Spacing="4"
															IsVisible="{Binding UserAsked}">

										<Button Classes="MidIconButton"
														Command="{Binding ApproveCommand}">
											<ico:MaterialIcon Kind="Check"/>
										</Button>

										<Button Classes="MidIconButton"
														Command="{Binding CancelCommand}">
											<ico:MaterialIcon Kind="Close"/>
										</Button>

									</StackPanel>

									<!-- Tool Call ID -->
									<TextBlock Grid.Column="3"
														 Text="{Binding ToolCallId}"
														 FontSize="11"
														 Opacity="0.35"
														 VerticalAlignment="Center"
														 HorizontalAlignment="Right"
														 Margin="0,0,8,0"/>

									<!-- Copy Arguments button -->
									<Button Grid.Column="4"
													Classes="IconButton"
													Command="{Binding CopyArgumentsCommand}"
													IsVisible="{Binding Arguments, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
													ToolTip.Tip="{loc:Loc copy-arguments}"
													Margin="3,0,0,0">

										<ico:MaterialIcon Kind="CodeBraces"/>

									</Button>

									<!-- Copy Result button -->
									<Button Grid.Column="5"
													Classes="IconButton"
													Command="{Binding CopyResultCommand}"
													IsVisible="{Binding Result, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
													ToolTip.Tip="{loc:Loc copy-result}"
													Margin="3,0,0,0">

										<ico:MaterialIcon Kind="ContentCopy"/>

									</Button>

								</Grid>

							</Border>

							<!-- Separator -->
							<Rectangle Grid.Row="1" Grid.RowSpan="2"
												 Fill="{DynamicResource SystemAccentColor}"
												 Height="1"
												 VerticalAlignment="Top"/>

							<ScrollViewer Grid.Row="1"
											VerticalScrollBarVisibility="Auto"
											HorizontalScrollBarVisibility="Auto"
											Padding="16,16,16,8">

								<StackPanel Orientation="Vertical" Spacing="20">

									<!-- Arguments Section -->
									<StackPanel Orientation="Vertical"
															Spacing="8"
															IsVisible="{Binding Arguments, Converter={StaticResource StringNonEmptyToBooleanConverter}}">
										
										<Border DockPanel.Dock="Top"
														BorderBrush="{DynamicResource DefaultForeground}"
														BorderThickness="0,0,0,1"
														Padding="8,6">
											<TextBlock Text="{loc:Loc tool-arguments}"
																 FontSize="18"
																 FontWeight="Bold"/>
										</Border>

										<Border Background="{DynamicResource CodeBackground}"
														BorderBrush="{DynamicResource CardBorderBrush}"
														BorderThickness="1"
														CornerRadius="6"
														Padding="14">

											<ctrl:MarkdownControl MarkdownText="{Binding Arguments}"
																						Background="Transparent"/>

										</Border>

									</StackPanel>

									<!-- Result Section -->
									<StackPanel Orientation="Vertical"
															Spacing="8"
															IsVisible="{Binding Result, Converter={StaticResource StringNonEmptyToBooleanConverter}}">
										
										<Border DockPanel.Dock="Top"
														BorderBrush="{DynamicResource DefaultForeground}"
														BorderThickness="0,0,0,1"
														Padding="8,6">
											<TextBlock Text="{loc:Loc tool-result}"
																 FontSize="18"
																 FontWeight="Bold"/>
										</Border>

										<Border Background="{DynamicResource CardBackground}"
														BorderBrush="{DynamicResource CardBorderBrush}"
														BorderThickness="1"
														CornerRadius="6"
														Padding="14">

											<ctrl:MarkdownControl MarkdownText="{Binding Result}"
																						UsePlaintext="True"
																						Background="Transparent"/>

										</Border>

									</StackPanel>

								</StackPanel>

							</ScrollViewer>

						</Grid>

					</Border>

				</Flyout>
			</Button.Flyout>

			<StackPanel Orientation="Horizontal"
									Spacing="4">
		
				<Grid Width="28" Height="28"
							Margin="0,0,2,0">
					
					<ico:MaterialIcon Kind="Edit"
														Margin="0"
														Classes="MidIcon"
														IsVisible="{Binding IsPending}">
				
						<ico:MaterialIcon.Styles>
							<Style Selector="ico|MaterialIcon">
								<Style.Animations>
									<Animation Duration="0:0:1"
														 IterationCount="INFINITE"
														 PlaybackDirection="Alternate"
														 Easing="SineEaseInOut">
										<KeyFrame Cue="0%">
											<Setter Property="Opacity" Value="1.0"/>
										</KeyFrame>
										<KeyFrame Cue="100%">
											<Setter Property="Opacity" Value="0.3"/>
										</KeyFrame>
									</Animation>
								</Style.Animations>
							</Style>
						</ico:MaterialIcon.Styles>
				
					</ico:MaterialIcon>

					<ctrl:ProgressRing IsVisible="{Binding InProgress}"
														 Minimum="{Binding MinProgress}" Maximum="{Binding MaxProgress}"
														 Value="{Binding Progress}"
														 IsIndeterminate="{Binding Progress, Converter={StaticResource NotnullToBooleanConverterInverted}}"/>

					<ico:MaterialIcon Kind="{Binding ToolIcon}"
														Margin="0"
														Classes="MidIcon"
														IsVisible="{Binding ToolIconVisible}"/>

				</Grid>
				
				<TextBlock Text="{loc:Loc {Binding ToolTitle}}"
									 FontSize="{DynamicResource FontSizeM}"
									 FontWeight="Medium"
									 VerticalAlignment="Bottom"
									 Margin="0,2"/>

				<Panel>
					
					<StackPanel Orientation="Horizontal"
											Spacing="4"
											IsVisible="{Binding UserAsked}">

						<Button Classes="MidIconButton"
										Command="{Binding ApproveCommand}">
							<ico:MaterialIcon Kind="Check"/>
						</Button>

						<Button Classes="MidIconButton"
										Command="{Binding CancelCommand}">
							<ico:MaterialIcon Kind="Close"/>
						</Button>

					</StackPanel>
				
					<StackPanel Orientation="Horizontal"
											Spacing="4"
											IsVisible="{Binding StatusAvailable}">

						<GridSplitter Width="2" MinWidth="2" ResizeDirection="Columns" IsEnabled="False"/>
				
						<ico:MaterialIcon Kind="{Binding StatusIcon}"
															IsVisible="{Binding StatusIcon, Converter={StaticResource NotnullToBooleanConverter}}"
															Width="24" Height="24"
															Margin="2"/>

						<ctrl:MarkdownControl MarkdownText="{Binding StatusTitle}"
																	Margin="2,3"
																	VerticalAlignment="Bottom"/>

					</StackPanel>

				</Panel>
			
			</StackPanel>

		</Button>

	</Panel>
	
</UserControl>
