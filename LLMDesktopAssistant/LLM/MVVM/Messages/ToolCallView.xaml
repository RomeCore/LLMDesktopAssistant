<UserControl x:Class="LLMDesktopAssistant.LLM.MVVM.Messages.ToolCallView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM.Messages"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 xmlns:controls="clr-namespace:LLMDesktopAssistant.Controls"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<UserControl.Resources>
		<Style x:Key="ToolIconStyle" TargetType="materialDesign:PackIcon">
			<Setter Property="Width" Value="24"/>
			<Setter Property="Height" Value="24"/>
			<Setter Property="Kind" Value="Hammer"/>
			<Style.Triggers>
				<DataTrigger Binding="{Binding Status}" Value="UserAsked">
					<Setter Property="Kind" Value="QuestionMarkCircle"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding Status}" Value="Success">
					<Setter Property="Kind" Value="CheckCircle"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding Status}" Value="Cancelled">
					<Setter Property="Kind" Value="CancelCircle"/>
				</DataTrigger>
				<DataTrigger Binding="{Binding Status}" Value="Error">
					<Setter Property="Kind" Value="AlertCircle"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>

		<DataTemplate x:Key="MarkdownResultTemplate">
			<controls:MarkdownControl MarkdownText="{Binding}"/>
		</DataTemplate>

		<DataTemplate x:Key="PlainTextResultTemplate">
			<TextBlock Text="{Binding}"
					   FontFamily="Cascadia Code"
					   FontSize="14"
					   TextWrapping="Wrap"/>
		</DataTemplate>

		<local:ToolResultTemplateSelector x:Key="ToolResultTemplateSelector"
										  MarkdownTemplate="{StaticResource MarkdownResultTemplate}"
										  PlainTextTemplate="{StaticResource PlainTextResultTemplate}"
										  Threshold="1"/>
	</UserControl.Resources>

	<Grid Margin="0,2">
		
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<!-- Container for icon/progress -->
		<Grid Grid.Column="0" Width="24" Height="24" Margin="0,0,4,0">
			<!-- Progress bar for InProgress state (visible only when status is InProgress) -->
			<ProgressBar 
				IsIndeterminate="True"
				Value="35">
				<ProgressBar.Style>
					<Style TargetType="ProgressBar" BasedOn="{StaticResource MaterialDesignCircularProgressBar}">
						<Setter Property="Visibility" Value="Collapsed"/>
						<Style.Triggers>
							<DataTrigger Binding="{Binding Status}" Value="InProgress">
								<Setter Property="Visibility" Value="Visible"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</ProgressBar.Style>
			</ProgressBar>

			<!-- Static icons for other states (visible when status is not InProgress) -->
			<materialDesign:PackIcon>
				<materialDesign:PackIcon.Style>
					<Style TargetType="materialDesign:PackIcon" BasedOn="{StaticResource ToolIconStyle}">
						<Setter Property="Visibility" Value="Visible"/>
						<Style.Triggers>
							<DataTrigger Binding="{Binding Status}" Value="InProgress">
								<Setter Property="Visibility" Value="Collapsed"/>
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</materialDesign:PackIcon.Style>
			</materialDesign:PackIcon>
		</Grid>

		<materialDesign:PopupBox Grid.Column="1" PopupMode="Click">
			
			<materialDesign:PopupBox.ToggleContent>
				<TextBlock Text="{loc:Loc {Binding ToolName}}"
						   FontSize="16"
						   FontWeight="Medium"
						   VerticalAlignment="Center"/>
			</materialDesign:PopupBox.ToggleContent>

			<materialDesign:PopupBox.PopupContent>

				<ScrollViewer VerticalScrollBarVisibility="Auto"
							  HorizontalScrollBarVisibility="Auto">

					<StackPanel Orientation="Vertical">

						<StackPanel Orientation="Vertical"
									Visibility="{Binding Arguments, Converter={StaticResource StringNonEmptyToVisiblityConverter}}">

							<Label Content="{loc:Loc tool-arguments}"
								   FontSize="16"/>

							<controls:MarkdownControl MarkdownText="{Binding Arguments}"
													  Margin="5,0"/>

						</StackPanel>

						<StackPanel Orientation="Vertical"
									Visibility="{Binding Result, Converter={StaticResource StringNonEmptyToVisiblityConverter}}">

							<Label Content="{loc:Loc tool-result}"
								   FontSize="16"/>

							<ContentControl Content="{Binding Result}"
											Margin="5,0"
											ContentTemplateSelector="{StaticResource ToolResultTemplateSelector}"/>

						</StackPanel>

					</StackPanel>

				</ScrollViewer>
				
			</materialDesign:PopupBox.PopupContent>
			
		</materialDesign:PopupBox>

		<StackPanel Grid.Column="2"
					Orientation="Horizontal"
					Margin="8,0,0,0">

			<StackPanel.Style>
				<Style TargetType="StackPanel">
					<Setter Property="Visibility" Value="Collapsed"/>
					<Style.Triggers>
						<DataTrigger Binding="{Binding Status}" Value="UserAsked">
							<Setter Property="Visibility" Value="Visible"/>
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</StackPanel.Style>

			<Button Width="20"
					Height="20"
					Margin="0,0,4,0"
					Command="{Binding ApproveCommand}"
					Style="{StaticResource MaterialDesignFloatingActionMiniButton}">

				<materialDesign:PackIcon Kind="Check"/>
			</Button>

			<Button Width="20"
					Height="20"
					Command="{Binding CancelCommand}"
					Style="{StaticResource MaterialDesignFloatingActionMiniDarkButton}">

				<materialDesign:PackIcon Kind="Close"/>
			</Button>

		</StackPanel>

	</Grid>
</UserControl>