<UserControl x:Class="LLMDesktopAssistant.Core.LLM.MVVM.Settings.ChatSettingsView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Core.LLM.MVVM.Settings"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Core.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Core.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<TabControl Style="{StaticResource MaterialDesignNavigationRailTabControl}"
				Width="800"
				Height="750">

		<TabItem>

			<TabItem.Header>
				<StackPanel Orientation="Vertical">

					<materialDesign:PackIcon Kind="Cog"
											 Width="24" Height="24"
											 HorizontalAlignment="Center"/>
					<TextBlock Text="{loc:Loc chat_settings_general}"
							   TextTrimming="CharacterEllipsis"/>

				</StackPanel>
			</TabItem.Header>

			<ContentControl Content="{Binding GeneralSettings}"/>

		</TabItem>

		<TabItem>

			<TabItem.Header>
				<StackPanel Orientation="Vertical">

					<materialDesign:PackIcon Kind="Wrench"
											 Width="24" Height="24"
											 HorizontalAlignment="Center"/>
					<TextBlock Text="{loc:Loc chat_settings_tools}"
							   TextTrimming="CharacterEllipsis"/>

				</StackPanel>
			</TabItem.Header>

			<ContentControl Content="{Binding ToolSettings}"/>

		</TabItem>

		<TabItem>

			<TabItem.Header>
				<StackPanel Orientation="Vertical">

					<materialDesign:PackIcon Kind="Connection"
											 Width="24" Height="24"
											 HorizontalAlignment="Center"/>
					<TextBlock Text="{loc:Loc chat_settings_mcp}"
							   TextTrimming="CharacterEllipsis"/>

				</StackPanel>
			</TabItem.Header>

			<ContentControl Content="{Binding McpSettings}"/>

		</TabItem>

	</TabControl>
	
</UserControl>
