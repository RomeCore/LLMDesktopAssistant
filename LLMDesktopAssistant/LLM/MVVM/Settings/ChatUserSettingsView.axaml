<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
			 xmlns:local="using:LLMDesktopAssistant.LLM.Settings"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.LLM.Settings.ChatUserSettingsView"
			 x:DataType="local:ChatUserSettingsViewModel">

	<Grid ColumnDefinitions="240,4,*">

		<!-- User list  -->
		<DockPanel Margin="4">
			<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="4,8">
				<Button Command="{Binding AddCommand}"
								Content="{loc:Loc add}"
								MinWidth="60"/>
				<Button Command="{Binding DeleteCommand}"
								Content="{loc:Loc remove}"
								MinWidth="60"/>
			</StackPanel>

			<ListBox ItemsSource="{Binding Users}"
							 SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
							 BorderThickness="0"
							 Margin="0,0,0,4">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal" Spacing="8" Margin="4,4">
							<StackPanel VerticalAlignment="Center">
								<TextBlock Text="{Binding Name}"
												   FontWeight="Bold"/>
								<TextBlock Text="{Binding Login}"
													 Opacity="0.6"
													 FontSize="11"/>
							</StackPanel>
						</StackPanel>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</DockPanel>

		<GridSplitter Grid.Column="1"
									Width="4"
									ResizeDirection="Columns"
									HorizontalAlignment="Stretch"/>

		<!-- User editor -->
		<ScrollViewer Grid.Column="2"
									VerticalScrollBarVisibility="Auto"
									IsVisible="{Binding SelectedUser, Converter={StaticResource NotnullToBooleanConverter}}">
			<StackPanel Margin="10" Spacing="12">

				<!-- Login -->
				<TextBlock Text="{loc:Loc user_login}"
									 FontWeight="Bold"
									 FontSize="{DynamicResource FontSizeL}"
									 Margin="0,5,0,0"/>

				<TextBlock Text="{loc:Loc user_login_hint}"
									 Opacity="0.6"
									 TextWrapping="Wrap"/>

				<TextBox Text="{Binding SelectedUser.Login, Mode=TwoWay}"
								 TextWrapping="NoWrap"
								 PlaceholderText="user"/>

				<!-- Separator -->
				<Rectangle Height="1"
									 Fill="{DynamicResource DefaultForeground}"
									 Opacity="0.2"
									 Margin="0,5"/>

				<!-- Name -->
				<TextBlock Text="{loc:Loc user_name}"
									 FontWeight="Bold"
									 FontSize="{DynamicResource FontSizeL}"
									 Margin="0,5,0,0"/>

				<TextBlock Text="{loc:Loc user_name_hint}"
									 Opacity="0.6"
									 TextWrapping="Wrap"/>

				<TextBox Text="{Binding SelectedUser.Name, Mode=TwoWay}"
								 TextWrapping="NoWrap"
								 PlaceholderText="User"/>

				<!-- Separator -->
				<Rectangle Height="1"
									 Fill="{DynamicResource DefaultForeground}"
									 Opacity="0.2"
									 Margin="0,5"/>

				<!-- Description -->
				<TextBlock Text="{loc:Loc user_description}"
									 FontWeight="Bold"
									 FontSize="{DynamicResource FontSizeL}"
									 Margin="0,5,0,0"/>

				<TextBlock Text="{loc:Loc user_description_hint}"
									 Opacity="0.6"
									 TextWrapping="Wrap"/>

				<TextBox Text="{Binding SelectedUser.Description, Mode=TwoWay}"
								 TextWrapping="Wrap"
								 MinHeight="60"
								 AcceptsReturn="True"/>

				<!-- Separator -->
				<Rectangle Height="1"
									 Fill="{DynamicResource DefaultForeground}"
									 Opacity="0.2"
									 Margin="0,5"/>

				<!-- Profile Image -->
				<TextBlock Text="{loc:Loc user_profile_image}"
									 FontWeight="Bold"
									 FontSize="{DynamicResource FontSizeL}"
									 Margin="0,5,0,0"/>

				<TextBlock Text="{loc:Loc user_profile_image_hint}"
									 Opacity="0.6"
									 TextWrapping="Wrap"/>

				<!-- Image preview -->
				<Border BorderBrush="{DynamicResource DefaultForeground}"
								BorderThickness="1"
								CornerRadius="8"
								Padding="4"
								Width="136"
								Height="136"
								HorizontalAlignment="Left">
					<Image Source="{Binding ProfileImage}"
								 Width="128"
								 Height="128"
								 Stretch="Uniform"
								 VerticalAlignment="Center"
								 HorizontalAlignment="Center"/>
				</Border>

				<StackPanel Orientation="Horizontal" Spacing="8">
					<Button Command="{Binding SelectImageCommand}"
									Content="{loc:Loc user_select_image}"/>

					<Button Command="{Binding ClearImageCommand}"
									Content="{loc:Loc user_clear_image}"/>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>

		<!-- Empty state when no user selected -->
		<TextBlock Grid.Column="2"
							 Text="{loc:Loc user_select_prompt}"
							 HorizontalAlignment="Center"
							 VerticalAlignment="Center"
							 Opacity="0.5"
							 IsVisible="{Binding SelectedUser, Converter={StaticResource NotnullToBooleanConverterInverted}}"/>

	</Grid>

</UserControl>
