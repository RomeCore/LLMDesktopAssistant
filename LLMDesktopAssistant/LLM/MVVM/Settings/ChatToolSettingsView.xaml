<UserControl x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.ChatToolSettingsView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM.Settings"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">
	
	<materialDesign:TreeListView ItemsSource="{Binding ToolCategories}"
								 Margin="5">

		<materialDesign:TreeListView.Resources>

			<HierarchicalDataTemplate DataType="{x:Type local:ToolCategoryViewModel}"
									  ItemsSource="{Binding Tools}">
				<TextBlock Text="{loc:Loc {Binding Name}}"
						   FontWeight="Bold"
						   FontSize="16"
						   VerticalAlignment="Center"/>
			</HierarchicalDataTemplate>

			<DataTemplate DataType="{x:Type local:ToolItemViewModel}">
				<TextBlock Text="{loc:Loc {Binding Name}}"
						   TextTrimming="CharacterEllipsis"
						   FontWeight="Bold"
						   FontSize="16"
						   VerticalAlignment="Center"/>
			</DataTemplate>

		</materialDesign:TreeListView.Resources>

		<materialDesign:TreeViewAssist.AdditionalTemplateSelector>
			<local:ToolAdditionalTemplateSelector>

				<local:ToolAdditionalTemplateSelector.ToolTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding Description}"
								   Margin="70,5,5,15"
								   HorizontalAlignment="Left"
								   MaxWidth="500" MaxHeight="120"
								   TextWrapping="Wrap"
								   TextTrimming="WordEllipsis"
								   FontSize="12"
								   OpacityMask="{Binding DescriptionOpacityMask}"/>
					</DataTemplate>
				</local:ToolAdditionalTemplateSelector.ToolTemplate>

			</local:ToolAdditionalTemplateSelector>
		</materialDesign:TreeViewAssist.AdditionalTemplateSelector>

		<materialDesign:TreeListView.View>
			<GridView>

				<GridViewColumn Width="250" Header="{loc:Loc name}">
					<GridViewColumn.CellTemplate>
						<DataTemplate>
							<StackPanel Orientation="Horizontal">

								<TextBlock Text="{loc:Loc {Binding Name}}"
										   ToolTip="{loc:Loc {Binding Name}}"
										   FontWeight="Bold"
										   TextTrimming="CharacterEllipsis"
										   VerticalAlignment="Center"/>

								<TextBlock Text="{Binding NameSuffix}"
										   Margin="5,0,0,0"
										   Opacity="0.6"
										   TextTrimming="CharacterEllipsis"
										   VerticalAlignment="Center"
										   Visibility="{Binding NameSuffix, Converter={StaticResource StringNonEmptyToVisiblityConverter}}"/>

							</StackPanel>


						</DataTemplate>
					</GridViewColumn.CellTemplate>
				</GridViewColumn>

				<GridViewColumn Width="120" Header="{loc:Loc enable}">
					<GridViewColumn.CellTemplate>
						<DataTemplate>
							<CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"
									  VerticalAlignment="Center"
									  HorizontalAlignment="Center"/>
						</DataTemplate>
					</GridViewColumn.CellTemplate>
				</GridViewColumn>

				<GridViewColumn Width="120" Header="{loc:Loc ask_for_confirmation}">
					<GridViewColumn.CellTemplate>
						<DataTemplate>
							<CheckBox IsChecked="{Binding AskForConfirmation, Mode=TwoWay}"
									  VerticalAlignment="Center"
									  HorizontalAlignment="Center"/>
						</DataTemplate>
					</GridViewColumn.CellTemplate>
				</GridViewColumn>

				<GridViewColumn Width="120" Header="{loc:Loc reset}">
					<GridViewColumn.CellTemplate>
						<DataTemplate>
							<Button Grid.Column="2"
									Command="{Binding ResetCommand}"
									Style="{StaticResource MaterialDesignIconButton}"
									Width="28" Height="28">

								<materialDesign:PackIcon Kind="LockReset"
														 Width="20" Height="20"/>

							</Button>
						</DataTemplate>
					</GridViewColumn.CellTemplate>
				</GridViewColumn>

			</GridView>
			
		</materialDesign:TreeListView.View>

	</materialDesign:TreeListView>
	
</UserControl>
