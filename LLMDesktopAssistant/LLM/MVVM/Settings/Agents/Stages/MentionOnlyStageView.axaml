<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Settings.Agents.Stages"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.Agents.Stages.MentionOnlyStageView"
			 x:DataType="local:MentionOnlyStageViewModel">

	<StackPanel>

		<!-- Global repeatable stage settings -->
		<Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto"
				  Margin="0,0,0,8">
			
			<TextBlock Grid.Row="0" Grid.Column="0"
					   Text="{loc:Loc settings_stage_enable_mentions}"
					   VerticalAlignment="Center" Margin="0,0,8,0"/>
			<CheckBox Grid.Row="0" Grid.Column="1"
					  IsChecked="{Binding MentionStage.EnableMentions}"
					  VerticalAlignment="Center"/>

			<TextBlock Grid.Row="1" Grid.Column="0"
					   Text="{loc:Loc settings_stage_can_agents_execute_again}"
					   VerticalAlignment="Center" Margin="0,0,8,4"/>
			<CheckBox Grid.Row="1" Grid.Column="1"
					  IsChecked="{Binding MentionStage.CanAgentsExecuteAgain}"
					  VerticalAlignment="Center" Margin="0,0,0,4"/>

			<TextBlock Grid.Row="2" Grid.Column="0"
					   Text="{loc:Loc settings_stage_min_iterations}"
					   VerticalAlignment="Center" Margin="0,0,8,4"/>
			<NumericUpDown Grid.Row="2" Grid.Column="1"
						   Value="{Binding MentionStage.MinIterations}"
						   Minimum="-1"
						   Margin="0,0,0,4"/>

			<TextBlock Grid.Row="3" Grid.Column="0"
					   Text="{loc:Loc settings_stage_max_iterations}"
					   VerticalAlignment="Center" Margin="0,0,8,4"/>
			<NumericUpDown Grid.Row="3" Grid.Column="1"
						   Value="{Binding MentionStage.MaxIterations}"
						   Minimum="-1"
						   Margin="0,0,0,4"/>
		</Grid>

		<!-- Divider -->
		<Border BorderBrush="{DynamicResource SystemAccentColor}"
				BorderThickness="0,0,0,1"
				Opacity="0.3"
				Margin="0,0,0,6"/>

		<TextBlock Text="{loc:Loc settings_stage_mentionable_agents}"
				   FontWeight="Bold"
				   Margin="0,0,0,4"/>

		<!-- Agent list (no weights, no ordering) -->
		<ItemsControl ItemsSource="{Binding Agents}">
			<ItemsControl.ItemTemplate>
				<DataTemplate DataType="local:MentionStageAgentViewModel">
					<Border Padding="4,2" Margin="0,1"
							BorderBrush="{DynamicResource SystemAccentColor}"
							BorderThickness="0,0,0,0.5">

						<Grid ColumnDefinitions="Auto,*,Auto">

							<!-- Enabled checkbox -->
							<CheckBox Grid.Column="0"
									  IsChecked="{Binding Instance.Enabled}"
									  VerticalAlignment="Center"/>

							<!-- Agent name -->
							<TextBlock Grid.Column="1"
									   Text="{Binding Agent.Info.Name}"
									   VerticalAlignment="Center"
									   Margin="4,0"/>

							<!-- Remove -->
							<Button Grid.Column="2"
									Command="{Binding RemoveCommand}"
									Classes="IconButton"
									Margin="2,0"
									ToolTip.Tip="{loc:Loc settings_stage_remove_agent}">
								<ico:MaterialIcon Kind="Close"/>
							</Button>

						</Grid>

					</Border>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<!-- Add agent button -->
		<Button Command="{Binding AddAgentCommand}"
				Margin="0,4"
				HorizontalAlignment="Left"
				ToolTip.Tip="{loc:Loc settings_stage_add_agent}">
			<StackPanel Orientation="Horizontal" Spacing="4">
				<ico:MaterialIcon Kind="Plus"/>
				<TextBlock Text="{loc:Loc settings_stage_add_agent}"/>
			</StackPanel>
		</Button>
	</StackPanel>

</UserControl>
