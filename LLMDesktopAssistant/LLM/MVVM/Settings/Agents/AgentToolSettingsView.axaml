<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Settings.Agents"
			 xmlns:sett="using:LLMDesktopAssistant.LLM.MVVM.Settings"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:flui="using:FluentAvalonia.UI"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.Agents.AgentToolSettingsView"
			 x:DataType="local:AgentToolSettingsViewModel">

	<StackPanel Margin="10">

		<!-- Enable tools checkbox -->
		<CheckBox IsChecked="{Binding ToolSettings.EnableTools}"
							Content="{loc:Loc settings-use_tools}"/>

		<!-- Policy override checkbox (agent-only) -->
		<CheckBox IsChecked="{Binding EnablePolicyOverride}"
							Content="{loc:Loc enable_policy_override}"
							Margin="0,4,0,4"
							IsEnabled="{Binding ToolSettings.EnableTools}"/>

		<!-- Auto-Approve Behaviours section -->
		<Expander Header="{loc:Loc tools_auto_approve_behaviours}"
							IsExpanded="True"
							IsVisible="{Binding EnablePolicyOverride}"
							Margin="0,4,0,4">
			<ItemsControl ItemsSource="{Binding AutoApproveBehaviourItems}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel MaxWidth="600"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="sett:ToolBehaviourItem">
						<CheckBox IsChecked="{Binding IsEnabled}"
											Content="{Binding DisplayName}"
											ToolTip.Tip="{Binding Description}"
											Margin="4,2"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</Expander>

		<!-- Disallowed Behaviours section -->
		<Expander Header="{loc:Loc tools_disallowed_behaviours}"
							IsExpanded="False"
							IsVisible="{Binding EnablePolicyOverride}"
							Margin="0,4,0,4">
			<ItemsControl ItemsSource="{Binding DisallowedBehaviourItems}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel MaxWidth="600"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="sett:ToolBehaviourItem">
						<CheckBox IsChecked="{Binding IsEnabled}"
											Content="{Binding DisplayName}"
											ToolTip.Tip="{Binding Description}"
											Margin="4,2"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</Expander>

		<!-- Column headers for tool list -->
		<Grid Grid.IsSharedSizeScope="True">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="50"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="150"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="50"/>
			</Grid.ColumnDefinitions>

			<TextBlock Grid.Column="0"
								 Text="{loc:Loc name}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

			<GridSplitter Grid.Column="1"
									  ResizeDirection="Columns"/>

			<TextBlock Grid.Column="2"
								 Text="{loc:Loc enable}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

			<GridSplitter Grid.Column="3"
									  ResizeDirection="Columns"/>

			<TextBlock Grid.Column="4"
								 Text="{loc:Loc approval_level}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

			<GridSplitter Grid.Column="5"
									  ResizeDirection="Columns"/>

			<TextBlock Grid.Column="6"
								 Text="{loc:Loc reset}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

		</Grid>

		<!-- Tool list by categories -->
		<TreeView ItemsSource="{Binding ToolCategories}"
							IsEnabled="{Binding ToolSettings.EnableTools}"
							ScrollViewer.HorizontalScrollBarVisibility="Disabled"
							ScrollViewer.VerticalScrollBarVisibility="Auto">

			<TreeView.DataTemplates>

				<TreeDataTemplate DataType="local:ToolCategoryViewModel"
												  ItemsSource="{Binding Tools}">

					<Grid Margin="0,4">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="2"/>
							<ColumnDefinition Width="50"/>
							<ColumnDefinition Width="2"/>
							<ColumnDefinition Width="150"/>
							<ColumnDefinition Width="2"/>
							<ColumnDefinition Width="50"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0"
												Orientation="Horizontal"
												VerticalAlignment="Center"
												Spacing="4"
												ClipToBounds="True">

							<TextBlock Text="{Binding TitlePrefix}"
												 Foreground="{Binding TitlePrefixForeground}"
												 IsVisible="{Binding TitlePrefix, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
												 Opacity="0.7"/>

							<TextBlock Text="{loc:Loc {Binding Title}}"
											   FontWeight="Bold"/>

							<TextBlock Text="{Binding TitleSuffix}"
												 IsVisible="{Binding TitleSuffix, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
												 Opacity="0.7"/>

						</StackPanel>

						<!-- Enabled -->
						<CheckBox Grid.Column="2"
											IsChecked="{Binding Enabled, Mode=TwoWay}"
											HorizontalAlignment="Center"/>

						<!-- Approval Level -->
						<ComboBox Grid.Column="4"
											SelectedItem="{Binding ApprovalLevel, Mode=TwoWay}"
											ItemsSource="{Binding ApprovalLevelList}"
											HorizontalAlignment="Stretch"
											Margin="2,0">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding DisplayName}"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

						<!-- Reset -->
						<Button Grid.Column="6"
								Command="{Binding ResetCommand}"
								HorizontalAlignment="Center"
								Classes="IconButton">

							<ico:MaterialIcon Kind="Refresh"/>
						</Button>

					</Grid>

				</TreeDataTemplate>

				<DataTemplate DataType="local:ToolItemViewModel">

					<StackPanel>

						<Grid Margin="0,2">

							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="2"/>
								<ColumnDefinition Width="50"/>
								<ColumnDefinition Width="2"/>
								<ColumnDefinition Width="150"/>
								<ColumnDefinition Width="2"/>
								<ColumnDefinition Width="50"/>
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Column="0"
													Orientation="Horizontal"
													VerticalAlignment="Center"
													Spacing="4"
													ClipToBounds="True">

								<TextBlock Text="{Binding TitlePrefix}"
													 Foreground="{Binding TitlePrefixForeground}"
													 IsVisible="{Binding TitlePrefix, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
													 Opacity="0.7"/>

								<TextBlock Text="{loc:Loc {Binding Title}}"
												   FontWeight="Bold"/>

								<TextBlock Text="{Binding TitleSuffix}"
													 IsVisible="{Binding TitleSuffix, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
													 Opacity="0.7"/>

							</StackPanel>

							<CheckBox Grid.Column="2"
												IsChecked="{Binding Enabled, Mode=TwoWay}"
												HorizontalAlignment="Center"/>

						<ComboBox Grid.Column="4"
											SelectedItem="{Binding ApprovalLevel, Mode=TwoWay}"
											ItemsSource="{Binding ApprovalLevelList}"
											HorizontalAlignment="Stretch"
											Margin="2,0">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding DisplayName}"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

							<Button Grid.Column="6"
											Command="{Binding ResetCommand}"
											HorizontalAlignment="Center"
											Classes="IconButton">
								<ico:MaterialIcon Kind="Refresh"/>
							</Button>

						</Grid>

						<TextBlock Text="{Binding Description}"
								   Margin="0,2,0,8"
								   HorizontalAlignment="Left"
								   MaxWidth="500"
								   TextWrapping="Wrap"
								   Opacity="0.7"
								   FontSize="12"
								   IsVisible="{Binding Description}"/>

					</StackPanel>

				</DataTemplate>

			</TreeView.DataTemplates>

		</TreeView>

	</StackPanel>

</UserControl>
