<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Settings.Agents"
			 xmlns:sett="using:LLMDesktopAssistant.LLM.MVVM.Settings"
			 xmlns:llmsg="using:LLMDesktopAssistant.LLM.Messages"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:flui="using:FluentAvalonia.UI"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.Agents.AgentToolSettingsView"
			 x:DataType="local:AgentToolSettingsViewModel">

	<StackPanel Margin="8" Spacing="8">

		<!-- Enable tools checkbox -->
		<CheckBox IsChecked="{Binding ToolSettings.EnableTools}"
							Content="{loc:Loc settings-use_tools}"/>
		
		<TextBlock Text="{loc:Loc tool_behaviour_policy}"
							 FontSize="{DynamicResource FontSizeL}"
							 FontWeight="Bold"/>

		<!-- Policy override checkbox (agent-only) -->
		<CheckBox IsChecked="{Binding EnablePolicyOverride}"
							Content="{loc:Loc enable_policy_override}"
							IsEnabled="{Binding ToolSettings.EnableTools}"/>

		<!-- ============================================================ -->
		<!-- BEHAVIOUR POLICY -->
		<!-- ============================================================ -->
		<StackPanel IsVisible="{Binding EnablePolicyOverride}" Spacing="16">

			<!-- Column headers -->
			<Grid ColumnDefinitions="*,Auto">

				<TextBlock Grid.Column="0"
						   Text="{loc:Loc name}"
						   FontWeight="Bold"
						   Margin="5,0,0,0"/>

				<TextBlock Grid.Column="1"
						   Text="{loc:Loc policy}"
						   FontWeight="Bold"
						   Margin="8,0,8,0"/>
			</Grid>

			<ItemsControl ItemsSource="{Binding PolicyBehaviourItems}">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="sett:ToolBehaviourPolicyItem">
						<Border BorderBrush="{DynamicResource SecondaryAccentBrush}"
										BorderThickness="1"
										CornerRadius="4"
										Padding="8"
										Margin="0,0,0,8">
							<Grid RowDefinitions="Auto,Auto" VerticalAlignment="Center">

								<!-- Row 0: Icon + Name + ComboBox -->
								<Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

									<ico:MaterialIcon Grid.Column="0"
													  Kind="{Binding Icon}"
													  Foreground="{Binding Color}"
													  Width="20" Height="20"
													  VerticalAlignment="Center"
													  Margin="0,0,8,0"/>

									<TextBlock Grid.Column="1"
											   Text="{Binding DisplayName}"
											   FontWeight="Medium"
											   TextTrimming="CharacterEllipsis"
											   VerticalAlignment="Center"/>

									<ComboBox Grid.Column="2"
											  ItemsSource="{Binding PolicyModes}"
											  SelectedItem="{Binding PolicyMode, Mode=TwoWay}"
											  MinWidth="140"
											  Margin="8,0,0,0">
										<ComboBox.ItemTemplate>
											<DataTemplate x:DataType="sett:PolicyModeItem">
												<TextBlock Text="{Binding DisplayName}"/>
											</DataTemplate>
										</ComboBox.ItemTemplate>
									</ComboBox>
								</Grid>

								<!-- Row 1: Description -->
								<TextBlock Grid.Row="1"
										   Text="{Binding Description}"
										   Opacity="0.6"
										   FontSize="12"
										   TextWrapping="Wrap"
										   Margin="28,4,0,0"
										   IsVisible="{Binding Description, Converter={StaticResource StringNonEmptyToBooleanConverter}}"/>

							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

		</StackPanel>
		
		<TextBlock Text="{loc:Loc tool_settings}"
							 FontSize="{DynamicResource FontSizeL}"
							 FontWeight="Bold"/>

		<!-- Column headers for tool list -->
		<Grid Grid.IsSharedSizeScope="True">

			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="50"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="150"/>
				<ColumnDefinition Width="2"/>
				<ColumnDefinition Width="50"/>
			</Grid.ColumnDefinitions>

			<TextBlock Grid.Column="0"
								 Text="{loc:Loc name}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

			<GridSplitter Grid.Column="1"
									  ResizeDirection="Columns"/>

			<TextBlock Grid.Column="2"
								 Text="{loc:Loc enable}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

			<GridSplitter Grid.Column="3"
									  ResizeDirection="Columns"/>

			<TextBlock Grid.Column="4"
								 Text="{loc:Loc approval_level}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

			<GridSplitter Grid.Column="5"
									  ResizeDirection="Columns"/>

			<TextBlock Grid.Column="6"
								 Text="{loc:Loc reset}"
								 Margin="5"
								 HorizontalAlignment="Left" VerticalAlignment="Center"
								 TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
								 FontWeight="Bold"/>

		</Grid>

		<!-- Tool list by categories -->
		<TreeView ItemsSource="{Binding ToolCategories}"
							IsEnabled="{Binding ToolSettings.EnableTools}"
							ScrollViewer.HorizontalScrollBarVisibility="Disabled"
							ScrollViewer.VerticalScrollBarVisibility="Auto">

			<TreeView.DataTemplates>

				<TreeDataTemplate DataType="local:ToolCategoryViewModel"
												  ItemsSource="{Binding Tools}">

					<Grid Margin="0,4">

						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="2"/>
							<ColumnDefinition Width="50"/>
							<ColumnDefinition Width="2"/>
							<ColumnDefinition Width="150"/>
							<ColumnDefinition Width="2"/>
							<ColumnDefinition Width="50"/>
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0"
												Orientation="Horizontal"
												VerticalAlignment="Center"
												Spacing="4"
												ClipToBounds="True">

							<TextBlock Text="{Binding TitlePrefix}"
												 Foreground="{Binding TitlePrefixForeground}"
												 IsVisible="{Binding TitlePrefix, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
												 Opacity="0.7"/>

							<TextBlock Text="{loc:Loc {Binding Title}}"
											   FontWeight="Bold"/>

							<TextBlock Text="{Binding TitleSuffix}"
												 IsVisible="{Binding TitleSuffix, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
												 Opacity="0.7"/>

						</StackPanel>

						<!-- Enabled -->
						<CheckBox Grid.Column="2"
											IsChecked="{Binding Enabled, Mode=TwoWay}"
											HorizontalAlignment="Center"/>

						<!-- Approval Level -->
						<ComboBox Grid.Column="4"
											SelectedItem="{Binding ApprovalLevel, Mode=TwoWay}"
											ItemsSource="{Binding ApprovalLevelList}"
											HorizontalAlignment="Stretch"
											Margin="2,0">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding DisplayName}"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

						<!-- Reset -->
						<Button Grid.Column="6"
								Command="{Binding ResetCommand}"
								HorizontalAlignment="Center"
								Classes="IconButton">

							<ico:MaterialIcon Kind="Refresh"/>
						</Button>

					</Grid>

				</TreeDataTemplate>

				<DataTemplate DataType="local:ToolItemViewModel">

					<StackPanel>

						<Grid Margin="0,2">

							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="2"/>
								<ColumnDefinition Width="50"/>
								<ColumnDefinition Width="2"/>
								<ColumnDefinition Width="150"/>
								<ColumnDefinition Width="2"/>
								<ColumnDefinition Width="50"/>
							</Grid.ColumnDefinitions>

							<StackPanel Grid.Column="0"
													Orientation="Horizontal"
													VerticalAlignment="Center"
													Spacing="4"
													ClipToBounds="True">

								<TextBlock Text="{Binding TitlePrefix}"
													 Foreground="{Binding TitlePrefixForeground}"
													 IsVisible="{Binding TitlePrefix, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
													 Opacity="0.7"/>

								<TextBlock Text="{loc:Loc {Binding Title}}"
												   FontWeight="Bold"
													 TextTrimming="CharacterEllipsis"
													 ToolTip.Tip="{loc:Loc {Binding Title}}"/>

							</StackPanel>

							<CheckBox Grid.Column="2"
												IsChecked="{Binding Enabled, Mode=TwoWay}"
												HorizontalAlignment="Center"/>

						<ComboBox Grid.Column="4"
											SelectedItem="{Binding ApprovalLevel, Mode=TwoWay}"
											ItemsSource="{Binding ApprovalLevelList}"
											HorizontalAlignment="Stretch"
											Margin="2,0">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding DisplayName}"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>

							<Button Grid.Column="6"
											Command="{Binding ResetCommand}"
											HorizontalAlignment="Center"
											Classes="IconButton">
								<ico:MaterialIcon Kind="Refresh"/>
							</Button>

						</Grid>
						
						<StackPanel Orientation="Horizontal"
												Spacing="4">
							
							<TextBlock Text="{Binding Name}"
												 FontSize="11"
												 Opacity="0.4"
												 VerticalAlignment="Center"/>
							
							<ItemsControl ItemsSource="{Binding BehaviourFlags}"
														VerticalAlignment="Center">

								<ItemsControl.ItemsPanel>
									<ItemsPanelTemplate>
										<StackPanel Spacing="2" Orientation="Horizontal"/>
									</ItemsPanelTemplate>
								</ItemsControl.ItemsPanel>

								<ItemsControl.ItemTemplate>
									<DataTemplate>
										<Panel ToolTip.Tip="{Binding DisplayName}">
											<ico:MaterialIcon Kind="{Binding Icon}"
																				Foreground="{Binding Color}"
																				Background="Transparent"
																				Width="16" Height="16"/>
										</Panel>
									</DataTemplate>
								</ItemsControl.ItemTemplate>

							</ItemsControl>

						</StackPanel>

						<TextBlock Text="{Binding Description}"
								   Margin="0,2,0,8"
								   HorizontalAlignment="Left"
								   MaxWidth="500"
								   TextWrapping="Wrap"
								   Opacity="0.7"
								   FontSize="12"
								   IsVisible="{Binding Description}"/>

					</StackPanel>

				</DataTemplate>

			</TreeView.DataTemplates>

		</TreeView>

	</StackPanel>

</UserControl>
