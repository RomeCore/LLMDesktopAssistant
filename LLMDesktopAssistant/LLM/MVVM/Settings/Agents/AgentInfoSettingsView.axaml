<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Settings.Agents"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.Agents.AgentInfoSettingsView"
			 x:DataType="local:AgentInfoSettingsViewModel">

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Margin="10" Spacing="12">

			<!-- ===================== Name ===================== -->
			<TextBlock Text="{loc:Loc name}"
					   FontWeight="Bold"
					   FontSize="{DynamicResource FontSizeL}"
					   Margin="0,5,0,0"/>

			<TextBlock Text="{loc:Loc agent_info_name_hint}"
					   Opacity="0.6"
					   TextWrapping="Wrap"/>

			<TextBox Text="{Binding AgentInfo.Name, Mode=TwoWay}"
					 TextWrapping="NoWrap"
					 PlaceholderText="{loc:Loc agent_info_name_placeholder}"/>


			<!-- Separator -->
			<Rectangle Height="1"
					   Fill="{DynamicResource DefaultForeground}"
					   Opacity="0.2"
					   Margin="0,5"/>

			<!-- ===================== Description ===================== -->
			<TextBlock Text="{loc:Loc agent_info_description}"
					   FontWeight="Bold"
					   FontSize="{DynamicResource FontSizeL}"
					   Margin="0,5,0,0"/>

			<TextBlock Text="{loc:Loc agent_info_description_hint}"
					   Opacity="0.6"
					   TextWrapping="Wrap"/>

			<TextBox Text="{Binding AgentInfo.Description, Mode=TwoWay}"
					 TextWrapping="Wrap"
					 MinHeight="60"
					 AcceptsReturn="True"
					 PlaceholderText="{loc:Loc agent_info_description_placeholder}"/>

			<!-- Separator -->
			<Rectangle Height="1"
					   Fill="{DynamicResource DefaultForeground}"
					   Opacity="0.2"
					   Margin="0,5"/>

			<!-- ===================== Profile Image ===================== -->
			<TextBlock Text="{loc:Loc agent_info_profile_image}"
					   FontWeight="Bold"
					   FontSize="{DynamicResource FontSizeL}"
					   Margin="0,5,0,0"/>

			<TextBlock Text="{loc:Loc agent_info_profile_image_hint}"
					   Opacity="0.6"
					   TextWrapping="Wrap"/>

			<!-- Image preview -->
			<Border BorderBrush="{DynamicResource DefaultForeground}"
					BorderThickness="1"
					CornerRadius="8"
					Padding="4"
					Width="136"
					Height="136"
					HorizontalAlignment="Left">
				<Image Source="{Binding ProfileImage}"
					   Width="128"
					   Height="128"
					   Stretch="Uniform"
					   VerticalAlignment="Center"
					   HorizontalAlignment="Center"/>
			</Border>

			<StackPanel Orientation="Horizontal" Spacing="8">
				<Button Command="{Binding SelectImageCommand}"
						Content="{loc:Loc agent_info_select_image}"/>

				<Button Command="{Binding ClearImageCommand}"
						Content="{loc:Loc agent_info_clear_image}"/>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>

</UserControl>
