<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Settings.Agents"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.Agents.AgentExecutionConditionsSettingsView"
			 x:DataType="local:AgentExecutionConditionsSettingsViewModel">

	<StackPanel Orientation="Vertical"
				Margin="10"
				Spacing="10">

		<!-- Can be mentioned -->
		<CheckBox IsChecked="{Binding ExecutionConditionsSettings.CanBeMentioned, Mode=TwoWay}"
					Content="{loc:Loc settings_can_be_mentioned}"/>

		<TextBlock Text="{loc:Loc settings_can_be_mentioned_hint}"
					  Opacity="0.6"
					  TextWrapping="Wrap"/>

		<!-- Separator -->
		<Rectangle Height="1"
					  Fill="{DynamicResource DefaultForeground}"
					  Opacity="0.2"
					  Margin="0,10"/>

		<!-- Can mention others -->
		<CheckBox IsChecked="{Binding ExecutionConditionsSettings.CanMentionOthers, Mode=TwoWay}"
					Content="{loc:Loc settings_can_mention_others}"/>

		<TextBlock Text="{loc:Loc settings_can_mention_others_hint}"
					  Opacity="0.6"
					  TextWrapping="Wrap"/>

	</StackPanel>

</UserControl>
