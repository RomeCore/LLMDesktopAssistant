<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Settings"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.ChatAgentsSettingsView"
			 x:Name="AgentsView"
			 x:DataType="local:ChatAgentsSettingsViewModel">

	<DockPanel>
		<!-- Toolbar -->
		<Border DockPanel.Dock="Top"
				BorderBrush="{DynamicResource SystemAccentColor}"
				BorderThickness="0,0,0,1"
				Padding="8,6">
			<StackPanel Orientation="Horizontal" Spacing="4">
				<Button Command="{Binding AddAgentCommand}" Classes="IconButton"
						ToolTip.Tip="{loc:Loc settings_add_agent}">
					<ico:MaterialIcon Kind="Plus"/>
				</Button>
				<Button Command="{Binding RemoveAgentCommand}" Classes="IconButton"
						ToolTip.Tip="{loc:Loc settings_remove_agent}">
					<ico:MaterialIcon Kind="Close"/>
				</Button>
			</StackPanel>
		</Border>

		<!-- Agent list -->
		<ListBox ItemsSource="{Binding AgentOptions}"
				 SelectedItem="{Binding SelectedAgent, Mode=TwoWay}"
				 Margin="8">
			<ListBox.ItemTemplate>
				<DataTemplate DataType="local:AgentOptionViewModel">
					<Border Padding="6,4" BorderBrush="{DynamicResource SystemAccentColor}" BorderThickness="0,0,0,0.5">
						<Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
							<!-- Active toggle -->
							<CheckBox Grid.Column="0"
									  IsChecked="{Binding IsActive}"
									  VerticalAlignment="Center"
										Command="{Binding #AgentsView.DataContext.ToggleAgentActiveCommand}"
										CommandParameter="{Binding}"
									  ToolTip.Tip="{loc:Loc settings_toggle_agent_active}"/>

							<!-- Order index badge -->
							<Border Grid.Column="1"
									IsVisible="{Binding IsActive}"
									Background="{DynamicResource SystemAccentColor}"
									CornerRadius="8"
									Width="20" Height="20"
									Margin="4,0"
									VerticalAlignment="Center">
								<TextBlock Text="{Binding OrderIndex}"
										   HorizontalAlignment="Center"
										   VerticalAlignment="Center"
										   FontSize="11"
										   Foreground="White"/>
							</Border>

							<!-- Name -->
							<TextBlock Grid.Column="2"
									   Text="{Binding Agent.Prompts.Nickname}"
									   VerticalAlignment="Center"
									   Margin="4,0"/>

							<!-- Global badge -->
							<Border Grid.Column="3"
									IsVisible="{Binding IsGlobal}"
									Background="{DynamicResource SystemAccentColor}"
									Opacity="0.4"
									CornerRadius="4"
									Padding="4,1"
									VerticalAlignment="Center">
								<TextBlock Text="{loc:Loc settings_agent_global}" FontSize="11"/>
							</Border>

							<!-- Move up -->
							<Button Grid.Column="4"
									Command="{Binding #AgentsView.DataContext.MoveAgentUpCommand}"
									CommandParameter="{Binding}"
									IsEnabled="{Binding IsActive}"
									Classes="IconButton"
									Margin="2,0"
									ToolTip.Tip="{loc:Loc settings_move_agent_up}">
								<ico:MaterialIcon Kind="ChevronUp"/>
							</Button>

							<!-- Move down -->
							<Button Grid.Column="5"
									Command="{Binding #AgentsView.DataContext.MoveAgentDownCommand}"
									CommandParameter="{Binding}"
									IsEnabled="{Binding IsActive}"
									Classes="IconButton"
									Margin="2,0"
									ToolTip.Tip="{loc:Loc settings_move_agent_down}">
								<ico:MaterialIcon Kind="ChevronDown"/>
							</Button>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</DockPanel>

</UserControl>
