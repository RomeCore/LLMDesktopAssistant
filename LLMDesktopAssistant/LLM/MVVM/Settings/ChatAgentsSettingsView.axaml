<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Settings"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Settings.ChatAgentsSettingsView"
			 x:Name="AgentsView"
			 x:DataType="local:ChatAgentsSettingsViewModel">

	<DockPanel>
		<!-- Toolbar -->
		<Border DockPanel.Dock="Top"
				BorderBrush="{DynamicResource SystemAccentColor}"
				BorderThickness="0,0,0,1"
				Padding="8,6">
			<StackPanel Orientation="Horizontal" Spacing="4">
				<Button Command="{Binding AddAgentCommand}" Classes="IconButton"
						ToolTip.Tip="{loc:Loc settings_add_agent}">
					<ico:MaterialIcon Kind="Plus"/>
				</Button>
				<Button Command="{Binding RemoveAgentCommand}" Classes="IconButton"
						ToolTip.Tip="{loc:Loc settings_remove_agent}">
					<ico:MaterialIcon Kind="Close"/>
				</Button>
			</StackPanel>
		</Border>

		<!-- Agent list -->
		<ListBox ItemsSource="{Binding AgentOptions}"
				 SelectedItem="{Binding SelectedAgent, Mode=TwoWay}"
				 Margin="8">
			<ListBox.ItemTemplate>
				<DataTemplate DataType="local:AgentOptionViewModel">
					<Border Padding="6,4" BorderBrush="{DynamicResource SystemAccentColor}" BorderThickness="0,0,0,0.5">
						<Grid ColumnDefinitions="*,Auto,Auto">

							<!-- Name + Global badge -->
							<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
								<TextBlock Text="{Binding Agent.Info.Name}" VerticalAlignment="Center"/>

								<Border IsVisible="{Binding IsGlobal}"
										Background="{DynamicResource SystemAccentColor}"
										Opacity="0.6"
										CornerRadius="4"
										Padding="4,3"
										VerticalAlignment="Center">
									<TextBlock Text="{loc:Loc settings_agent_global}" FontSize="14"/>
								</Border>
							</StackPanel>

							<!-- Promote to global -->
							<Button Grid.Column="1"
									Command="{Binding #AgentsView.DataContext.PromoteToGlobalCommand}"
									CommandParameter="{Binding}"
									IsVisible="{Binding IsGlobal, Converter={StaticResource InverseBooleanConverter}}"
									Classes="IconButton"
									Margin="2,0"
									ToolTip.Tip="{loc:Loc settings_promote_to_global}">
								<ico:MaterialIcon Kind="CloudUpload"/>
							</Button>

							<!-- Copy to local -->
							<Button Grid.Column="2"
									Command="{Binding #AgentsView.DataContext.CopyToLocalCommand}"
									CommandParameter="{Binding}"
									IsVisible="{Binding IsGlobal}"
									Classes="IconButton"
									Margin="2,0"
									ToolTip.Tip="{loc:Loc settings_copy_to_local}">
								<ico:MaterialIcon Kind="CloudDownload"/>
							</Button>

						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</DockPanel>

</UserControl>
