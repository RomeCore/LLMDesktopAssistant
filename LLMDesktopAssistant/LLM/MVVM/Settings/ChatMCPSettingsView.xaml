<UserControl x:Class="LLMDesktopAssistant.Core.LLM.MVVM.Settings.ChatMCPSettingsView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Core.LLM.MVVM.Settings"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Core.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Core.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">
	
	<ScrollViewer VerticalScrollBarVisibility="Auto">

		<StackPanel Margin="10">

			<CheckBox IsChecked="{Binding Settings.EnableMcp}"
					  Content="{loc:Loc settings-use_mcp}"/>

			<ItemsControl ItemsSource="{Binding McpServers}"
						  IsEnabled="{Binding Settings.EnableMcp}">

				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>

						<materialDesign:Card Margin="0,0,0,8"
											 Padding="10">

							<StackPanel>

								<CheckBox Content="{Binding Name}"
										  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
										  FontWeight="Bold"
										  FontSize="14"/>

								<TextBlock Text="{Binding Endpoint}"
										   FontSize="12"
										   Opacity="0.7"
										   TextTrimming="CharacterEllipsis"/>

								<TextBlock Text="{Binding ConnectionType}"
										   FontSize="11"
										   Opacity="0.5"/>

							</StackPanel>

						</materialDesign:Card>

					</DataTemplate>
				</ItemsControl.ItemTemplate>

			</ItemsControl>

		</StackPanel>

	</ScrollViewer>
	
</UserControl>
