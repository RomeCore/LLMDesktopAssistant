<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="750"
			 xmlns:local="using:LLMDesktopAssistant.LLM.Settings"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:flui="using:FluentAvalonia.UI"
			 x:Class="LLMDesktopAssistant.LLM.Settings.ChatSettingsView"
			 x:DataType="local:ChatSettingsViewModel">

	<DockPanel Width="650"
					Height="500">

		<!-- Agent selection bar at the top -->
		<Border DockPanel.Dock="Top"
				BorderBrush="{DynamicResource SystemAccentColor}"
				BorderThickness="0,0,0,1"
				Padding="10,8">

			<Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
				  VerticalAlignment="Center">

				<TextBlock Grid.Column="0"
						   Text="{loc:Loc settings_selected_agent}"
						   VerticalAlignment="Center"
						   Margin="0,0,8,0"/>

				<ComboBox Grid.Column="1"
						  ItemsSource="{Binding AgentOptions}"
						  SelectedItem="{Binding SelectedAgent, Mode=TwoWay}"
						  Width="200">
					<ComboBox.ItemTemplate>
						<DataTemplate DataType="local:AgentOptionViewModel">
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="{Binding DisplayName}"/>
								<TextBlock Text="{loc:Loc settings_agent_global}"
										   IsVisible="{Binding IsGlobal}"
										   Opacity="0.5"
										   FontSize="11"/>
							</StackPanel>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>

				<Button Grid.Column="2"
						Command="{Binding AddAgentCommand}"
						Margin="4,0,0,0"
						Classes="IconButton"
						ToolTip.Tip="{loc:Loc settings_add_agent}">
					<ico:MaterialIcon Kind="Plus"/>
				</Button>

				<Button Grid.Column="3"
						Command="{Binding RemoveAgentCommand}"
						Margin="4,0,0,0"
						Classes="IconButton"
						ToolTip.Tip="{loc:Loc settings_remove_agent}">
					<ico:MaterialIcon Kind="Close"/>
				</Button>

			</Grid>

		</Border>

		<!-- Main settings tabs -->
		<TabControl 
					TabStripPlacement="Left">

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Vertical"
								MaxWidth="80"
								Margin="5">
						<ico:MaterialIcon Kind="Brain"
										  Width="24" Height="24"
										  HorizontalAlignment="Center"/>
						<TextBlock Text="{loc:Loc chat_settings_models}"
								   FontSize="15"
								   HorizontalAlignment="Center"
								   TextTrimming="CharacterEllipsis"
								   TextWrapping="NoWrap"/>
					</StackPanel>
				</TabItem.Header>
				<ContentControl Content="{Binding ModelSettings}"/>
			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Vertical"
								MaxWidth="80"
								Margin="5">
						<ico:MaterialIcon Kind="Text"
										  Width="24" Height="24"
										  HorizontalAlignment="Center"/>
						<TextBlock Text="{loc:Loc chat_settings_prompts}"
								   FontSize="15"
								   HorizontalAlignment="Center"
								   TextTrimming="CharacterEllipsis"
								   TextWrapping="NoWrap"/>
					</StackPanel>
				</TabItem.Header>

				<!-- Agent-specific prompt settings -->
				<Panel>
					<ScrollViewer IsVisible="{Binding SelectedAgentDescriptor, Converter={StaticResource NotnullToBooleanConverter}}">
						<ContentControl Content="{Binding AgentPromptSettings}"/>
					</ScrollViewer>
					<TextBlock Text="{loc:Loc settings_select_agent_first}"
							   IsVisible="{Binding SelectedAgentDescriptor, Converter={StaticResource NotnullToBooleanConverterInverted}}"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"
							   Opacity="0.5"/>
				</Panel>

			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Vertical"
								MaxWidth="80"
								Margin="5">
						<ico:MaterialIcon Kind="Tune"
										  Width="24" Height="24"
										  HorizontalAlignment="Center"/>
						<TextBlock Text="{loc:Loc chat_settings_llm_properties}"
								   FontSize="15"
								   HorizontalAlignment="Center"
								   TextTrimming="CharacterEllipsis"
								   TextWrapping="NoWrap"/>
					</StackPanel>
				</TabItem.Header>

				<!-- Agent-specific LLM properties -->
				<Panel>
					<ScrollViewer IsVisible="{Binding SelectedAgentDescriptor, Converter={StaticResource NotnullToBooleanConverter}}">
						<ContentControl Content="{Binding AgentLLMPropertiesSettings}"/>
					</ScrollViewer>
					<TextBlock Text="{loc:Loc settings_select_agent_first}"
							   IsVisible="{Binding SelectedAgentDescriptor, Converter={StaticResource NotnullToBooleanConverterInverted}}"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"
							   Opacity="0.5"/>
				</Panel>

			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Vertical"
								MaxWidth="80"
								Margin="5">
						<ico:MaterialIcon Kind="ArrowCollapseVertical"
										  Width="24" Height="24"
										  HorizontalAlignment="Center"/>
						<TextBlock Text="{loc:Loc chat_settings_summarization}"
								   FontSize="15"
								   HorizontalAlignment="Center"
								   TextTrimming="CharacterEllipsis"
								   TextWrapping="NoWrap"/>
					</StackPanel>
				</TabItem.Header>
				<ContentControl Content="{Binding SummarizationSettings}"/>
			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Vertical"
								MaxWidth="80"
								Margin="5">
						<ico:MaterialIcon Kind="FolderSettings"
										  Width="24" Height="24"
										  HorizontalAlignment="Center"/>
						<TextBlock Text="{loc:Loc chat_settings_environment}"
								   FontSize="15"
								   HorizontalAlignment="Center"
								   TextTrimming="CharacterEllipsis"
								   TextWrapping="NoWrap"/>
					</StackPanel>
				</TabItem.Header>
				<ContentControl Content="{Binding EnvironmentSettings}"/>
			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Vertical"
								MaxWidth="80"
								Margin="5">
						<ico:MaterialIcon Kind="Wrench"
										  Width="24" Height="24"
										  HorizontalAlignment="Center"/>
						<TextBlock Text="{loc:Loc chat_settings_tools}"
								   FontSize="15"
								   HorizontalAlignment="Center"
								   TextTrimming="CharacterEllipsis"
								   TextWrapping="NoWrap"/>
					</StackPanel>
				</TabItem.Header>

				<!-- Agent-specific tool settings -->
				<Panel>
					<ScrollViewer IsVisible="{Binding SelectedAgentDescriptor, Converter={StaticResource NotnullToBooleanConverter}}">
						<ContentControl Content="{Binding AgentToolSettings}"/>
					</ScrollViewer>
					<TextBlock Text="{loc:Loc settings_select_agent_first}"
							   IsVisible="{Binding SelectedAgentDescriptor, Converter={StaticResource NotnullToBooleanConverterInverted}}"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"
							   Opacity="0.5"/>
				</Panel>

			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Vertical"
								MaxWidth="80"
								Margin="5">
						<ico:MaterialIcon Kind="Connection"
										  Width="24" Height="24"
										  HorizontalAlignment="Center"/>
						<TextBlock Text="{loc:Loc chat_settings_mcp}"
								   FontSize="15"
								   HorizontalAlignment="Center"
								   TextTrimming="CharacterEllipsis"
								   TextWrapping="NoWrap"/>
					</StackPanel>
				</TabItem.Header>
				<ContentControl Content="{Binding McpSettings}"/>
			</TabItem>

		</TabControl>

	</DockPanel>

</UserControl>
