<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Additional.Context"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Additional.Context.TokenCostView"
			 x:DataType="local:TokenCostViewModel">

	<WrapPanel LineSpacing="2" ItemSpacing="3" Margin="0,0,0,4">

		<!-- Model -->
		<TextBlock Text="{Binding ModelName}"
							 Opacity="0.4"
							 FontSize="11"
							 FontWeight="SemiBold"
							 VerticalAlignment="Center"/>

		<!-- Separator -->
		<TextBlock Text="·"
							 Opacity="0.3"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputCacheHitTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		
		<!-- Cache hit (only visible when cache data available) -->
		<TextBlock Text="{Binding CacheHitLabel}"
							 Opacity="0.4"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputCacheHitTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		<TextBlock Text="{Binding CacheHitFormatted}"
							 Opacity="0.4"
							 FontSize="11"
							 FontWeight="SemiBold"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputCacheHitTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		
		<!-- Separator -->
		<TextBlock Text="·"
							 Opacity="0.3"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputCacheMissTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		
		<!-- Cache miss (only visible when cache data available) -->
		<TextBlock Text="{Binding CacheMissLabel}"
							 Opacity="0.4"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputCacheMissTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		<TextBlock Text="{Binding CacheMissFormatted}"
							 Opacity="0.4"
							 FontSize="11"
							 FontWeight="SemiBold"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputCacheMissTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		
		<!-- Separator -->
		<TextBlock Text="·"
							 Opacity="0.3"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>

		<!-- Input tokens -->
		<TextBlock Text="{Binding InputTokensLabel}"
							 Opacity="0.4"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		<TextBlock Text="{Binding InputTokensFormatted}"
							 Opacity="0.4"
							 FontSize="11"
							 FontWeight="SemiBold"
							 VerticalAlignment="Center"
							 IsVisible="{Binding InputTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>

		<!-- Separator -->
		<TextBlock Text="·"
							 Opacity="0.3"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding OutputTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>

		<!-- Output tokens -->
		<TextBlock Text="{Binding OutputTokensLabel}"
							 Opacity="0.4"
							 FontSize="11"
							 VerticalAlignment="Center"
							 IsVisible="{Binding OutputTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>
		<TextBlock Text="{Binding OutputTokensFormatted}"
							 Opacity="0.4"
							 FontSize="11"
							 FontWeight="SemiBold"
							 VerticalAlignment="Center"
							 IsVisible="{Binding OutputTokens, Converter={StaticResource NotnullToBooleanConverter}}"/>

		<!-- Separator -->
		<TextBlock Text="·"
							 Opacity="0.3"
							 FontSize="11"
							 VerticalAlignment="Center"/>

		<!-- TTFT -->
		<TextBlock Text="{Binding TTFTLabel}"
							 Opacity="0.4"
							 FontSize="11"
							 VerticalAlignment="Center"/>
		<TextBlock Text="{Binding TTFTFormatted}"
							 Opacity="0.4"
							 FontSize="11"
							 FontWeight="SemiBold"
							 VerticalAlignment="Center"/>

		<!-- Separator -->
		<TextBlock Text="·"
							 Opacity="0.3"
							 FontSize="11"
							 VerticalAlignment="Center"/>

		<!-- Generation time -->
		<TextBlock Text="{Binding GenerationTimeLabel}"
							 Opacity="0.4"
							 FontSize="11"
							 VerticalAlignment="Center"/>
		<TextBlock Text="{Binding GenerationTimeFormatted}"
							 Opacity="0.4"
							 FontSize="11"
							 FontWeight="SemiBold"
							 VerticalAlignment="Center"/>

	</WrapPanel>

</UserControl>
