<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:LLMDesktopAssistant.LLM.MVVM.Additional.Context"
			 xmlns:ctrl="using:LLMDesktopAssistant.Controls"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.Additional.Context.SummaryView"
			 x:DataType="local:SummaryViewModel">
	
	<Expander Header="{loc:Loc message_summary}"
						Margin="20,0,20,8"
						IsExpanded="False">

		<Border Background="{DynamicResource ThemeAccentBrush4}"
						CornerRadius="4"
						Padding="8"
						Margin="0,4,0,0">

			<ctrl:MarkdownControl MarkdownText="{Binding Summary}"/>

		</Border>

	</Expander>

</UserControl>
