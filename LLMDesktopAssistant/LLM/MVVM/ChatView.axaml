<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM"
			 xmlns:beh="clr-namespace:LLMDesktopAssistant.Behaviours"
			 x:Class="LLMDesktopAssistant.LLM.MVVM.ChatView"
			 x:DataType="local:ChatViewModel">
	
	<Grid RowDefinitions="*,Auto" ColumnDefinitions="0.1*,2,*">

		<!-- Left Sidebar -->
		<TabControl Grid.Row="0" Grid.Column="0"
								ItemsSource="{Binding Chat.ContextTabs}">
			
			<TabControl.ItemTemplate>
				<DataTemplate>
					<TabItem Header="{Binding Title}"
									 IsVisible="{Binding IsVisible}"
									 Content="{Binding}"/>
				</DataTemplate>
			</TabControl.ItemTemplate>
			
		</TabControl>

		<!-- Splitter -->
		<GridSplitter Grid.Row="0" Grid.Column="1"
									ResizeDirection="Columns"/>

		<!-- Messages Area -->
		<ScrollViewer Grid.Row="0" Grid.Column="2"
									VerticalScrollBarVisibility="Visible"
									beh:ScrollViewerBehavior.AutoScrollEnabled="True">

			<StackPanel>
				<ContentControl Content="{Binding MessageSequence}"/>
				<ContentControl Content="{Binding ChatStatus}" />
			</StackPanel>
		</ScrollViewer>

		<!-- Input Area -->
		<Border Grid.Row="1" Grid.ColumnSpan="3"
						Padding="16,8"
						BorderBrush="{DynamicResource PrimaryAccentBrush}"
						BorderThickness="0,1,0,0">

			<ContentControl Content="{Binding UserInput}"/>
		</Border>
	</Grid>
	
</UserControl>
