<UserControl x:Class="LLMDesktopAssistant.LLM.MVVM.UserInputView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<materialDesign:Card Grid.Column="0"
				 Padding="8,4"
				 materialDesign:ShadowAssist.Darken="True">

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<!-- Attach Button -->
			<Button Grid.Column="0"
					Style="{StaticResource MaterialDesignIconButton}"
					ToolTip="{loc:Loc chat-attach_file_hint}">
				<materialDesign:PackIcon Kind="Paperclip"/>
			</Button>

			<!-- Text Input -->
			<TextBox Grid.Column="1"
					 materialDesign:HintAssist.Hint="{loc:Loc chat-input_hint}"
					 materialDesign:TextFieldAssist.HasClearButton="True"
					 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
					 Text="{Binding Text, Mode=TwoWay}"
					 Margin="8,0"
					 VerticalAlignment="Center"
					 TextWrapping="Wrap"
					 AcceptsReturn="True"
					 MaxHeight="120"
					 Foreground="{DynamicResource MaterialDesignBody}"
					 FontSize="16"
					 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

			<!-- Send Button -->
			<Button Grid.Column="2"
					Style="{StaticResource MaterialDesignIconButton}"
					Command="{Binding SendMessageCommand}"
					ToolTip="{loc:Loc chat-send_button_hint}">
				<materialDesign:PackIcon Kind="Send"/>
			</Button>
		</Grid>
	</materialDesign:Card>

</UserControl>
