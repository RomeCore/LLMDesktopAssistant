<UserControl x:Class="LLMDesktopAssistant.LLM.MVVM.UserInputView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<UserControl.Resources>

		<Style x:Key="ControlButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">

			<Setter Property="Width" Value="32"/>
			<Setter Property="Height" Value="32"/>
			<Setter Property="Margin" Value="4"/>

		</Style>

		<Style x:Key="ControlButtonIcon" TargetType="materialDesign:PackIcon">

			<Setter Property="Width" Value="24"/>
			<Setter Property="Height" Value="24"/>

		</Style>

	</UserControl.Resources>

	<Grid>

		<Grid.RowDefinitions>
			<RowDefinition/>
			<RowDefinition Height="auto"/>
		</Grid.RowDefinitions>

		<!-- Text Input -->
		<TextBox Grid.Row="0"
				 materialDesign:HintAssist.Hint="{loc:Loc chat-input_hint}"
				 materialDesign:TextFieldAssist.HasClearButton="True"
				 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
				 Text="{Binding Text, Mode=TwoWay}"
				 VerticalAlignment="Center"
				 TextWrapping="Wrap"
				 AcceptsReturn="True"
				 MaxHeight="120"
				 Foreground="{DynamicResource MaterialDesignBody}"
				 FontSize="16"
				 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			
			<!-- Model Selector -->
			<ctrl:LLModelSelectorControl Grid.Column="0"
										 SelectedModel="{Binding Chat.Settings.ChatModel, Mode=TwoWay}"/>

			<!-- Settings Button -->
			<Button Grid.Column="1"
					Style="{StaticResource ControlButton}"
					Command="{Binding OpenSettingsCommand}"
					ToolTip="{loc:Loc settings}">

				<materialDesign:PackIcon Kind="Cog"
										 Style="{StaticResource ControlButtonIcon}"/>
			</Button>

			<!-- Attach Button -->
			<Button Grid.Column="2"
					Style="{StaticResource ControlButton}"
					ToolTip="{loc:Loc chat-attach_file_hint}">

				<materialDesign:PackIcon Kind="Paperclip"
										 Style="{StaticResource ControlButtonIcon}"/>
			</Button>

			<!-- Send and Cancel Button -->
			<Grid Grid.Column="3" HorizontalAlignment="Right">

				<Button Style="{StaticResource ControlButton}"
						Command="{Binding SendMessageCommand}"
						Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverterInverted}}"
						ToolTip="{loc:Loc chat-send_button_hint}">

					<materialDesign:PackIcon Kind="Send"
											 Style="{StaticResource ControlButtonIcon}"/>
				</Button>

				<Button Style="{StaticResource ControlButton}"
						Command="{Binding CancelGenerationCommand}"
						Visibility="{Binding IsGenerating, Converter={StaticResource BooleanToVisibilityConverter}}"
						ToolTip="{loc:Loc chat-stop_button_hint}">

					<materialDesign:PackIcon Kind="Stop"
											 Style="{StaticResource ControlButtonIcon}"/>
				</Button>

			</Grid>

		</Grid>
	</Grid>

</UserControl>
