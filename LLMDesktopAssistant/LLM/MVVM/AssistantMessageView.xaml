<UserControl x:Class="LLMDesktopAssistant.LLM.MVVM.AssistantMessageView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.LLM.MVVM"
			 xmlns:controls="clr-namespace:LLMDesktopAssistant.Controls"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<Border Grid.Column="1"
			Margin="40,8"
			HorizontalAlignment="Left"
			Padding="12,8"
			Background="{DynamicResource MaterialDesignCardBackground}"
			CornerRadius="16 16 16 4"
			MaxWidth="600"
			controls:ProcessingAnimationBehavior.NormalColor="#FF454545"
			controls:ProcessingAnimationBehavior.ProcessingColor="#FF777777"
			controls:ProcessingAnimationBehavior.IsProcessing="{Binding State, Converter={StaticResource AssistantMessageStateToBooleanConverter}}"
			controls:ProcessingAnimationBehavior.AnimationSpeed="0.8">

		<ItemsControl ItemsSource="{Binding MessageParts}"
					  Foreground="{DynamicResource MaterialDesignBody}"
					  HorizontalContentAlignment="Left">
		</ItemsControl>

	</Border>

</UserControl>