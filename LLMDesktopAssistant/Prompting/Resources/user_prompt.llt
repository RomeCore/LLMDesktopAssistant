@template user_message_prompt
{
	@metadata
	{
		lang: 'en-US'
	}
	[USER MESSAGE FROM: @user_name]
	[MESSAGE SENT AT: @time_sent]
	@if can_read_attachments && attachments
	{
		@foreach attachment in attachments
		{
			[ATTACHMENT]
			File: @attachment.LocalPath
			Size: @attachment.DisplaySize
		}
		[END OF ATTACHMENTS]
		Note that attachments also can be accessed via various tools, like python, shell or filesystem.
		Look at the preview or full content to understand the structure of the attachments (if it's available).
	}
	@if can_read_content
	{
		[CONTENT]
		@content
	}
}