@template foreign_assistant_prompt
{
	@metadata
	{
		lang: 'en-US'
	}
	[OTHER AGENT MESSAGE FROM: '@agent_name']:
	[MESSAGE SENT AT: @time_sent]
	@if can_read_reasoning && reasoning_content
	{
		[REASONING]:
		@reasoning_content
	}
	@if can_read_content
	{
		[CONTENT]:
		@content
	}
	@if tool_calls
	{
		@if can_read_tool_calls
		{
			[TOOL CALLS]:
			@foreach tool_call in tool_calls
			{
				- @tool_call.name:
				[ARGUMENTS: @tool_call.arguments]
				@tool_call.result_content
			}
		}
		else
		{
			[TOOL CALLS]:
			@foreach tool_call in tool_calls
			{
				- @tool_call.name:
				[ARGUMENTS: @tool_call.arguments]
				[RESULT HIDDEN]
			}
		}
	}
}