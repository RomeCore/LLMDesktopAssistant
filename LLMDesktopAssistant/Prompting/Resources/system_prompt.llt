@template system_prompt
{
	@if prompt
	{
		@prompt
	}
	@foreach component in components
	{
		@component
	}
	@if persona
	{
		Act as:
		@persona
	}
	@if assistantNickname
	{
		Your alternate name is:
		@assistantNickname
	}
	@if userNickname
	{
		Call user as:
		@userNickname
	}
	@if summary
	{
		There is summary of previous messages in the conversation:
		@summary
	}
}