@template system_prompt
{
	@metadata
	{
		lang: 'en-US'
	}
	@if prompt
	{
		@prompt
	}
	@foreach component in components
	{
		@component
	}
	@foreach slider in sliders
	{
		@slider
	}
	@if persona
	{
		Act as:
		@persona
	}
	@if specialization
	{
		Your specialization is:
		@specialization
	}
	@if persona && specialization
	{
		Integrate your personality with your specialization naturally.
		Your personality defines who you are, your specialization defines what you do.
	}
	@if assistantNickname
	{
		Your alternate name is:
		@assistantNickname
	}
	@if summary
	{
		There is summary of previous messages in the conversation:
		@summary
	}
}
