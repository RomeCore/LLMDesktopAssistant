<UserControl x:Class="LLMDesktopAssistant.Browsing.BrowserView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Browsing"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<materialDesign:DrawerHost OpenMode="Standard">

		<materialDesign:DrawerHost.RightDrawerContent>

			<ContentControl Content="{Binding SelectedTab.Chat}"
							Width="500"/>

		</materialDesign:DrawerHost.RightDrawerContent>

		<Grid>

			<TabControl ItemsSource="{Binding TabItems}"
						SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
						TabStripPlacement="Top"
						materialDesign:TabAssist.HeaderPanelMargin="0,0,100,0">

				<TabControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal">
							<TextBlock Text="{Binding Title}"/>
							<Button Style="{StaticResource MaterialDesignToolButton}">
								<materialDesign:PackIcon Kind="Close"
														 Width="12"
														 Height="12"/>
							</Button>
						</StackPanel>
					</DataTemplate>
				</TabControl.ItemTemplate>

				<TabControl.ContentTemplate>
					<DataTemplate>
						<ContentControl Content="{Binding}" />
					</DataTemplate>
				</TabControl.ContentTemplate>

			</TabControl>

			<ToggleButton x:Name="ChatToggleButton"
						  Style="{StaticResource MaterialDesignFlatToggleButton}"
						  HorizontalAlignment="Right"
						  VerticalAlignment="Top"
						  Margin="5">

				<materialDesign:PackIcon Kind="ListBox"
										 Width="20"
										 Height="20"/>

			</ToggleButton>

		</Grid> 

	</materialDesign:DrawerHost>
	
</UserControl>
