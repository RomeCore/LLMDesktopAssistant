<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:LLMDesktopAssistant.ApiKeys"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="350"
			 x:Class="LLMDesktopAssistant.ApiKeys.AddApiKeyDialogView"
			 x:DataType="local:AddApiKeyDialogViewModel">

	<StackPanel Orientation="Vertical" Spacing="10" Margin="16" Width="380">

		<!-- Header -->
		<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
			<ico:MaterialIcon Kind="KeyPlus" Width="20" Height="20" 
							  VerticalAlignment="Center"
							  Foreground="{DynamicResource PrimaryAccentBrush}"/>
			<TextBlock Text="{Binding TitleText}"
					   FontSize="{DynamicResource FontSizeL}"
					   FontWeight="Bold"
					   VerticalAlignment="Center"/>
		</StackPanel>

		<!-- Error message -->
		<Border Background="#33FF0000" 
				CornerRadius="4" 
				Padding="8"
				IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNonEmptyToBooleanConverter}}">
			<TextBlock Text="{Binding ErrorMessage}" 
					   Foreground="Red"/>
		</Border>

		<!-- Name -->
		<StackPanel Orientation="Vertical" Spacing="4">
			<TextBlock Text="{loc:Loc settings_apikey_name}"
					   FontWeight="Medium"/>
			<TextBox Text="{Binding Name, Mode=TwoWay}"
					 PlaceholderText="{loc:Loc settings_apikey_name_placeholder}"/>
		</StackPanel>

		<!-- Value -->
		<StackPanel Orientation="Vertical" Spacing="4">
			<TextBlock Text="{loc:Loc settings_apikey_value}"
					   FontWeight="Medium"/>
			<TextBox Text="{Binding Value, Mode=TwoWay}"
					 PlaceholderText="{loc:Loc settings_apikey_value_placeholder}"
					 PasswordChar="•"/>
		</StackPanel>

		<!-- Storage scheme -->
		<StackPanel Orientation="Vertical" Spacing="4">
			<TextBlock Text="{loc:Loc settings_apikey_scheme}"
					   FontWeight="Medium"/>
			<ComboBox SelectedIndex="{Binding Scheme, Mode=TwoWay}">
				<ComboBoxItem Content="{loc:Loc settings_apikey_scheme_raw}"/>
				<ComboBoxItem Content="{loc:Loc settings_apikey_scheme_encrypted}"/>
				<ComboBoxItem Content="{loc:Loc settings_apikey_scheme_env}"/>
			</ComboBox>
		</StackPanel>

		<!-- Buttons -->
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
			<Button Content="{loc:Loc cancel}"
					Command="{Binding CancelCommand}"
					Classes="Secondary"/>
			<Button Content="{Binding ConfirmButtonText}"
					Command="{Binding AddCommand}"
					Classes="Primary"/>
		</StackPanel>

	</StackPanel>

</UserControl>
