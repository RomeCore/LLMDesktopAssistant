<UserControl x:Class="LLMDesktopAssistant.Core.MCP.MCPManagerView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Core.MCP"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Core.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Core.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<Grid Margin="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="250"/>
			<ColumnDefinition Width="10"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<StackPanel Grid.Column="0">

			<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
				
				<Button Command="{Binding AddCommand}"
						Style="{StaticResource MaterialDesignIconButton}"
						Width="32" Height="32"
						Content="{materialDesign:PackIcon Kind=Plus}"
						ToolTip="{loc:Loc add}"/>

				<Button Command="{Binding RemoveCommand}"
						Style="{StaticResource MaterialDesignIconButton}"
						Width="32" Height="32"
						Content="{materialDesign:PackIcon Kind=Delete}"
						Margin="5,0,0,0"
						ToolTip="{loc:Loc remove}"/>
				
			</StackPanel>

			<ListBox ItemsSource="{Binding Servers}"
					 SelectedItem="{Binding SelectedServer}">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon Kind="LanConnect"
													 Width="16"
													 Margin="0,0,5,0"/>

							<TextBlock Text="{Binding Info.Name}"/>

							<Ellipse Width="8" Height="8"
									 Margin="5,0,0,0"
									 Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}"
									 Fill="LightGreen"/>
						</StackPanel>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

		</StackPanel>

		<StackPanel Grid.Column="2"
					DataContext="{Binding SelectedServer}"
					Visibility="{Binding Converter={StaticResource NotnullToVisibilityConverter}}">

			<TextBox Text="{Binding Info.Name, Mode=TwoWay}"
					 Style="{StaticResource MaterialDesignOutlinedTextBox}"
					 materialDesign:HintAssist.Hint="{loc:Loc name}"
					 Margin="0,0,0,15"/>

			<ComboBox SelectedItem="{Binding Info.ConnectionType, Mode=TwoWay}"
					  ItemsSource="{Binding ConnectionTypes}"
					  materialDesign:HintAssist.Hint="{loc:Loc mcp-connection_type}"
					  Style="{StaticResource MaterialDesignOutlinedComboBox}"
					  Margin="0,0,0,15"/>

			<TextBox Text="{Binding Info.Endpoint, Mode=TwoWay}"
					 Style="{StaticResource MaterialDesignOutlinedTextBox}"
					 materialDesign:HintAssist.Hint="{loc:Loc mcp-endpoint}"
					 Margin="0,0,0,15"/>

			<Grid HorizontalAlignment="Left">

				<Button Content="{loc:Loc connect}"
						Command="{Binding ConnectCommand}"
						Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverterInverted}}"/>

				<Button Content="{loc:Loc disconnect}"
						Command="{Binding DisconnectCommand}"
						Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}"/>

			</Grid>

		</StackPanel>
	</Grid>

</UserControl>
