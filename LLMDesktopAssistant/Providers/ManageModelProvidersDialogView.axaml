<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:LLMDesktopAssistant.Providers"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
			 x:Class="LLMDesktopAssistant.Providers.ManageModelProvidersDialogView"
			 x:DataType="local:ManageModelProvidersDialogViewModel">

	<StackPanel Orientation="Vertical" Spacing="8" Margin="16" Width="560" MinHeight="300">

		<!-- Header -->
		<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
			<ico:MaterialIcon Kind="Cloud" Width="20" Height="20"
							  VerticalAlignment="Center"
							  Foreground="{DynamicResource PrimaryAccentBrush}"/>
			<TextBlock Text="{loc:Loc settings_providers_manage_title}"
					   FontSize="{DynamicResource FontSizeL}"
					   FontWeight="Bold"
					   VerticalAlignment="Center"/>
		</StackPanel>

		<!-- Toolbar -->
		<StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4"
					HorizontalAlignment="Left">
			<Button Command="{Binding AddCommand}"
					Classes="Primary">
				<StackPanel Orientation="Horizontal" Spacing="4">
					<ico:MaterialIcon Kind="AddCircle" Width="14" Height="14"/>
					<TextBlock Text="{loc:Loc settings_providers_add}"/>
				</StackPanel>
			</Button>

			<Button Command="{Binding EditCommand}"
					IsEnabled="{Binding IsProviderSelected}">
				<StackPanel Orientation="Horizontal" Spacing="4">
					<ico:MaterialIcon Kind="Edit" Width="14" Height="14"/>
					<TextBlock Text="{loc:Loc settings_providers_edit}"/>
				</StackPanel>
			</Button>

			<Button Command="{Binding DeleteCommand}"
					IsEnabled="{Binding IsProviderSelected}"
					Classes="Danger">
				<StackPanel Orientation="Horizontal" Spacing="4">
					<ico:MaterialIcon Kind="Delete" Width="14" Height="14"/>
					<TextBlock Text="{loc:Loc settings_providers_delete}"/>
				</StackPanel>
			</Button>
		</StackPanel>

		<!-- Provider list -->
		<ListBox ItemsSource="{Binding Providers}"
				 SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
				 MinHeight="200">
			<ListBox.DataTemplates>
				<DataTemplate x:DataType="local:ProviderDisplayItem">
					<StackPanel Orientation="Horizontal" Spacing="8" Margin="4,3">
						<ico:MaterialIcon Kind="Cloud"
										  Width="14" Height="14"
										  VerticalAlignment="Center"
										  Opacity="0.7"/>
						<StackPanel Orientation="Vertical">
							<TextBlock Text="{Binding Name}"
									   FontWeight="Medium"/>
							<StackPanel Orientation="Horizontal" Spacing="12">
								<TextBlock Text="{Binding Type}"
										   FontSize="{DynamicResource FontSizeS}"
										   Opacity="0.6"/>
								<TextBlock Text="{Binding ModelCount}"
										   FontSize="{DynamicResource FontSizeS}"
										   Opacity="0.6"/>
								<TextBlock Text="{Binding ConnectionStatus}"
										   FontSize="{DynamicResource FontSizeS}"
										   Foreground="{DynamicResource PrimaryAccentBrush}"/>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</DataTemplate>
			</ListBox.DataTemplates>
		</ListBox>

		<!-- Close button -->
		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
			<Button Content="{loc:Loc settings_providers_close}"
					Command="{Binding CloseCommand}"/>
		</StackPanel>

	</StackPanel>

</UserControl>
