<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="LLMDesktopAssistant.App"
			 xmlns:mvvm="using:LLMDesktopAssistant.MVVM"
			 xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 xmlns:fluentAvalonia="using:FluentAvalonia.Styling"
			 RequestedThemeVariant="Dark">
  
	<Application.Styles>
		<FluentTheme />
		<fluentAvalonia:FluentAvaloniaTheme />
		<materialIcons:MaterialIconStyles />
		<StyleInclude Source="avares://LiveMarkdown.Avalonia/Styles.axaml"/>
		
		<StyleInclude Source="avares://LLMDesktopAssistant/Styles/CommonStyles.axaml"/>
		<StyleInclude Source="avares://LLMDesktopAssistant/Styles/ButtonsIcons.axaml"/>
		<StyleInclude Source="avares://LLMDesktopAssistant/Styles/MarkdownStyles.axaml"/>
	</Application.Styles>

	<Application.Resources>
		<ResourceDictionary>
			
			<ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="avares://LiveMarkdown.Avalonia/Defaults.axaml"/>
				
				<ResourceInclude Source="avares://LLMDesktopAssistant/Styles/MarkdownResources.axaml"/>
				<ResourceInclude Source="avares://LLMDesktopAssistant/Styles/Resources.axaml"/>
				<ResourceInclude Source="avares://LLMDesktopAssistant/Styles/Converters.axaml"/>
			</ResourceDictionary.MergedDictionaries>

		</ResourceDictionary>
	</Application.Resources>
	
	<Application.DataTemplates>
		<mvvm:ViewLocator />
	</Application.DataTemplates>

</Application>