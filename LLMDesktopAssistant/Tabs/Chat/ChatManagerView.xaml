<UserControl x:Class="LLMDesktopAssistant.Tabs.Chat.ChatManagerView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Tabs.Chat"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Localization"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<materialDesign:DrawerHost>

		<materialDesign:DrawerHost.RightDrawerContent>
			<DockPanel Width="320">

				<StackPanel Orientation="Horizontal" Margin="8" DockPanel.Dock="Top">
					<TextBlock Text="{loc:Loc chats}"
							   Foreground="{DynamicResource MaterialDesignBody}"
							   FontSize="18"
							   VerticalAlignment="Center"
							   Margin="8"/>

					<Button Command="{Binding CreateConversationCommand}"
							Style="{StaticResource MaterialDesignIconButton}"
							ToolTip="{loc:Loc new_chat}">
						<materialDesign:PackIcon Kind="Plus"/>
					</Button>
				</StackPanel>

				<ListBox ItemsSource="{Binding Conversations}"
						 SelectedItem="{Binding SelectedConversation}"
						 Style="{StaticResource MaterialDesignChoiceChipListBox}"
						 Margin="8">

					<ListBox.ItemTemplate>
						<DataTemplate>
							
							<DockPanel>



								<Label Content="{Binding Title}"/>

							</DockPanel>
							
						</DataTemplate>
					</ListBox.ItemTemplate>
					
				</ListBox>
				
			</DockPanel>
		</materialDesign:DrawerHost.RightDrawerContent>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition/>
			</Grid.RowDefinitions>

			<!-- TOP BAR -->
			<DockPanel Background="{DynamicResource MaterialDesignPaper}">

				<TextBlock Text="{Binding SelectedConversation.Title}"
						   Foreground="{DynamicResource MaterialDesignBody}"
						   VerticalAlignment="Center"
						   DockPanel.Dock="Left"
						   Margin="16,0,0,0"
						   FontSize="16"/>

				<Button Style="{StaticResource MaterialDesignIconButton}"
						Command="{x:Static materialDesign:DrawerHost.OpenDrawerCommand}"
						DockPanel.Dock="Right"
						HorizontalAlignment="Right">
					<materialDesign:PackIcon Kind="Menu"/>
				</Button>
				
			</DockPanel>

			<!-- CHAT -->
			<ContentControl Grid.Row="1"
							Content="{Binding CurrentChat}"/>
		</Grid>

	</materialDesign:DrawerHost>
	
</UserControl>
