<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:LLMDesktopAssistant.Tools.MVVM.Diff"
             xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:utils="using:LLMDesktopAssistant.Utils.Files"
			 xmlns:material="using:Material.Icons.Avalonia"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="LLMDesktopAssistant.Tools.MVVM.Diff.TextDiffAdditionalView"
			 x:DataType="local:TextDiffAdditionalViewModel">

	<Border BorderBrush="{DynamicResource CardBorderBrush}"
			BorderThickness="1"
			CornerRadius="6"
			Margin="4"
			Padding="0"
			HorizontalAlignment="Stretch"
			MaxHeight="600">

		<Grid RowDefinitions="Auto,*,Auto">

			<!-- Header -->
			<Border Grid.Row="0"
							Padding="8,6"
							CornerRadius="6,6,0,0">

				<Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

					<!-- Icon -->
					<material:MaterialIcon Kind="FileDocumentEditOutline"
																 Grid.Row="0" Grid.Column="0"
																 Width="18" Height="18"
																 Opacity="0.6"
																 Margin="0,0,6,0"
																 VerticalAlignment="Center"/>

					<!-- Title -->
					<TextBlock Text="{Binding Title}"
										 Grid.Row="0" Grid.Column="1"
										 FontSize="13"
										 FontWeight="SemiBold"
										 TextTrimming="CharacterEllipsis"
										 VerticalAlignment="Center"/>

					<!-- Stats -->
					<StackPanel Orientation="Horizontal" Spacing="4"
											Grid.Row="0" Grid.Column="2"
											VerticalAlignment="Center"
											Margin="8,0,0,0">
						<Border Background="#1B8B3A40" CornerRadius="3" Padding="4,1">
							<TextBlock Text="{Binding TotalAdded, StringFormat='+{0}'}"
												 FontSize="11"
												 FontWeight="SemiBold"
												 Foreground="#4CAF50"/>
						</Border>
						<Border Background="#8B1A1A40" CornerRadius="3" Padding="4,1">
							<TextBlock Text="{Binding TotalRemoved, StringFormat='-{0}'}"
												 FontSize="11"
												 FontWeight="SemiBold"
												 Foreground="#F44336"/>
						</Border>
					</StackPanel>

					<!-- Description -->
					<TextBlock Text="{Binding Description}"
										 Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
										 FontSize="11"
										 Opacity="0.5"
										 Margin="0,2,0,0"
										 TextTrimming="CharacterEllipsis"/>

				</Grid>
			</Border>

			<!-- Diff Content -->
			<ScrollViewer Grid.Row="1"
										HorizontalScrollBarVisibility="Auto"
										VerticalScrollBarVisibility="Auto"
										Background="#0D000000">

				<ItemsControl ItemsSource="{Binding Chunks}">

					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Spacing="0"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>

					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="utils:HunkGroup">

							<Border Padding="0" Margin="0" CornerRadius="0"
											BorderThickness="0,0,0,0">

								<Grid RowDefinitions="Auto,*" Margin="0">

									<!-- Chunk header -->
									<Border Grid.Row="0"
													Background="#1A000000"
													Padding="8,2,8,2">

										<TextBlock FontFamily="Cascadia Code,Consolas,monospace"
															 FontSize="11"
															 Opacity="0.7"
															 TextTrimming="CharacterEllipsis"
															 VerticalAlignment="Center">
											<Run Text="@@ -"/>
											<Run Text="{Binding OldStart}"/>
											<Run Text=","/>
											<Run Text="{Binding OldCount}"/>
											<Run Text=" +"/>
											<Run Text="{Binding NewStart}"/>
											<Run Text=","/>
											<Run Text="{Binding NewCount}"/>
											<Run Text=" @@"/>
										</TextBlock>
									</Border>

									<!-- Lines -->
									<ItemsControl Grid.Row="1"
												  ItemsSource="{Binding Lines}"
												  Margin="0,0,0,0">

										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<StackPanel Spacing="0"/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>

										<ItemsControl.ItemTemplate>
											<DataTemplate x:DataType="utils:HunkLine">
												<Border Padding="8,0,8,0"
																Background="{Binding Kind, Converter={StaticResource DiffLineBackgroundConverter}}"
																MinHeight="20">
													<Grid ColumnDefinitions="20,*">
														<!-- Line kind indicator -->
														<TextBlock Text="{Binding Kind}"
																			 FontFamily="Cascadia Code,Consolas,monospace"
																			 FontSize="12"
																			 Foreground="{Binding Kind, Converter={StaticResource DiffLineForegroundConverter}}"
																			 VerticalAlignment="Center"
																			 HorizontalAlignment="Center"/>

														<!-- Content -->
														<TextBlock Grid.Column="1"
																			 Text="{Binding Content}"
																			 FontFamily="Cascadia Code,Consolas,monospace"
																			 FontSize="12"
																			 Foreground="{DynamicResource DefaultForeground}"
																			 TextWrapping="NoWrap"
																			 VerticalAlignment="Center"/>
													</Grid>
												</Border>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>

								</Grid>
							</Border>

						</DataTemplate>
					</ItemsControl.ItemTemplate>

				</ItemsControl>

			</ScrollViewer>

			<!-- Footer (confirmation mode only) -->
			<Border Grid.Row="2"
					Padding="8,6"
					CornerRadius="0,0,6,6"
					IsVisible="{Binding !IsReadOnly}">

				<StackPanel Orientation="Horizontal" Spacing="8"
										HorizontalAlignment="Left">

					<!-- Decline -->
					<Button Command="{Binding DeclineCommand}"
									Classes="Danger"
									FontSize="12"
									Padding="8,2"
									IsVisible="{Binding IsPending}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<material:MaterialIcon Kind="Close"
																	   Width="14" Height="14"/>
							<TextBlock Text="{loc:Loc 'fs-diff_decline'}"/>
						</StackPanel>
					</Button>

					<!-- Confirm -->
					<Button Command="{Binding ConfirmCommand}"
									Classes="Primary"
									FontSize="12"
									Padding="8,2"
									IsVisible="{Binding IsPending}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<material:MaterialIcon Kind="Check"
																	   Width="14" Height="14"/>
							<TextBlock Text="{loc:Loc 'fs-diff_confirm'}"/>
						</StackPanel>
					</Button>

					<!-- Accepted state -->
					<Border Background="#1B8B3A40" CornerRadius="3" Padding="8,2"
									IsVisible="{Binding IsAccepted}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<material:MaterialIcon Kind="CheckCircle"
																		 Width="14" Height="14"
																		 Foreground="#4CAF50"/>
							<TextBlock Text="{loc:Loc 'fs-diff_accepted'}"
												 FontSize="12"
												 FontWeight="SemiBold"
												 Foreground="#4CAF50"/>
						</StackPanel>
					</Border>

					<!-- Declined state -->
					<Border Background="#8B1A1A40" CornerRadius="3" Padding="8,2"
									IsVisible="{Binding IsDeclined}">
						<StackPanel Orientation="Horizontal" Spacing="4">
							<material:MaterialIcon Kind="CloseCircle"
																		 Width="14" Height="14"
																		 Foreground="#F44336"/>
							<TextBlock Text="{loc:Loc 'fs-diff_declined'}"
												 FontSize="12"
												 FontWeight="SemiBold"
												 Foreground="#F44336"/>
						</StackPanel>
					</Border>

				</StackPanel>
			</Border>

		</Grid>
	</Border>

</UserControl>
