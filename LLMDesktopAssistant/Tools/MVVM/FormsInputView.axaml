<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="350"
			 xmlns:local="using:LLMDesktopAssistant.Tools.MVVM"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.Tools.MVVM.FormsInputView"
			 x:DataType="local:FormsInputViewModel">

	<Border Background="{DynamicResource CardBackground}"
			BorderBrush="{DynamicResource CardBorderBrush}"
			HorizontalAlignment="Left"
			BorderThickness="1"
			CornerRadius="8"
			Padding="16"
			Margin="4"
			MinWidth="280"
			MaxWidth="520">

		<StackPanel Orientation="Vertical" Spacing="10">

			<!-- Title -->
			<TextBlock Text="{Binding Title}"
					   FontSize="16"
					   FontWeight="Bold"
					   TextWrapping="Wrap"/>

			<!-- Description -->
			<TextBlock Text="{Binding Description}"
					   FontSize="13"
					   TextWrapping="Wrap"
					   IsVisible="{Binding Description, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
					   Opacity="0.8"/>

			<!-- Form fields -->
			<ItemsControl ItemsSource="{Binding Fields}"
						  IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Vertical" Spacing="8"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<StackPanel Orientation="Vertical" Spacing="2">
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="{Binding Label}"
										   FontSize="13"
										   TextWrapping="Wrap"
										   VerticalAlignment="Center"/>
								<TextBlock Text="*"
										   Foreground="Red"
											 VerticalAlignment="Bottom"
										   IsVisible="{Binding IsRequired}"/>
							</StackPanel>

							<!-- Field input: uses AcceptsReturn only for multiline type -->
							<TextBox Text="{Binding Value}"
									 PlaceholderText="{Binding Placeholder}"
									 MinLines="3"
									 MaxLines="8"
									 AcceptsReturn="{Binding FieldType, Converter={StaticResource StringEqualsConverter}, ConverterParameter=multiline}"/>

							<!-- Error -->
							<TextBlock Text="{Binding Error}"
									   Foreground="Red"
									   FontSize="11"
									   IsVisible="{Binding Error, Converter={StaticResource StringNonEmptyToBooleanConverter}}"/>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<!-- Submit button -->
			<Button Content="{loc:Loc ok}"
					Command="{Binding SubmitCommand}"
					HorizontalAlignment="Right"
					MinWidth="80"
					IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}"/>

			<!-- Result -->
			<StackPanel Orientation="Horizontal" Spacing="4"
						IsVisible="{Binding IsResultSet}">
				<ico:MaterialIcon Kind="CheckCircle"
								  Width="20" Height="20"
								  Foreground="{DynamicResource SuccessColor}"/>
				<TextBlock Text="{loc:Loc forms_form_submitted}" FontSize="13" Opacity="0.7"/>
			</StackPanel>

		</StackPanel>

	</Border>

</UserControl>
