<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
			 xmlns:local="using:LLMDesktopAssistant.Tools.Forms"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.Tools.Forms.FormsFilePickerView"
			 x:DataType="local:FormsFilePickerViewModel">

	<Border Background="{DynamicResource CardBackground}"
			BorderBrush="{DynamicResource CardBorderBrush}"
			BorderThickness="1"
			CornerRadius="8"
			Padding="16"
			Margin="4"
			MinWidth="280"
			MaxWidth="420">

		<StackPanel Orientation="Vertical" Spacing="10">

			<!-- Заголовок -->
			<TextBlock Text="{Binding Title}"
					   FontSize="16"
					   FontWeight="Bold"
					   TextWrapping="Wrap"/>

			<!-- Описание -->
			<TextBlock Text="{Binding Description}"
					   FontSize="13"
					   TextWrapping="Wrap"
					   IsVisible="{Binding Description, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
					   Opacity="0.8"/>

			<!-- Кнопка выбора файла -->
			<Button Command="{Binding PickCommand}"
					IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<ico:MaterialIcon Kind="File"/>
					<TextBlock Text="Выбрать файл..."/>
				</StackPanel>
			</Button>

			<!-- Выбранный путь -->
			<TextBlock Text="{Binding SelectedPath}"
					   FontSize="12"
					   TextWrapping="Wrap"
					   IsVisible="{Binding SelectedPath, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
					   Opacity="0.7"/>

			<!-- Кнопка подтверждения -->
			<Button Content="OK"
					Command="{Binding SubmitCommand}"
					HorizontalAlignment="Right"
					MinWidth="80"
					IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}"/>

			<!-- Результат -->
			<StackPanel Orientation="Horizontal" Spacing="4"
						IsVisible="{Binding IsResultSet}">
				<ico:MaterialIcon Kind="CheckCircle"
								  Width="20" Height="20"
								  Foreground="{DynamicResource SuccessColor}"/>
				<TextBlock Text="Файл выбран" FontSize="13" Opacity="0.7"/>
			</StackPanel>

		</StackPanel>

	</Border>

</UserControl>
