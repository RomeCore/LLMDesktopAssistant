<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
			 xmlns:local="using:LLMDesktopAssistant.Tools.Forms"
			 xmlns:loc="using:LLMDesktopAssistant.Localization"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.Tools.Forms.FormsFilePickerView"
			 x:DataType="local:FormsFilePickerViewModel">

	<Border Background="{DynamicResource CardBackground}"
			BorderBrush="{DynamicResource CardBorderBrush}"
			HorizontalAlignment="Left"
			BorderThickness="1"
			CornerRadius="8"
			Padding="16"
			Margin="4"
			MinWidth="280"
			MaxWidth="520">

		<StackPanel Orientation="Vertical" Spacing="10">

			<!-- Title -->
			<TextBlock Text="{Binding Title}"
					   FontSize="16"
					   FontWeight="Bold"
					   TextWrapping="Wrap"/>

			<!-- Description -->
			<TextBlock Text="{Binding Description}"
					   FontSize="13"
					   TextWrapping="Wrap"
					   IsVisible="{Binding Description, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
					   Opacity="0.8"/>

			<!-- File picker button -->
			<Button Command="{Binding PickCommand}"
					IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<ico:MaterialIcon Kind="File"/>
					<TextBlock Text="{loc:Loc forms_select_file}"/>
				</StackPanel>
			</Button>

			<!-- Selected paths -->
			<ItemsControl ItemsSource="{Binding SelectedPaths}">
				
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Vertical" Spacing="2"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding}"
											 FontSize="12"
											 TextWrapping="Wrap"
											 Opacity="0.7"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
				
			</ItemsControl>

			<!-- Submit button -->
			<Button Content="{loc:Loc ok}"
							Command="{Binding SubmitCommand}"
							HorizontalAlignment="Left"
							MinWidth="80"
							IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}"/>

			<!-- Result -->
			<StackPanel Orientation="Horizontal" Spacing="4"
									HorizontalAlignment="Left"
									IsVisible="{Binding IsResultSet}">

				<ico:MaterialIcon Kind="CheckCircle"
													Width="20" Height="20"
													Foreground="{DynamicResource SuccessColor}"/>

				<TextBlock Text="{loc:Loc forms_file_selected}" FontSize="13" Opacity="0.7"/>

			</StackPanel>

		</StackPanel>

	</Border>

</UserControl>
