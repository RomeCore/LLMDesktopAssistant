<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
			 xmlns:local="using:LLMDesktopAssistant.Tools.Forms"
			 xmlns:ico="using:Material.Icons.Avalonia"
			 x:Class="LLMDesktopAssistant.Tools.Forms.FormsChoiceView"
			 x:DataType="local:FormsChoiceViewModel"
			 x:Name="Form">

	<Border Background="{DynamicResource CardBackground}"
			BorderBrush="{DynamicResource CardBorderBrush}"
			BorderThickness="1"
			CornerRadius="8"
			Padding="16"
			Margin="4"
			MinWidth="280"
			MaxWidth="420">

		<StackPanel Orientation="Vertical" Spacing="10">

			<!-- Title -->
			<TextBlock Text="{Binding Title}"
					   FontSize="16"
					   FontWeight="Bold"
					   TextWrapping="Wrap"/>

			<!-- Description -->
			<TextBlock Text="{Binding Description}"
					   FontSize="13"
					   TextWrapping="Wrap"
					   IsVisible="{Binding Description, Converter={StaticResource StringNonEmptyToBooleanConverter}}"
					   Opacity="0.8"/>

			<!-- Hint -->
			<TextBlock FontSize="11" Opacity="0.5"
					   IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}">
				<TextBlock.Text>
					<Binding Path="AllowMultiple"/>
				</TextBlock.Text>
			</TextBlock>

			<ItemsControl ItemsSource="{Binding Options}"
						  IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Vertical" Spacing="4"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
				<ItemsControl.ItemTemplate>
					<DataTemplate>
						<Button Content="{Binding Label}"
								Command="{Binding #Form.DataContext.ToggleCommand}"
								CommandParameter="{Binding}"
								HorizontalAlignment="Stretch"
								Classes="ChoiceOption"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>

			<TextBox Text="{Binding CustomInput}"
					 PlaceholderText="Свой вариант..."
					 IsVisible="{Binding AllowCustom}"/>

			<Button Content="OK"
					Command="{Binding SubmitCommand}"
					HorizontalAlignment="Right"
					MinWidth="80"
					IsVisible="{Binding IsResultSet, Converter={StaticResource InverseBooleanConverter}}"/>

			<StackPanel Orientation="Horizontal" Spacing="4"
						IsVisible="{Binding IsResultSet}">
				<ico:MaterialIcon Kind="CheckCircle"
								  Width="20" Height="20"
								  Foreground="{DynamicResource SuccessColor}"/>
				<TextBlock Text="Выбор подтверждён" FontSize="13" Opacity="0.7"/>
			</StackPanel>

		</StackPanel>

	</Border>

</UserControl>
