<UserControl x:Class="LLMDesktopAssistant.Core.Settings.SettingsCategoryView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:LLMDesktopAssistant.Core.Settings"
			 xmlns:ctrl="clr-namespace:LLMDesktopAssistant.Core.Controls"
			 xmlns:loc="clr-namespace:LLMDesktopAssistant.Core.Localization"
			 xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800">

	<GroupBox Padding="0">

		<GroupBox.Header>

			<Grid HorizontalAlignment="Left">

				<Grid.ColumnDefinitions>
					<ColumnDefinition/>
					<ColumnDefinition/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0"
						   Margin="5,0"
						   Text="{loc:Loc settings_profile}"
						   FontWeight="Bold"
						   VerticalAlignment="Center"/>

				<Grid Grid.Column="1"
					  Visibility="{Binding IsEditingId, Converter={StaticResource BooleanToVisibilityConverterInverted}}">

					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="auto"/>
						<ColumnDefinition Width="auto"/>
						<ColumnDefinition Width="auto"/>
					</Grid.ColumnDefinitions>

					<ComboBox Grid.Column="0"
							  MinWidth="150"
							  Margin="0,0,5,0"
							  VerticalAlignment="Center"
							  SelectedItem="{Binding CurrentId}"
							  ItemsSource="{Binding Ids}"
							  Visibility="{Binding IsEditingId, Converter={StaticResource BooleanToVisibilityConverterInverted}}"/>

					<Button Grid.Column="1"
							Command="{Binding CreateNewIdCommand}"
							Style="{StaticResource MaterialDesignIconForegroundButton}"
							Width="24" Height="24">

						<materialDesign:PackIcon Kind="Plus"
							 Width="16" Height="16"/>

					</Button>

					<Button Grid.Column="2"
							Command="{Binding RenameIdCommand}"
							Style="{StaticResource MaterialDesignIconForegroundButton}"
							Width="24" Height="24">

						<materialDesign:PackIcon Kind="Edit"
							 Width="16" Height="16"/>

					</Button>

					<Button Grid.Column="3"
							Command="{Binding RemoveIdCommand}"
							Style="{StaticResource MaterialDesignIconForegroundButton}"
							Width="24" Height="24">

						<materialDesign:PackIcon Kind="Remove"
							 Width="16" Height="16"/>

					</Button>

				</Grid>

				<Grid Grid.Column="1"
					  Visibility="{Binding IsEditingId, Converter={StaticResource BooleanToVisibilityConverter}}">

					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="auto"/>
						<ColumnDefinition Width="auto"/>
					</Grid.ColumnDefinitions>

					<TextBox Grid.Column="0"
							 VerticalAlignment="Center"
							 MinWidth="150"
							 Text="{Binding NewId}"/>

					<Button Grid.Column="1"
							Command="{Binding ConfirmEditIdCommand}"
							Style="{StaticResource MaterialDesignIconForegroundButton}"
							Width="24" Height="24">

						<materialDesign:PackIcon Kind="Check"
							 Width="16" Height="16"/>

					</Button>

					<Button Grid.Column="2"
							Command="{Binding CancelEditIdCommand}"
							Style="{StaticResource MaterialDesignIconForegroundButton}"
							Width="24" Height="24">

						<materialDesign:PackIcon Kind="Cancel"
							 Width="16" Height="16"/>

					</Button>

				</Grid>

			</Grid>

		</GroupBox.Header>

		<ContentControl Content="{Binding CurrentViewModel}"/>

	</GroupBox>
</UserControl>
